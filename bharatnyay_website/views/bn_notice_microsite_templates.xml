<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="bn_notice_microsite_page" name="Notice QR response">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <section class="container py-5 col-lg-8 mx-auto">
                    <t t-if="thanks">
                        <h1 class="mb-3">Thank you</h1>
                        <p class="lead">Your arbitrator preference has been recorded on the BharatNyay case file.</p>
                        <p class="text-muted">You may close this page. The case team may contact you with next steps.</p>
                    </t>
                    <t t-else="">
                        <h1 class="mb-2">BharatNyay notice response</h1>
                        <p class="text-muted mb-4">
                            Loan <strong t-esc="loan.loan_number"/> · Case <strong t-esc="loan.case_number or '—'"/>
                        </p>
                        <t t-if="error">
                            <div class="alert alert-danger" role="alert">
                                <span t-esc="error"/>
                            </div>
                        </t>
                        <div class="card shadow-sm mb-4">
                            <div class="card-body">
                                <p><strong>OTP (demo)</strong>: enter the 6-digit code shown on your notice email.</p>
                                <form id="bn_notice_form"
                                      t-attf-action="/bn/respond/{{ line.qr_access_token }}"
                                      t-attf-data-slots-url="/bn/respond/{{ line.qr_access_token }}/slots"
                                      method="post"
                                      class="o_mark_required">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="grid_selected_index" id="bn_grid_selected_index" value="0"/>
                                    <div class="mb-3">
                                        <label class="form-label">OTP</label>
                                        <input class="form-control" type="text" name="otp" maxlength="8" required="required"/>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Choose arbitrator</label>
                                        <select class="form-select" name="arbitrator_id" id="bn_arbitrator_id" required="required">
                                            <option value="">—</option>
                                            <t t-foreach="arbitrators" t-as="u">
                                                <option t-att-value="u.id"><t t-esc="u.name"/></option>
                                            </t>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label" for="bn_scheduler_date">Preferred hearing day</label>
                                        <input type="date"
                                               class="form-control"
                                               name="scheduler_date"
                                               id="bn_scheduler_date"
                                               t-att-value="default_scheduler_date"
                                               required="required"/>
                                    </div>
                                    <div class="mb-3 bn-notice-slot-wrap" id="bn_slot_section" style="display: none;">
                                        <label class="form-label d-block">Pick a time slot</label>
                                        <div class="bn-slot-legend">
                                            <span class="lg-free"><i/> Free</span>
                                            <span class="lg-booked"><i/> Booked</span>
                                            <span class="lg-unavail"><i/> Unavailable</span>
                                        </div>
                                        <div id="bn_slot_grid" class="bn-slot-grid" role="grid" aria-label="Hearing time slots"/>
                                        <p class="text-muted small mb-0" id="bn_slot_hint"/>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Additional notes (optional)</label>
                                        <textarea class="form-control" name="preferred_slot_notes" rows="2" placeholder="Any special requests for the hearing"/>
                                    </div>
                                    <div class="form-check mb-3">
                                        <input class="form-check-input" type="checkbox" name="consent" value="1" id="bn_consent" required="required"/>
                                        <label class="form-check-label" for="bn_consent">
                                            I confirm that I am authorised to submit this preference for the borrower on this loan.
                                        </label>
                                    </div>
                                    <button type="submit" class="btn btn-primary">Submit</button>
                                </form>
                            </div>
                        </div>
                    </t>
                </section>
            </div>
        </t>
    </template>
</odoo>
