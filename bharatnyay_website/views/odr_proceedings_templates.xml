<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="page_odr_proceedings" name="ODR proceedings primer">
        <t t-call="website.layout">
            <t t-set="no_footer" t-value="True"/>
            <div id="wrap">
                <t t-set="bn_nav_inner" t-value="True"/>
                <t t-call="bharatnyay_website.bn_public_nav"/>
                <div class="bn-about-page">
                    <header class="bn-about-hero text-lg-start bn-hero-split">
                        <div class="container">
                            <div class="bn-hero-inner">
                                <p class="bn-hash mb-3">Education · Procedures</p>
                                <h1><span class="text-orange">ODR</span> proceeding stages you can orchestrate digitally</h1>
                                <p class="mb-0">From intake to interim relief to final outcome, disciplined case management parallels institutional rules published globally — here translated for NBFC portfolios, enterprise disputes, and court-referred ADR programs.</p>
                            </div>
                        </div>
                    </header>
                    <section class="bn-about-body">
                        <div class="container bn-prose bn-prose-page">

                            <div class="bn-prose-block">
                                <span class="bn-prose-kicker">E-Filing</span>
                                <h2>E-Filing and Case Management</h2>
                                <h3>E-Filing and Case Vetting</h3>
                                <p class="bn-prose-lead">The platform enables seamless electronic filing and preliminary scrutiny of cases, ensuring procedural compliance and efficient case administration.</p>
                                <p class="fw-semibold small text-uppercase letter-spacing-sm mb-3" style="letter-spacing:0.08em;color:var(--bn-text-muted-light);">Workflow</p>
                                <t t-call="bharatnyay_website.bn_prose_workflow"/>
                            </div>

                            <div class="bn-prose-block">
                                <span class="bn-prose-kicker">Platform</span>
                                <h2>Platform capabilities on BharatNyay</h2>
                                <p class="bn-prose-lead">End-to-end tooling aligned to arbitration, mediation, and conciliation programmes — governed, transparent, and built for India-facing ODR.</p>
                                <t t-call="bharatnyay_website.bn_prose_capabilities"/>
                            </div>

                            <div class="bn-prose-block">
                                <p class="bn-prose-lead mb-0">Proceedings may run under online mediation, conciliation, or arbitration depending on clause design and party consent.</p>
                                <t t-call="bharatnyay_website.bn_prose_exclusion"/>
                            </div>

                            <div class="bn-prose-cta-bar">
                                <p class="bn-prose-cta-hint">Pair this briefing with BharatNyay’s workflow screens and clause library.</p>
                                <div class="d-flex flex-wrap gap-2">
                                    <a href="/odr/model-clause" class="btn bn-btn-pill-primary btn-sm">Draft clauses →</a>
                                    <a href="/features" class="btn bn-btn-pill-soft btn-sm">Platform features</a>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
                <div class="bn-landing-root"><t t-call="bharatnyay_website.bn_public_footer"/></div>
            </div>
        </t>
    </template>
</odoo>
