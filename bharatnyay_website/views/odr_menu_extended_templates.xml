<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="page_odr_procedural_rules" name="ODR procedural rules">
        <t t-call="website.layout">
            <t t-set="bn_meta_title">Procedural Rules</t>
            <t t-set="bn_meta_description">BharatNyay procedural rules for digitised arbitration, mediation, and conciliation — timelines, filings, hearings, and enforceable outcomes.</t>
            <t t-set="bn_seo_canonical">/odr/procedural-rules</t>
            <t t-call="bharatnyay_website.bn_page_seo"/>
            <t t-set="no_footer" t-value="True"/>
            <div id="wrap">
                <t t-set="bn_nav_inner" t-value="True"/>
                <t t-call="bharatnyay_website.bn_public_nav"/>
                <div class="bn-about-page">
                    <header class="bn-about-hero text-lg-start bn-hero-split">
                        <div class="container">
                            <div class="bn-hero-inner">
                                <p class="bn-hash mb-3">Education · Rules posture</p>
                                <h1><span class="text-orange">Procedural</span> rules in digitised arbitration &amp; mediation</h1>
                                <p class="mb-0">Parties adopt institutional rulebooks (<em>e.g.</em>, SIAC, ICC, ICA, UNCITRAL) or bespoke charters. BharatNyay encodes timelines, pleadings uploads, arbitrator challenges, confidentiality, interim relief interplay, and tribunal secretary roles so software mirrors the rule narrative — not substitutes it.</p>
                            </div>
                        </div>
                    </header>
                    <section class="bn-about-body">
                        <div class="container bn-prose bn-prose-page">
                            <div class="bn-prose-block">
                                <span class="bn-prose-kicker">Governance</span>
                                <h2>What procedural rules govern on-platform activity?</h2>
                                <t t-call="bharatnyay_website.bn_prose_procedural_rules"/>
                                <div class="bn-prose-note mt-3">
                                    <i class="fa fa-info-circle" aria-hidden="true"/>
                                    <span>Deploy with issuer counsel approving the governing rules text; configure BharatNyay to flag breaches of internal SLAs referencing those rules.</span>
                                </div>
                            </div>
                            <div class="bn-prose-cta-bar">
                                <p class="bn-prose-cta-hint">Explore related ODR education and clause design.</p>
                                <div class="d-flex flex-wrap gap-2">
                                    <a href="/odr/proceedings" class="btn bn-btn-pill-soft btn-sm">Proceedings ladder</a>
                                    <a href="/odr/model-clause" class="btn bn-btn-pill-soft btn-sm">Model clause cues</a>
                                    <a href="/features" class="btn bn-btn-pill-primary btn-sm">Platform features</a>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
                <div class="bn-landing-root"><t t-call="bharatnyay_website.bn_public_footer"/></div>
            </div>
        </t>
    </template>

</odoo>
