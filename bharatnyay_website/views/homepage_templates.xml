<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="homepage" name="BharatNyay Homepage" inherit_id="website.homepage">
        <xpath expr="//div[@id='wrap']" position="before">
            <t t-set="no_footer" t-value="True"/>
            <t t-set="bn_meta_title">Online Dispute Resolution Platform</t>
            <t t-set="bn_meta_description">BharatNyay is India's governed ODR platform for arbitration, mediation, and conciliation. Secure digital dispute resolution aligned with the Arbitration Act 1996.</t>
            <t t-set="bn_seo_canonical">/</t>
            <t t-call="bharatnyay_website.bn_page_seo"/>
        </xpath>
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="oe_structure bn-landing-root">
                <t t-set="bn_nav_inner" t-value="False"/>
                <t t-call="bharatnyay_website.bn_public_nav"/>

                <section class="bn-hero">
                    <div class="container position-relative">
                        <div class="bn-chip"><i class="fa fa-star me-1 text-warning"/> Online Dispute Resolution platform</div>
                        <h1>BharatNyay</h1>
                        <div class="bn-tagline-lg">Click Karo! Resolve Karo!</div>
                        <p class="bn-hero-copy">A comprehensive digital platform facilitating modern dispute resolution mechanisms, including
                            <strong class="text-white">Arbitration</strong>, <strong class="text-white">Mediation</strong>, and <strong class="text-white">Conciliation</strong>.</p>
                        <div class="bn-hero-buttons">
                            <a href="/contactus" class="btn bn-btn-orange">Government →</a>
                            <a href="/contactus" class="btn bn-btn-outline-light border-0">Corporate →</a>
                        </div>
                        <div class="bn-trust-pills">
                            <span><i class="fa fa-gavel me-2"/> Arb. &amp; Conciliation Act 1996</span>
                            <span><i class="fa fa-shield me-2"/> Party autonomy + neutral safeguards</span>
                            <span><i class="fa fa-lock me-2"/> Signed-in workspace</span>
                        </div>
                    </div>
                </section>

                <section class="bn-stats">
                    <div class="container">
                        <div class="row g-3">
                            <div class="col-6 col-md-3"><div class="bn-stat-card"><div class="bn-stat-icon"><i class="fa fa-check"/></div><h3>856+</h3><p>Cases tracked</p></div></div>
                            <div class="col-6 col-md-3"><div class="bn-stat-card"><div class="bn-stat-icon"><i class="fa fa-trophy"/></div><h3>91%</h3><p>Resolution fidelity</p></div></div>
                            <div class="col-6 col-md-3"><div class="bn-stat-card"><div class="bn-stat-icon"><i class="fa fa-clock-o"/></div><h3>14 days</h3><p>SLA target</p></div></div>
                            <div class="col-6 col-md-3"><div class="bn-stat-card"><div class="bn-stat-icon"><i class="fa fa-inr"/></div><h3>₹12.5 Cr+</h3><p>Portfolio value</p></div></div>
                        </div>
                    </div>
                </section>

                <section class="bn-light-section bn-odr-callout-home">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-10">
                                <div class="bn-odr-callout-card bn-prose-muted">
                                    <span class="bn-badge-pill">ODR snapshot</span>
                                    <p class="lead mb-3"><strong>BharatNyay</strong> provides a secure and technology-enabled platform to support Online Dispute Resolution (ODR) proceedings, including Arbitration, Mediation, and Conciliation — with confidential case management, digital evidence submission, transparent procedural workflows, and end-to-end ODR support.</p>
                                    <p class="mb-4">The platform does not undertake negotiation functions unless specifically incorporated within a structured mediation or conciliation process conducted in accordance with applicable law and institutional rules.</p>
                                    <div class="d-flex flex-wrap gap-2 justify-content-center justify-content-lg-start">
                                        <a href="/odr/what-is" class="btn btn-sm bn-btn-pill-primary">What is ODR?</a>
                                        <a href="/odr/proceedings" class="btn btn-sm bn-btn-pill-soft">Proceedings ladder</a>
                                        <a href="/features" class="btn btn-sm bn-btn-pill-soft">Platform fit</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="bn-trusted-strip">
                    <div class="container">
                        <p class="bn-trusted-label mb-0">Trusted by teams across India’s lending ecosystem</p>
                        <div class="bn-trusted-inner">
                            <span>Bajaj Finance</span><span>HDFC Bank</span><span>SBI</span>
                            <span>ICICI Bank</span><span>Axis Bank</span><span>Kotak Mahindra</span>
                        </div>
                    </div>
                </section>

                <section class="bn-light-section scroll-target" id="features">
                    <div class="container">
                        <div class="bn-section-title">
                            <span class="bn-badge-pill">Platform features</span>
                            <h2>Platform Features Mapped to the ODR Process</h2>
                            <p class="lead">A comprehensive digital platform facilitating modern dispute resolution mechanisms, including Arbitration, Mediation, and Conciliation.</p>
                        </div>
                        <div class="row g-4">
                            <div class="col-md-6 col-xl-4">
                                <article class="bn-feature-card"><div class="icon-box"><i class="fa fa-shield"/></div><h4>Secure case management</h4><p>Confidential case management, digital evidence submission, transparent workflows, and neutral adjudication in accordance with applicable laws.</p></article>
                            </div>
                            <div class="col-md-6 col-xl-4">
                                <article class="bn-feature-card"><div class="icon-box"><i class="fa fa-file-text-o"/></div><h4>E-Filing &amp; case vetting</h4><p>Seamless electronic filing and preliminary scrutiny of cases, ensuring procedural compliance and efficient case administration.</p></article>
                            </div>
                            <div class="col-md-6 col-xl-4">
                                <article class="bn-feature-card"><div class="icon-box"><i class="fa fa-video-camera"/></div><h4>Virtual hearings</h4><p>Video-enabled hearing rooms, secure party participation, real-time document sharing, and accessibility from any location.</p></article>
                            </div>
                            <div class="col-md-6 col-xl-4">
                                <article class="bn-feature-card"><div class="icon-box"><i class="fa fa-magic"/></div><h4>AI-assisted support</h4><p>Administrative assistance for data organization, document retrieval, workflow automation, and scheduling — not decision-making.</p></article>
                            </div>
                            <div class="col-md-6 col-xl-4">
                                <article class="bn-feature-card"><div class="icon-box"><i class="fa fa-line-chart"/></div><h4>Transparency &amp; monitoring</h4><p>Real-time status updates, procedural milestone visibility, case progress monitoring, and performance tracking.</p></article>
                            </div>
                            <div class="col-md-6 col-xl-4">
                                <article class="bn-feature-card"><div class="icon-box"><i class="fa fa-comments-o"/></div><h4>Communication &amp; tracking</h4><p>Efficient communication and case tracking mechanisms with end-to-end support for online dispute resolution proceedings.</p></article>
                            </div>
                        </div>
                        <div class="text-center mt-4"><a href="/features" class="bn-link-accent">Full feature briefing →</a></div>
                    </div>
                </section>

                <section class="bn-light-section pb-5" id="how">
                    <div class="container">
                        <div class="bn-section-title">
                            <span class="bn-badge-pill">How it works</span>
                            <h2>E-Filing and Case Management</h2>
                            <p class="lead">From case initiation and vetting through hearings to resolution and outcome — transparent milestones at every step.</p>
                        </div>
                        <div class="row g-3 g-lg-4 text-center">
                            <div class="col-6 col-md-4 col-lg-2">
                                <div class="rounded-4 bg-white bn-step-card p-3 p-lg-4 h-100">
                                    <strong class="d-block fs-5 bn-step-num mb-2">01</strong>
                                    <h6 class="fw-bold mb-2 small">Case initiation</h6>
                                    <p class="bn-step-desc mb-0">Case Initiation and Registration.</p>
                                </div>
                            </div>
                            <div class="col-6 col-md-4 col-lg-2">
                                <div class="rounded-4 bg-white bn-step-card p-3 p-lg-4 h-100">
                                    <strong class="d-block fs-5 bn-step-num mb-2">02</strong>
                                    <h6 class="fw-bold mb-2 small">Case vetting</h6>
                                    <p class="bn-step-desc mb-0">Preliminary Review and Case Vetting.</p>
                                </div>
                            </div>
                            <div class="col-6 col-md-4 col-lg-2">
                                <div class="rounded-4 bg-white bn-step-card p-3 p-lg-4 h-100">
                                    <strong class="d-block fs-5 bn-step-num mb-2">03</strong>
                                    <h6 class="fw-bold mb-2 small">Hearings</h6>
                                    <p class="bn-step-desc mb-0">Scheduling of Hearings.</p>
                                </div>
                            </div>
                            <div class="col-6 col-md-4 col-lg-2">
                                <div class="rounded-4 bg-white bn-step-card p-3 p-lg-4 h-100">
                                    <strong class="d-block fs-5 bn-step-num mb-2">04</strong>
                                    <h6 class="fw-bold mb-2 small">Evidence</h6>
                                    <p class="bn-step-desc mb-0">Submission of Evidence and Documents.</p>
                                </div>
                            </div>
                            <div class="col-6 col-md-4 col-lg-2">
                                <div class="rounded-4 bg-white bn-step-card p-3 p-lg-4 h-100">
                                    <strong class="d-block fs-5 bn-step-num mb-2">05</strong>
                                    <h6 class="fw-bold mb-2 small">Conduct</h6>
                                    <p class="bn-step-desc mb-0">Conduct of Hearings.</p>
                                </div>
                            </div>
                            <div class="col-6 col-md-4 col-lg-2">
                                <div class="rounded-4 bg-white bn-step-card p-3 p-lg-4 h-100">
                                    <strong class="d-block fs-5 bn-step-num mb-2">06</strong>
                                    <h6 class="fw-bold mb-2 small">Outcome</h6>
                                    <p class="bn-step-desc mb-0">Resolution and Issuance of Outcome.</p>
                                </div>
                            </div>
                        </div>
                        <div class="text-center mt-4"><a href="/how-it-works" class="bn-link-accent">Deep dive on timings →</a></div>
                    </div>
                </section>

                <section class="bn-stake-section" id="stakeholders">
                    <div class="container">
                        <div class="bn-section-title">
                            <span class="bn-badge-pill">Our stakeholders</span>
                            <h2>Governance-ready roles</h2>
                            <p class="lead">Consumers, financiers, neutrals, and supervisors converge on one fabric — aligning with fiduciary duties and supervisory expectations for fair recovery (<abbr title="Reserve Bank of India">RBI</abbr>).</p>
                        </div>
                        <div class="row g-4">
                            <div class="col-md-6 col-xl-3"><article class="bn-stake-card"><div class="icon-box"><i class="fa fa-user"/></div><h4>Borrowers</h4><p>Fair EMI disputes, coercion complaints, SARFAESI interplay — mediated channels before escalation.</p></article></div>
                            <div class="col-md-6 col-xl-3"><article class="bn-stake-card"><div class="icon-box"><i class="fa fa-building"/></div><h4>Lenders &amp; NBFCs</h4><p>Repeatable dockets respecting fair practices code timelines and escalation governance.</p></article></div>
                            <div class="col-md-6 col-xl-3"><article class="bn-stake-card"><div class="icon-box"><i class="fa fa-pencil-square-o"/></div><h4>Neutrals</h4><p>Remote case management disclosures, neutrality declarations, remuneration transparency.</p></article></div>
                            <div class="col-md-6 col-xl-3"><article class="bn-stake-card"><div class="icon-box"><i class="fa fa-shield"/></div><h4>Regulators / audit</h4><p>Grievance redress artefacts, SLA telemetry, segregation of duties for sensitive actions.</p></article></div>
                        </div>
                    </div>
                </section>

                <section class="bn-light-section" id="testimonials">
                    <div class="container">
                        <div class="bn-section-title">
                            <span class="bn-badge-pill">Testimonials</span>
                            <h2>Trusted by thousands</h2>
                            <p class="lead small mx-auto">Illustrative stories — customise with live references after deployment.</p>
                        </div>
                        <div class="row g-4">
                            <div class="col-md-4">
                                <blockquote class="bn-testimonial-card">
                                    <div class="stars"><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/></div>
                                    <p class="quote">“Structured ODR ladders closed my EMI overcharge in twelve days.”</p>
                                    <footer class="user-info"><span class="avatar">SR</span><div class="name-box"><h5>Sneha Reddy</h5><p>Borrower, Hyderabad</p></div></footer>
                                </blockquote>
                            </div>
                            <div class="col-md-4">
                                <blockquote class="bn-testimonial-card">
                                    <div class="stars"><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/></div>
                                    <p class="quote">“Neutral dashboards shave hours versus inbox arbitration.”</p>
                                    <footer class="user-info"><span class="avatar">AP</span><div class="name-box"><h5>Adv. Priya Sharma</h5><p>Mediator</p></div></footer>
                                </blockquote>
                            </div>
                            <div class="col-md-4">
                                <blockquote class="bn-testimonial-card">
                                    <div class="stars"><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/></div>
                                    <p class="quote">“Penalty reversal path finally matched our clause library governance.”</p>
                                    <footer class="user-info"><span class="avatar">VE</span><div class="name-box"><h5>Vikram Enterprises</h5><p>MSME borrower, Mumbai</p></div></footer>
                                </blockquote>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="bn-light-section pt-2 pb-5">
                    <div class="container">
                        <div class="bn-cta-box">
                            <h2>Deploy governed ODR for your portfolios</h2>
                            <p class="bn-cta-subtext">Book a blueprint session — neutrality policy, arbitrator panel rules, data residency, escalation matrices, integrations.</p>
                            <div class="d-flex flex-wrap justify-content-center gap-3">
                                <a class="btn bn-cta-orange" href="/contactus">File a dispute now →</a>
                                <a class="btn bn-cta-white" href="/odr/model-clause">Review model clause cues</a>
                            </div>
                        </div>
                    </div>
                </section>

                <t t-call="bharatnyay_website.bn_public_footer"/>
            </div>
        </xpath>
    </template>
</odoo>
