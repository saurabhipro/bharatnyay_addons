<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="homepage" name="BharatNyay Homepage" inherit_id="website.homepage">
        <xpath expr="//div[@id='wrap']" position="before">
            <t t-set="no_footer" t-value="True"/>
            <t t-set="bn_meta_title">Online Dispute Resolution Platform</t>
            <t t-set="bn_meta_description">BharatNyay is India's governed ODR platform for arbitration, mediation, and conciliation. Secure digital dispute resolution aligned with the Arbitration Act 1996.</t>
            <t t-set="bn_seo_canonical">/</t>
            <t t-call="bharatnyay_website.bn_page_seo"/>
        </xpath>
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="oe_structure bn-landing-root">
                <t t-set="bn_nav_inner" t-value="False"/>
                <t t-call="bharatnyay_website.bn_public_nav"/>

                <section class="bn-hero">
                    <div class="container position-relative">
                        <div class="bn-chip"><i class="fa fa-star me-1"/> Online Dispute Resolution platform</div>
                        <h1>BharatNyay</h1>
                        <div class="bn-tagline-lg">Click Karo! Resolve Karo!</div>
                        <p class="bn-hero-copy">A comprehensive digital platform for modern dispute resolution —
                            <strong>Arbitration</strong>, <strong>Mediation</strong>, and <strong>Conciliation</strong> — trusted across India's lending ecosystem.</p>
                        <div class="bn-hero-buttons">
                            <a href="/contactus" class="btn bn-btn-orange">
                                <i class="fa fa-university me-2"/>Government
                            </a>
                            <a href="/contactus" class="btn bn-btn-glass">
                                <i class="fa fa-briefcase me-2"/>Corporate
                            </a>
                        </div>
                        <div class="bn-trust-pills">
                            <span><i class="fa fa-gavel"/> Arb. &amp; Conciliation Act 1996</span>
                            <span><i class="fa fa-shield"/> Party autonomy + neutral safeguards</span>
                            <span><i class="fa fa-lock"/> Signed-in workspace</span>
                        </div>
                    </div>
                </section>

                <section class="bn-stats">
                    <div class="container">
                        <div class="row g-3 g-lg-4">
                            <div class="col-6 col-md-3">
                                <div class="bn-stat-card">
                                    <div class="bn-stat-icon"><i class="fa fa-check-circle"/></div>
                                    <h3>856+</h3>
                                    <p>Cases tracked</p>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="bn-stat-card">
                                    <div class="bn-stat-icon"><i class="fa fa-trophy"/></div>
                                    <h3>91%</h3>
                                    <p>Resolution fidelity</p>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="bn-stat-card">
                                    <div class="bn-stat-icon"><i class="fa fa-bolt"/></div>
                                    <h3>14 days</h3>
                                    <p>SLA target</p>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="bn-stat-card">
                                    <div class="bn-stat-icon"><i class="fa fa-inr"/></div>
                                    <h3>₹12.5 Cr+</h3>
                                    <p>Portfolio value</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="bn-odr-snapshot">
                    <div class="container">
                        <div class="bn-snapshot-card">
                            <div class="row align-items-center g-0">
                                <div class="col-lg-7 bn-snapshot-left">
                                    <span class="bn-snapshot-kicker">
                                        <i class="fa fa-balance-scale" aria-hidden="true"/>
                                        ODR snapshot
                                    </span>
                                    <h2 class="bn-snapshot-title">India's governed<br/><span>dispute resolution</span> platform</h2>
                                    <p class="bn-snapshot-desc">BharatNyay delivers structured Arbitration, Mediation, and Conciliation — with confidential case management, digital evidence, and transparent procedural workflows.</p>
                                    <div class="bn-snapshot-actions">
                                        <a href="/odr/what-is" class="btn bn-btn-pill-primary btn-sm">What is ODR?</a>
                                        <a href="/odr/proceedings" class="btn bn-btn-pill-soft btn-sm">Proceedings</a>
                                        <a href="/features" class="btn bn-btn-pill-soft btn-sm">Platform fit</a>
                                    </div>
                                </div>
                                <div class="col-lg-5 bn-snapshot-right">
                                    <ul class="bn-snapshot-facts">
                                        <li>
                                            <i class="fa fa-shield" aria-hidden="true"/>
                                            <span>Confidential case management &amp; role-based access</span>
                                        </li>
                                        <li>
                                            <i class="fa fa-folder-open-o" aria-hidden="true"/>
                                            <span>Digital evidence submission &amp; immutable audit trail</span>
                                        </li>
                                        <li>
                                            <i class="fa fa-gavel" aria-hidden="true"/>
                                            <span>Neutral adjudication aligned with Arbitration Act 1996</span>
                                        </li>
                                        <li>
                                            <i class="fa fa-line-chart" aria-hidden="true"/>
                                            <span>Real-time milestone visibility &amp; SLA tracking</span>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="bn-trusted-strip" aria-labelledby="bn-trusted-heading">
                    <div class="container">
                        <div class="bn-trusted-head">
                            <span class="bn-trusted-line" aria-hidden="true"/>
                            <p id="bn-trusted-heading" class="bn-trusted-label mb-0">Arbitration is trusted — so these brands are onboarded directly. Trusted across India’s lending ecosystem</p>
                            <span class="bn-trusted-line" aria-hidden="true"/>
                        </div>
                        <ul class="bn-trusted-logos" role="list">
                            <li class="bn-trusted-logo">
                                <img src="/bharatnyay_website/static/src/img/logos/sbin/logo.png"
                                     alt="State Bank of India" loading="lazy" width="220" height="64"/>
                            </li>
                            <li class="bn-trusted-logo">
                                <img src="/bharatnyay_website/static/src/img/logos/hdfc/logo.png"
                                     alt="HDFC Bank" loading="lazy" width="220" height="64"/>
                            </li>
                            <li class="bn-trusted-logo">
                                <img src="/bharatnyay_website/static/src/img/logos/icic/logo.png"
                                     alt="ICICI Bank" loading="lazy" width="220" height="64"/>
                            </li>
                            <li class="bn-trusted-logo">
                                <img src="/bharatnyay_website/static/src/img/logos/barb/logo.png"
                                     alt="Bank of Baroda" loading="lazy" width="220" height="64"/>
                            </li>
                            <li class="bn-trusted-logo">
                                <img src="/bharatnyay_website/static/src/img/logos/punb/logo.png"
                                     alt="Punjab National Bank" loading="lazy" width="220" height="64"/>
                            </li>
                            <li class="bn-trusted-logo">
                                <img src="/bharatnyay_website/static/src/img/logos/utib/logo.png"
                                     alt="Axis Bank" loading="lazy" width="220" height="64"/>
                            </li>
                            <li class="bn-trusted-logo">
                                <img src="/bharatnyay_website/static/src/img/logos/kkbk/logo.png"
                                     alt="Kotak Mahindra Bank" loading="lazy" width="220" height="64"/>
                            </li>
                            <li class="bn-trusted-logo">
                                <img src="/bharatnyay_website/static/src/img/logos/cnrb/logo.png"
                                     alt="Canara Bank" loading="lazy" width="220" height="64"/>
                            </li>
                            <li class="bn-trusted-logo">
                                <img src="/bharatnyay_website/static/src/img/logos/bkid/logo.png"
                                     alt="Bank of India" loading="lazy" width="220" height="64"/>
                            </li>
                            <li class="bn-trusted-logo">
                                <img src="/bharatnyay_website/static/src/img/logos/yesb/logo.png"
                                     alt="Yes Bank" loading="lazy" width="220" height="64"/>
                            </li>
                        </ul>
                    </div>
                </section>

                <section class="bn-light-section scroll-target" id="features">
                    <div class="container">
                        <div class="bn-section-title">
                            <span class="bn-badge-pill">Platform features</span>
                            <h2>Platform Features Mapped to the ODR Process</h2>
                            <p class="lead">A comprehensive digital platform facilitating modern dispute resolution mechanisms, including Arbitration, Mediation, and Conciliation.</p>
                        </div>
                        <div class="row g-4">
                            <div class="col-12 col-md-6 col-xl-4">
                                <article class="bn-feature-card"><div class="icon-box"><i class="fa fa-shield"/></div><h4>Secure case management</h4><p>Confidential case management, digital evidence submission, transparent workflows, and neutral adjudication in accordance with applicable laws.</p></article>
                            </div>
                            <div class="col-12 col-md-6 col-xl-4">
                                <article class="bn-feature-card"><div class="icon-box"><i class="fa fa-file-text-o"/></div><h4>E-Filing &amp; case vetting</h4><p>Seamless electronic filing and preliminary scrutiny of cases, ensuring procedural compliance and efficient case administration.</p></article>
                            </div>
                            <div class="col-12 col-md-6 col-xl-4">
                                <article class="bn-feature-card"><div class="icon-box"><i class="fa fa-video-camera"/></div><h4>Virtual hearings</h4><p>Video-enabled hearing rooms, secure party participation, real-time document sharing, and accessibility from any location.</p></article>
                            </div>
                            <div class="col-12 col-md-6 col-xl-4">
                                <article class="bn-feature-card"><div class="icon-box"><i class="fa fa-magic"/></div><h4>AI-assisted support</h4><p>Administrative assistance for data organization, document retrieval, workflow automation, and scheduling — not decision-making.</p></article>
                            </div>
                            <div class="col-12 col-md-6 col-xl-4">
                                <article class="bn-feature-card"><div class="icon-box"><i class="fa fa-line-chart"/></div><h4>Transparency &amp; monitoring</h4><p>Real-time status updates, procedural milestone visibility, case progress monitoring, and performance tracking.</p></article>
                            </div>
                            <div class="col-12 col-md-6 col-xl-4">
                                <article class="bn-feature-card"><div class="icon-box"><i class="fa fa-comments-o"/></div><h4>Communication &amp; tracking</h4><p>Efficient communication and case tracking mechanisms with end-to-end support for online dispute resolution proceedings.</p></article>
                            </div>
                        </div>
                        <div class="text-center mt-4"><a href="/features" class="bn-link-accent">Full feature briefing →</a></div>
                    </div>
                </section>

                <section class="bn-light-section pb-5" id="how">
                    <div class="container">
                        <div class="bn-section-title">
                            <span class="bn-badge-pill">How it works</span>
                            <h2>E-Filing and Case Management</h2>
                            <p class="lead">From case initiation and vetting through hearings to resolution and outcome — transparent milestones at every step.</p>
                        </div>
                        <t t-call="bharatnyay_website.bn_prose_workflow"/>
                        <div class="text-center mt-4"><a href="/how-it-works" class="bn-link-accent">Deep dive on timings →</a></div>
                    </div>
                </section>

                <section class="bn-stake-section" id="stakeholders">
                    <div class="container">
                        <div class="bn-section-title">
                            <span class="bn-badge-pill">Our stakeholders</span>
                            <h2>Governance-ready roles</h2>
                            <p class="lead">Consumers, financiers, neutrals, and supervisors converge on one fabric — aligning with fiduciary duties and supervisory expectations for fair recovery (<abbr title="Reserve Bank of India">RBI</abbr>).</p>
                        </div>
                        <div class="row g-4">
                            <div class="col-12 col-md-6 col-xl-3"><article class="bn-stake-card"><div class="icon-box"><i class="fa fa-user"/></div><h4>Borrowers</h4><p>Fair EMI disputes, coercion complaints, SARFAESI interplay — mediated channels before escalation.</p></article></div>
                            <div class="col-12 col-md-6 col-xl-3"><article class="bn-stake-card"><div class="icon-box"><i class="fa fa-building"/></div><h4>Lenders &amp; NBFCs</h4><p>Repeatable dockets respecting fair practices code timelines and escalation governance.</p></article></div>
                            <div class="col-12 col-md-6 col-xl-3"><article class="bn-stake-card"><div class="icon-box"><i class="fa fa-pencil-square-o"/></div><h4>Neutrals</h4><p>Remote case management disclosures, neutrality declarations, remuneration transparency.</p></article></div>
                            <div class="col-12 col-md-6 col-xl-3"><article class="bn-stake-card"><div class="icon-box"><i class="fa fa-shield"/></div><h4>Regulators / audit</h4><p>Grievance redress artefacts, SLA telemetry, segregation of duties for sensitive actions.</p></article></div>
                        </div>
                    </div>
                </section>

                <section class="bn-light-section" id="testimonials">
                    <div class="container">
                        <div class="bn-section-title">
                            <span class="bn-badge-pill">Testimonials</span>
                            <h2>Trusted by thousands</h2>
                            <p class="lead small mx-auto">Illustrative stories — customise with live references after deployment.</p>
                        </div>
                        <div class="row g-4">
                            <div class="col-12 col-md-4">
                                <blockquote class="bn-testimonial-card">
                                    <div class="stars"><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/></div>
                                    <p class="quote">“Structured ODR ladders closed my EMI overcharge in twelve days.”</p>
                                    <footer class="user-info"><span class="avatar">SR</span><div class="name-box"><h5>Sneha Reddy</h5><p>Borrower, Hyderabad</p></div></footer>
                                </blockquote>
                            </div>
                            <div class="col-12 col-md-4">
                                <blockquote class="bn-testimonial-card">
                                    <div class="stars"><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/></div>
                                    <p class="quote">“Neutral dashboards shave hours versus inbox arbitration.”</p>
                                    <footer class="user-info"><span class="avatar">AP</span><div class="name-box"><h5>Adv. Priya Sharma</h5><p>Mediator</p></div></footer>
                                </blockquote>
                            </div>
                            <div class="col-12 col-md-4">
                                <blockquote class="bn-testimonial-card">
                                    <div class="stars"><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/><i class="fa fa-star"/></div>
                                    <p class="quote">“Penalty reversal path finally matched our clause library governance.”</p>
                                    <footer class="user-info"><span class="avatar">VE</span><div class="name-box"><h5>Vikram Enterprises</h5><p>MSME borrower, Mumbai</p></div></footer>
                                </blockquote>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="bn-light-section pt-2 pb-5">
                    <div class="container">
                        <div class="bn-cta-box">
                            <h2>Deploy governed ODR for your portfolios</h2>
                            <p class="bn-cta-subtext">Book a blueprint session — neutrality policy, arbitrator panel rules, data residency, escalation matrices, integrations.</p>
                            <div class="d-flex flex-wrap justify-content-center gap-3">
                                <a class="btn bn-cta-orange" href="/contactus">File a dispute now →</a>
                                <a class="btn bn-cta-white" href="/odr/model-clause">Review model clause cues</a>
                            </div>
                        </div>
                    </div>
                </section>

                <t t-call="bharatnyay_website.bn_public_footer"/>
            </div>
        </xpath>
    </template>
</odoo>
