<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="page_how_it_works" name="How it works detailed">
        <t t-call="website.layout">
            <t t-set="no_footer" t-value="True"/>
            <div id="wrap">
                <t t-set="bn_nav_inner" t-value="True"/>
                <t t-call="bharatnyay_website.bn_public_nav"/>
                <div class="bn-about-page">
                    <header class="bn-about-hero bn-hero-split text-lg-start">
                        <div class="container">
                            <div class="bn-hero-inner">
                                <p class="bn-hash mb-3">Operating model</p>
                                <h1>How BharatNyay <span class="text-orange">supports</span> the ODR process</h1>
                                <p class="mb-0">A comprehensive digital platform facilitating modern dispute resolution mechanisms, including Arbitration, Mediation, and Conciliation.</p>
                            </div>
                        </div>
                    </header>
                    <section class="bn-about-body">
                        <div class="container bn-prose bn-prose-page">

                            <div class="bn-prose-block">
                                <span class="bn-prose-kicker">Overview</span>
                                <h2>What BharatNyay offers</h2>
                                <p class="bn-prose-lead">BharatNyay provides a secure and technology-enabled platform to support Online Dispute Resolution (ODR) proceedings, including Arbitration, Mediation, and Conciliation.</p>
                                <p class="fw-semibold small text-uppercase mb-3" style="letter-spacing:0.08em;color:var(--bn-text-muted-light);">The platform offers</p>
                                <t t-call="bharatnyay_website.bn_prose_offers"/>
                            </div>

                            <div class="bn-prose-block">
                                <span class="bn-prose-kicker">E-Filing</span>
                                <h2>E-Filing and Case Management</h2>
                                <h3>E-Filing and Case Vetting</h3>
                                <p class="bn-prose-lead">The platform enables seamless electronic filing and preliminary scrutiny of cases, ensuring procedural compliance and efficient case administration.</p>
                                <p class="fw-semibold small text-uppercase mb-3" style="letter-spacing:0.08em;color:var(--bn-text-muted-light);">Workflow</p>
                                <t t-call="bharatnyay_website.bn_prose_workflow"/>
                            </div>

                            <div class="bn-prose-block">
                                <span class="bn-prose-kicker">Hearings</span>
                                <h2>Virtual Hearings</h2>
                                <p class="bn-prose-lead">The platform facilitates secure virtual hearings for the smooth and efficient conduct of dispute resolution proceedings.</p>
                                <p class="fw-semibold small text-uppercase mb-3" style="letter-spacing:0.08em;color:var(--bn-text-muted-light);">Key features</p>
                                <t t-call="bharatnyay_website.bn_prose_virtual_hearings"/>
                            </div>

                            <div class="bn-prose-block">
                                <span class="bn-prose-kicker">Automation</span>
                                <h2>AI-Assisted Support</h2>
                                <p class="bn-prose-lead">Artificial Intelligence is utilized solely for administrative and operational purposes, including:</p>
                                <t t-call="bharatnyay_website.bn_prose_ai_support"/>
                            </div>

                            <div class="bn-prose-block">
                                <span class="bn-prose-kicker">Visibility</span>
                                <h2>Transparency and Performance Monitoring</h2>
                                <h3>Interim Updates and Case Visibility</h3>
                                <p class="bn-prose-lead">The platform provides stakeholders with real-time insight into every procedural milestone.</p>
                                <t t-call="bharatnyay_website.bn_prose_transparency"/>
                            </div>

                            <div class="bn-prose-block">
                                <t t-call="bharatnyay_website.bn_prose_exclusion"/>
                            </div>

                            <div class="bn-prose-cta-bar">
                                <p class="bn-prose-cta-hint">See how each capability fits your operating model end to end.</p>
                                <div class="d-flex flex-wrap gap-2">
                                    <a href="/features" class="btn bn-btn-pill-primary btn-sm">Platform features</a>
                                    <a href="/odr/proceedings" class="btn bn-btn-pill-soft btn-sm">ODR proceedings</a>
                                    <a href="/odr/what-is" class="btn bn-btn-pill-soft btn-sm">What is ODR?</a>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
                <div class="bn-landing-root"><t t-call="bharatnyay_website.bn_public_footer"/></div>
            </div>
        </t>
    </template>
</odoo>
