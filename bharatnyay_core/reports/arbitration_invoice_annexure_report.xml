<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_report_bharat_arbitration_invoice_annexure" model="ir.actions.report">
        <field name="name">Arbitration invoice annexure</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bharatnyay_core.report_bharat_arbitration_invoice_annexure_doc</field>
        <field name="report_file">bharatnyay_core.report_bharat_arbitration_invoice_annexure_doc</field>
        <field name="print_report_name">'Annexure_%s' % (object.name or object.id)</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_bharat_arbitration_invoice_annexure_doc">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="bharatnyay_core.bharat_report_external_layout">
                    <div class="page" style="font-family: Arial, sans-serif; font-size: 11px; color: #1e293b;">
                        <h2 style="margin: 0 0 8px 0; font-size: 18px;">Invoice annexure</h2>
                        <p style="margin: 0 0 16px 0; color: #475569;">
                            <strong>Invoice:</strong> <span t-field="doc.name"/>
                            <span style="margin: 0 8px;">|</span>
                            <strong>Batch:</strong> <span t-esc="doc.bharat_invoice_batch_ref or '-'"/>
                            <span style="margin: 0 8px;">|</span>
                            <strong>Cases:</strong> <span t-esc="doc.bharat_annexure_case_count"/>
                        </p>
                        <table style="width: 100%; border-collapse: collapse; font-size: 10px;">
                            <thead>
                                <tr style="background: #eef2ff;">
                                    <th style="border: 1px solid #cbd5e1; padding: 6px; text-align: left;">#</th>
                                    <th style="border: 1px solid #cbd5e1; padding: 6px; text-align: left;">Loan no.</th>
                                    <th style="border: 1px solid #cbd5e1; padding: 6px; text-align: left;">BharatNyay case</th>
                                    <th style="border: 1px solid #cbd5e1; padding: 6px; text-align: left;">Borrower</th>
                                    <th style="border: 1px solid #cbd5e1; padding: 6px; text-align: left;">Task</th>
                                    <th style="border: 1px solid #cbd5e1; padding: 6px; text-align: right;">Rate</th>
                                    <th style="border: 1px solid #cbd5e1; padding: 6px; text-align: right;">Qty</th>
                                    <th style="border: 1px solid #cbd5e1; padding: 6px; text-align: right;">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="row_num" t-value="0"/>
                                <t t-set="total" t-value="0.0"/>
                                <tr t-foreach="doc.bharat_annexure_line_ids.sorted('sequence')" t-as="line">
                                    <t t-set="row_num" t-value="row_num + 1"/>
                                    <t t-set="total" t-value="total + (line.amount or 0.0)"/>
                                    <td style="border: 1px solid #e2e8f0; padding: 5px;" t-esc="row_num"/>
                                    <td style="border: 1px solid #e2e8f0; padding: 5px;" t-esc="line.loan_number or ''"/>
                                    <td style="border: 1px solid #e2e8f0; padding: 5px;" t-esc="line.case_number or ''"/>
                                    <td style="border: 1px solid #e2e8f0; padding: 5px;" t-esc="line.customer_name or ''"/>
                                    <td style="border: 1px solid #e2e8f0; padding: 5px;" t-esc="line.milestone_label or ''"/>
                                    <td style="border: 1px solid #e2e8f0; padding: 5px; text-align: right;">
                                        <span t-field="line.unit_price" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                    <td style="border: 1px solid #e2e8f0; padding: 5px; text-align: right;" t-esc="line.quantity"/>
                                    <td style="border: 1px solid #e2e8f0; padding: 5px; text-align: right;">
                                        <span t-field="line.amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr style="background: #f8fafc; font-weight: bold;">
                                    <td colspan="7" style="border: 1px solid #cbd5e1; padding: 6px; text-align: right;">Invoice total</td>
                                    <td style="border: 1px solid #cbd5e1; padding: 6px; text-align: right;">
                                        <span t-field="doc.amount_total" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
