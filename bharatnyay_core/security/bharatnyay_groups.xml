<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="module_category_bharatnyay_roles" model="ir.module.category">
        <field name="name">BharatNyay</field>
        <field name="description">Operational roles for BharatNyay</field>
        <field name="sequence">25</field>
    </record>

    <record id="group_bharat_case_manager" model="res.groups">
        <field name="name">Case Manager</field>
        <field name="category_id" ref="module_category_bharatnyay_roles"/>
        <field name="comment">BharatNyay operational role: case manager</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_bharat_arbitrator" model="res.groups">
        <field name="name">Arbitrator</field>
        <field name="category_id" ref="module_category_bharatnyay_roles"/>
        <field name="comment">BharatNyay operational role: arbitrator</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_bharat_borrower" model="res.groups">
        <field name="name">Borrower</field>
        <field name="category_id" ref="module_category_bharatnyay_roles"/>
        <field name="comment">BharatNyay operational role: borrower</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_bharat_lender" model="res.groups">
        <field name="name">Lender</field>
        <field name="category_id" ref="module_category_bharatnyay_roles"/>
        <field name="comment">BharatNyay operational role: lender</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_bharat_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="category_id" ref="module_category_bharatnyay_roles"/>
        <field name="comment">BharatNyay operational role: full app access</field>
        <field name="implied_ids" eval="[
            (4, ref('base.group_user')),
            (4, ref('group_bharat_case_manager')),
            (4, ref('group_bharat_arbitrator')),
            (4, ref('group_bharat_borrower')),
            (4, ref('group_bharat_lender')),
        ]"/>
    </record>
</odoo>
