<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="bharatnyay_core.FlowSimulation">
        <div class="o_bharat_flow_sim o_action">
            <div class="o_bharat_flow_sim__backdrop"/>

            <header class="o_bharat_flow_sim__header">
                <div class="o_bharat_flow_sim__brand">
                    <span class="o_bharat_flow_sim__pulse"/>
                    <div>
                        <div class="o_bharat_flow_sim__eyebrow">Guided demo</div>
                        <h1>Case flow simulation</h1>
                    </div>
                </div>
                <div class="o_bharat_flow_sim__case" t-if="state.payload">
                    <span class="o_bharat_flow_sim__case-label" t-out="state.payload.loan_label"/>
                    <span class="o_bharat_flow_sim__case-milestone" t-out="state.payload.milestone_label"/>
                </div>
                <button type="button"
                        class="btn btn-link o_bharat_flow_sim__exit"
                        title="Exit demo"
                        t-on-click="onExit">
                    <i class="fa fa-times"/> Exit
                </button>
            </header>

            <div class="o_bharat_flow_sim__body" t-if="state.phase === 'pick_mode'">
                <div class="o_bharat_flow_sim__setup">
                    <div class="o_bharat_flow_sim__setup-icon">
                        <i class="fa fa-play-circle"/>
                    </div>
                    <h2>How would you like to run the demo?</h2>
                    <p class="o_bharat_flow_sim__setup-lead">
                        Walk one case from its current stage through Award and invoice.
                        Choose whether steps advance on their own or wait for you.
                    </p>
                    <div class="o_bharat_flow_sim__mode-cards">
                        <button type="button"
                                class="o_bharat_flow_sim__mode-card"
                                t-att-disabled="state.busy"
                                t-on-click="() => this.startDemo('auto')">
                            <span class="o_bharat_flow_sim__mode-icon">
                                <i class="fa fa-forward"/>
                            </span>
                            <span class="o_bharat_flow_sim__mode-title">Auto play</span>
                            <span class="o_bharat_flow_sim__mode-desc">
                                Steps run automatically with short pauses between them.
                            </span>
                        </button>
                        <button type="button"
                                class="o_bharat_flow_sim__mode-card o_bharat_flow_sim__mode-card--manual"
                                t-att-disabled="state.busy"
                                t-on-click="() => this.startDemo('manual')">
                            <span class="o_bharat_flow_sim__mode-icon">
                                <i class="fa fa-hand-pointer-o"/>
                            </span>
                            <span class="o_bharat_flow_sim__mode-title">Manual</span>
                            <span class="o_bharat_flow_sim__mode-desc">
                                You control each step with the Next button.
                            </span>
                        </button>
                    </div>
                </div>
            </div>

            <div class="o_bharat_flow_sim__body" t-elif="state.loading">
                <div class="o_bharat_flow_sim__loader">
                    <i class="fa fa-spinner fa-spin fa-2x"/>
                    <p>Preparing demo case…</p>
                </div>
            </div>

            <div class="o_bharat_flow_sim__body" t-elif="state.error">
                <div class="o_bharat_flow_sim__error alert alert-danger">
                    <i class="fa fa-exclamation-circle"/>
                    <span t-out="state.error"/>
                </div>
                <button type="button" class="btn btn-secondary" t-on-click="onExit">Close</button>
            </div>

            <div class="o_bharat_flow_sim__body" t-elif="state.payload">
                <aside class="o_bharat_flow_sim__timeline">
                    <div class="o_bharat_flow_sim__timeline-title">Flow timeline</div>
                    <ol class="o_bharat_flow_sim__steps">
                        <li t-foreach="state.payload.steps" t-as="step" t-key="step.key"
                            t-att-class="'o_bharat_flow_sim__step o_bharat_flow_sim__step--' + step.state">
                            <span class="o_bharat_flow_sim__step-icon">
                                <i t-att-class="'fa ' + step.icon"/>
                            </span>
                            <span class="o_bharat_flow_sim__step-title" t-out="step.title"/>
                        </li>
                    </ol>
                </aside>

                <main class="o_bharat_flow_sim__stage">
                    <div class="o_bharat_flow_sim__progress">
                        <div class="o_bharat_flow_sim__progress-bar"
                             t-att-style="'width:' + progressPct() + '%'"/>
                    </div>
                    <div class="o_bharat_flow_sim__progress-label"
                         t-out="progressLabel()"/>

                    <div t-if="state.payload.done" class="o_bharat_flow_sim__hero o_bharat_flow_sim__hero--done">
                        <div class="o_bharat_flow_sim__hero-icon">
                            <i class="fa fa-flag-checkered"/>
                        </div>
                        <h2>Demo complete</h2>
                        <p>Commencement → Award → Invoice. The full arbitration journey in one guided run.</p>
                        <div class="o_bharat_flow_sim__hero-actions">
                            <button t-if="state.payload.invoice_id"
                                    type="button"
                                    class="btn btn-primary"
                                    t-on-click="openInvoice">
                                <i class="fa fa-file-text-o"/> View invoice
                            </button>
                            <button type="button"
                                    class="btn btn-outline-light"
                                    t-on-click="openCase">
                                <i class="fa fa-folder-open-o"/> Open case
                            </button>
                            <button type="button"
                                    class="btn btn-link text-white-50"
                                    t-on-click="onExit">
                                Back to dashboard
                            </button>
                        </div>
                    </div>

                    <div t-else="" class="o_bharat_flow_sim__hero">
                        <div class="o_bharat_flow_sim__hero-icon"
                             t-att-class="state.busy ? 'o_bharat_flow_sim__hero-icon--busy' : ''">
                            <i t-att-class="'fa ' + (state.payload.current_step?.icon || 'fa-circle-o')"/>
                        </div>
                        <h2 t-out="state.payload.current_step?.title || 'Processing…'"/>
                        <p t-out="state.payload.current_step?.subtitle || state.message"/>
                        <p t-if="state.message and state.payload.current_step?.subtitle"
                           class="o_bharat_flow_sim__message"
                           t-out="state.message"/>

                        <p t-if="state.payload.current_step?.prompt and state.waitingForUser"
                           class="o_bharat_flow_sim__prompt"
                           t-out="state.payload.current_step.prompt"/>

                        <div class="o_bharat_flow_sim__hero-actions">
                            <button t-if="state.videoRoomUrl"
                                    type="button"
                                    class="btn btn-outline-info btn-lg"
                                    t-on-click="openVideoRoom">
                                <i class="fa fa-video-camera"/> Open video room
                            </button>
                            <button t-if="state.waitingForUser and state.payload.current_step?.key === 'open_case'"
                                    type="button"
                                    class="btn btn-outline-light"
                                    t-on-click="openCase">
                                <i class="fa fa-folder-open-o"/> Open case again
                            </button>
                            <button t-if="state.waitingForUser and canReopenWizard()"
                                    type="button"
                                    class="btn btn-outline-light"
                                    t-on-click="reopenWizard">
                                <i class="fa fa-external-link"/> Open wizard again
                            </button>
                        </div>
                    </div>

                    <div t-if="canShowNext() or state.busy"
                         class="o_bharat_flow_sim__nav">
                        <p class="o_bharat_flow_sim__nav-hint" t-out="nextHint()"/>
                        <button t-if="canShowNext()"
                                type="button"
                                class="btn btn-primary btn-lg o_bharat_flow_sim__next"
                                t-att-disabled="state.busy"
                                t-on-click="onNext">
                            <i class="fa fa-arrow-right"/>
                            <t t-out="nextButtonLabel()"/>
                        </button>
                    </div>

                    <div class="o_bharat_flow_sim__log" t-if="state.payload.log_text">
                        <div class="o_bharat_flow_sim__log-title">Activity log</div>
                        <pre t-out="state.payload.log_text"/>
                    </div>
                </main>
            </div>
        </div>
    </t>

</templates>
