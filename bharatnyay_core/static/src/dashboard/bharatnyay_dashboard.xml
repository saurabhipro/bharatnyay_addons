<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="bharatnyay_core.BharatnyayDashboard">
        <div class="o_bharatnyay_dashboard">
            <div class="bn-wrap">
                <div class="bn-header bn-header--admin">
                    <div class="bn-header__brand">
                        <i class="fa fa-shield bn-header__icon-inline" aria-hidden="true"/>
                        <div class="bn-title-block bn-title-block--inline">
                            <h1>Admin Dashboard</h1>
                            <span class="bn-header__tagline">Cases, exposure, and workflow at a glance.</span>
                        </div>
                    </div>
                    <div class="bn-header-actions">
                        <t t-set="filterBarClass" t-value="'bn-filter-bar--admin'"/>
                        <t t-call="bharatnyay_core.DashboardFilterBar"/>
                        <input type="search"
                               class="bn-search bn-search--admin"
                               placeholder="Search loan number…"
                               t-att-value="state.search"
                               t-on-input="onSearchInput"
                               t-on-keydown="onSearchKeydown"/>
                        <button type="button"
                                class="bn-icon-btn bn-icon-btn--admin"
                                title="Search loan"
                                t-on-click="onSearchSubmit">
                            <i class="fa fa-search"/>
                        </button>
                        <button type="button"
                                class="bn-icon-btn bn-icon-btn--admin"
                                title="Refresh"
                                t-on-click="onRefresh">
                            <i class="fa fa-refresh"/>
                        </button>
                        <button type="button"
                                class="bn-icon-btn bn-icon-btn--admin"
                                title="Open loan sheet"
                                t-on-click="openLoanList">
                            <i class="fa fa-table"/>
                        </button>
                    </div>
                </div>

                <t t-if="state.loading">
                    <div class="bn-muted-empty">
                        <i class="fa fa-spinner fa-spin fa-2x mb-2"/>
                        <div>Loading admin dashboard…</div>
                    </div>
                </t>

                <t t-elif="state.error">
                    <div class="bn-muted-empty bn-error">
                        <span t-out="state.error"/>
                    </div>
                </t>

                <t t-elif="state.data">
                    <div class="bn-dashboard-section">
                    <div class="bn-kpi-grid bn-kpi-grid--7">
                        <div class="bn-kpi-card bn-kpi-card--tone-blue">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-briefcase" title="Total cases"/></span>
                                <div class="bn-kpi-label">Total cases</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.total_loans)"/>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--click bn-kpi-card--tone-green" t-on-click="openLoanList">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-cubes" title="Total batches"/></span>
                                <div class="bn-kpi-label">Total batches</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.total_batches || 0)"/>
                            <div class="bn-kpi-trend">Distinct import batches</div>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--click bn-kpi-card--tone-cyan"
                             t-on-click="openPendingPostalStatus">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-envelope-o" title="Awaiting POD status"/></span>
                                <div class="bn-kpi-label">Awaiting POD status</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.postal_status_pending_count || 0)"/>
                            <div class="bn-kpi-trend"
                                 t-out="fmtMoney(state.data.kpis.postal_status_pending_amount || 0) + ' · ' + fmtInt(state.data.kpis.postal_status_pending_notice_1 || 0) + ' N1, ' + fmtInt(state.data.kpis.postal_status_pending_interim_1 || 0) + ' IO1'"/>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--click bn-kpi-card--tone-teal"
                             data-filter="paid"
                             t-on-click="openInvoices">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-check-circle" title="Invoices paid"/></span>
                                <div class="bn-kpi-label">Invoices paid</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtMoney(state.data.kpis.paid_invoice_amount || 0)"/>
                            <div class="bn-kpi-trend" t-out="fmtInt(state.data.kpis.paid_invoices || 0) + ' invoices'"/>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--click bn-kpi-card--tone-amber"
                             data-filter="unpaid"
                             t-on-click="openInvoices">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-file-text-o" title="Invoices unpaid"/></span>
                                <div class="bn-kpi-label">Invoices unpaid</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtMoney(state.data.kpis.unpaid_invoice_amount || 0)"/>
                            <div class="bn-kpi-trend" t-out="fmtInt(state.data.kpis.unpaid_invoices || 0) + ' invoices'"/>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--click bn-kpi-card--tone-rose"
                             t-on-click="openUnbilledCases">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-clock-o" title="Unbilled cases"/></span>
                                <div class="bn-kpi-label">Unbilled cases</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.unbilled_cases || 0)"/>
                            <div class="bn-kpi-trend" t-out="fmtInt(state.data.kpis.pending_billing_charges || 0) + ' pending charges'"/>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--tone-purple">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-gavel" title="Hearings today"/></span>
                                <div class="bn-kpi-label">Hearings today</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.hearings_today || 0)"/>
                        </div>
                    </div>
                    </div>

                    <div class="bn-dashboard-section">
                    <div class="bn-section-title">Case pipeline</div>
                    <p class="bn-stage-strip-hint">
                        <i class="fa fa-file-text-o" title="Unbilled billing"/>
                        Amber badge — milestone accrues an unbilled charge (Notice 1, Hearing 1, Award per master).
                    </p>
                    <t t-call="bharatnyay_core.DashboardStageCardStrip"/>
                    </div>

                    <div class="bn-dashboard-section">
                    <div class="bn-section-title">Portfolio breakdown</div>
                    <div class="bn-chart-row bn-chart-row--3">
                        <t t-call="bharatnyay_core.DashboardPanelBatchVolumeStacked"/>
                        <div class="bn-panel">
                            <div class="bn-panel-head">
                                <div class="bn-panel-head__title">
                                    <span class="bn-panel-icon"><i class="fa fa-tasks"/></span>
                                    <h2>Case status</h2>
                                </div>
                                <span class="hint">Notice 1–3, hearings, award</span>
                            </div>
                            <div class="bn-panel-body">
                            <div class="bn-pie-wrap" t-if="state.data.workflow_mix.length">
                                <div class="bn-pie" t-attf-style="background: {{ state.workflowPieStyle }}"/>
                                <ul>
                                    <t t-foreach="state.data.workflow_mix" t-as="s" t-key="s.key">
                                        <li class="bn-pie-legend-item bn-pie-legend-item--click"
                                            t-att-data-stage="s.key"
                                            t-on-click="openStageCases">
                                            <span class="sq" t-attf-style="background: {{ s.color }}"/>
                                            <span class="lbl" t-out="s.label"/>
                                            <span class="pct" t-out="s.percent + '%'"/>
                                        </li>
                                    </t>
                                </ul>
                            </div>
                            <div t-else="" class="bn-muted-empty">No workflow data.</div>
                            </div>
                        </div>
                        <div class="bn-panel">
                            <div class="bn-panel-head">
                                <div class="bn-panel-head__title">
                                    <span class="bn-panel-icon"><i class="fa fa-credit-card"/></span>
                                    <h2>Payment status</h2>
                                </div>
                                <span class="hint">Arbitration invoices</span>
                            </div>
                            <div class="bn-panel-body">
                            <div class="bn-pie-wrap" t-if="state.data.payment_mix.length">
                                <div class="bn-pie" t-attf-style="background: {{ state.paymentPieStyle }}"/>
                                <ul>
                                    <t t-foreach="state.data.payment_mix" t-as="s" t-key="s.filter">
                                        <li class="bn-pie-legend-item bn-pie-legend-item--click"
                                            t-att-data-filter="s.filter"
                                            t-on-click="openInvoices">
                                            <span class="sq" t-attf-style="background: {{ s.color }}"/>
                                            <span class="lbl" t-out="s.label"/>
                                            <span class="pct" t-out="s.percent + '%'"/>
                                        </li>
                                    </t>
                                </ul>
                            </div>
                            <div t-else="" class="bn-muted-empty">No invoice data.</div>
                            </div>
                        </div>
                    </div>
                    <div class="bn-chart-row bn-chart-row--3 bn-chart-row--mix mt-2">
                        <div class="bn-panel">
                            <div class="bn-panel-head">
                                <div class="bn-panel-head__title">
                                    <span class="bn-panel-icon"><i class="fa fa-building-o"/></span>
                                    <h2>Branch mix</h2>
                                </div>
                                <span class="hint">Click a branch to filter cases</span>
                            </div>
                            <div class="bn-panel-body">
                            <div class="bn-pie-wrap" t-if="state.data.branch_mix.length">
                                <div class="bn-pie" t-attf-style="background: {{ state.branchPieStyle }}"/>
                                <ul>
                                    <t t-foreach="state.data.branch_mix" t-as="s" t-key="s.label">
                                        <li t-att-class="s.id !== undefined ? 'bn-pie-legend-item bn-pie-legend-item--click' : 'bn-pie-legend-item'"
                                            t-att-data-mix-kind="'branch'"
                                            t-att-data-mix-id="s.id"
                                            t-on-click="openMixCases">
                                            <span class="sq" t-attf-style="background: {{ s.color }}"/>
                                            <span class="lbl" t-out="s.label"/>
                                            <span class="pct" t-out="s.percent + '%'"/>
                                        </li>
                                    </t>
                                </ul>
                            </div>
                            <div t-else="" class="bn-muted-empty">No branch data.</div>
                            </div>
                        </div>
                        <div class="bn-panel">
                            <div class="bn-panel-head">
                                <div class="bn-panel-head__title">
                                    <span class="bn-panel-icon"><i class="fa fa-cubes"/></span>
                                    <h2>Product mix</h2>
                                </div>
                                <span class="hint">By product class</span>
                            </div>
                            <div class="bn-panel-body">
                            <div class="bn-pie-wrap" t-if="state.data.product_mix.length">
                                <div class="bn-pie" t-attf-style="background: {{ state.pieStyle }}"/>
                                <ul>
                                    <t t-foreach="state.data.product_mix" t-as="s" t-key="s.label">
                                        <li class="bn-pie-legend-item">
                                            <span class="sq" t-attf-style="background: {{ s.color }}"/>
                                            <span class="lbl" t-out="s.label"/>
                                            <span class="pct" t-out="s.percent + '%'"/>
                                        </li>
                                    </t>
                                </ul>
                            </div>
                            <div t-else="" class="bn-muted-empty">No classification data.</div>
                            </div>
                        </div>
                        <div class="bn-panel">
                            <div class="bn-panel-head">
                                <div class="bn-panel-head__title">
                                    <span class="bn-panel-icon"><i class="fa fa-map-marker"/></span>
                                    <h2>Location mix</h2>
                                </div>
                                <span class="hint">Click a location to filter cases</span>
                            </div>
                            <div class="bn-panel-body">
                            <div class="bn-pie-wrap" t-if="state.data.location_mix.length">
                                <div class="bn-pie" t-attf-style="background: {{ state.locationPieStyle }}"/>
                                <ul>
                                    <t t-foreach="state.data.location_mix" t-as="s" t-key="s.label">
                                        <li t-att-class="s.id !== undefined ? 'bn-pie-legend-item bn-pie-legend-item--click' : 'bn-pie-legend-item'"
                                            t-att-data-mix-kind="'location'"
                                            t-att-data-mix-id="s.id"
                                            t-on-click="openMixCases">
                                            <span class="sq" t-attf-style="background: {{ s.color }}"/>
                                            <span class="lbl" t-out="s.label"/>
                                            <span class="pct" t-out="s.percent + '%'"/>
                                        </li>
                                    </t>
                                </ul>
                            </div>
                            <div t-else="" class="bn-muted-empty">No location data.</div>
                            </div>
                        </div>
                    </div>
                    </div>

                    <div class="bn-dashboard-section bn-ops-section" t-if="state.data.processes">
                        <div class="bn-ops-grid">
                            <!-- Task queue: background jobs / process runs -->
                            <div class="bn-ops-panel bn-ops-panel--jobs">
                                <div class="bn-ops-panel__head">
                                    <button type="button"
                                            class="bn-ops-panel__title"
                                            title="Open full job history"
                                            t-on-click="() => this.openProcessRuns()">
                                        <span class="bn-ops-panel__icon bn-ops-panel__icon--jobs">
                                            <i class="fa fa-tasks"/>
                                        </span>
                                        <span>
                                            <strong>Task queue</strong>
                                            <small>Background jobs &amp; schedulers</small>
                                        </span>
                                    </button>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary"
                                            t-on-click="() => this.openProcessRuns()">
                                        All jobs
                                    </button>
                                </div>

                                <div class="bn-process-stats-grid">
                                    <button type="button"
                                            class="bn-process-stat bn-process-stat--click bn-process-stat--total"
                                            title="View all jobs"
                                            t-on-click="() => this.openProcessRuns()">
                                        <div class="bn-process-stat__head">
                                            <span class="bn-process-stat__icon"><i class="fa fa-history"/></span>
                                            <span class="bn-process-stat__label">Total</span>
                                        </div>
                                        <span class="bn-process-stat__value"
                                              t-out="fmtInt((state.data.processes.summary and state.data.processes.summary.total) or state.data.processes.total_count or 0)"/>
                                    </button>
                                    <button type="button"
                                            t-attf-class="bn-process-stat bn-process-stat--click bn-process-stat--running {{ processActiveCount() ? 'bn-process-stat--live' : '' }}"
                                            title="View running / queued jobs"
                                            t-on-click="() => this.openProcessRunsActive()">
                                        <div class="bn-process-stat__head">
                                            <span class="bn-process-stat__icon">
                                                <i t-attf-class="fa {{ processActiveCount() ? 'fa-cog fa-spin' : 'fa-play-circle' }}"/>
                                            </span>
                                            <span class="bn-process-stat__label">Running</span>
                                        </div>
                                        <span class="bn-process-stat__value"
                                              t-out="fmtInt((state.data.processes.summary and state.data.processes.summary.active) or state.data.processes.running_count or 0)"/>
                                    </button>
                                    <button type="button"
                                            class="bn-process-stat bn-process-stat--click bn-process-stat--success"
                                            title="View completed jobs"
                                            t-on-click="() => this.openProcessRunsFiltered('done')">
                                        <div class="bn-process-stat__head">
                                            <span class="bn-process-stat__icon"><i class="fa fa-check-circle"/></span>
                                            <span class="bn-process-stat__label">Success</span>
                                        </div>
                                        <span class="bn-process-stat__value"
                                              t-out="fmtInt((state.data.processes.summary and state.data.processes.summary.success) or state.data.processes.success_count or 0)"/>
                                    </button>
                                    <button type="button"
                                            class="bn-process-stat bn-process-stat--click bn-process-stat--failed"
                                            title="View failed jobs"
                                            t-on-click="() => this.openProcessRunsFiltered('failed')">
                                        <div class="bn-process-stat__head">
                                            <span class="bn-process-stat__icon"><i class="fa fa-exclamation-circle"/></span>
                                            <span class="bn-process-stat__label">Failed</span>
                                        </div>
                                        <span class="bn-process-stat__value"
                                              t-out="fmtInt((state.data.processes.summary and state.data.processes.summary.failed) or state.data.processes.failed_count or 0)"/>
                                    </button>
                                </div>

                                <div class="bn-ops-toolbar">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger"
                                            t-if="state.data.processes.has_active_jobs"
                                            t-on-click.stop="cancelAllJobs">
                                        <i class="fa fa-stop"/> Stop all jobs
                                    </button>
                                    <span class="bn-process-queue-hint"
                                          t-if="!state.data.processes.queue_enabled &amp;&amp; state.data.processes.running_count">
                                        Vault queue paused — rebuild a batch to resume
                                    </span>
                                </div>

                                <div class="bn-process-table-wrap" t-if="state.data.processes.recent.length">
                                    <table class="bn-process-table">
                                        <thead>
                                            <tr>
                                                <th class="col-status"/>
                                                <th>Job</th>
                                                <th>Type</th>
                                                <th>Started</th>
                                                <th>Duration</th>
                                                <th class="col-actions">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="state.data.processes.recent" t-as="job" t-key="job.id">
                                                <tr t-attf-class="bn-process-row bn-process-row--{{ job.state }}"
                                                    t-att-title="job.error_message || job.message || ''">
                                                    <td class="col-status">
                                                        <i t-attf-class="fa {{ processStateIcon(job.state) }}"/>
                                                    </td>
                                                    <td class="col-job">
                                                        <div class="bn-process-row__title" t-out="job.name"/>
                                                        <div class="bn-process-row__hint"
                                                             t-if="job.batch_number"
                                                             t-out="job.batch_number"/>
                                                    </td>
                                                    <td t-out="job.job_type_label"/>
                                                    <td t-out="fmtDateTime(job.started_at)"/>
                                                    <td>
                                                        <span t-if="job.duration_seconds &amp;&amp; job.state !== 'running' &amp;&amp; job.state !== 'queued'"
                                                              t-out="fmtDuration(job.duration_seconds)"/>
                                                        <span t-elif="job.state === 'running' || job.state === 'queued'"
                                                              t-out="processProgressLabel(job)"/>
                                                        <span t-else="">—</span>
                                                    </td>
                                                    <td class="col-actions">
                                                        <div class="bn-process-row__actions">
                                                            <button type="button"
                                                                    class="btn btn-sm btn-outline-danger"
                                                                    title="Stop job"
                                                                    t-if="job.can_cancel"
                                                                    t-on-click="(ev) => this.cancelJob(ev, job.id)">
                                                                Stop
                                                            </button>
                                                            <button type="button"
                                                                    class="btn btn-sm btn-outline-primary"
                                                                    title="Rerun"
                                                                    t-if="job.can_rerun"
                                                                    t-on-click="(ev) => this.rerunJob(ev, job.id)">
                                                                Rerun
                                                            </button>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                                <div class="bn-process-pagination"
                                     t-if="processJobsTotalPages() > 1 || processJobsTotalCount() > state.jobsPageSize">
                                    <span class="bn-process-pagination__meta">
                                        <t t-out="fmtInt(processJobsTotalCount())"/> jobs · page <t t-out="processJobsPageLabel()"/>
                                    </span>
                                    <div class="bn-process-pagination__controls">
                                        <button type="button"
                                                class="btn btn-sm btn-outline-secondary"
                                                t-att-disabled="state.jobsPage &lt;= 1"
                                                t-on-click="processJobsPrev">
                                            <i class="fa fa-chevron-left"/>
                                        </button>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-secondary"
                                                t-att-disabled="state.jobsPage >= processJobsTotalPages()"
                                                t-on-click="processJobsNext">
                                            <i class="fa fa-chevron-right"/>
                                        </button>
                                    </div>
                                </div>
                                <div t-if="!state.data.processes.recent.length" class="bn-muted-empty bn-muted-empty--compact">
                                    No jobs yet. Milestone moves, imports, and vault builds appear here.
                                </div>
                            </div>

                            <!-- Case Vault: batch PDF archive -->
                            <div class="bn-ops-panel bn-ops-panel--vault" t-if="state.data.case_vault">
                                <div class="bn-ops-panel__head">
                                    <button type="button"
                                            class="bn-ops-panel__title"
                                            title="Open Case Vault"
                                            t-on-click="openCaseVault">
                                        <span class="bn-ops-panel__icon bn-ops-panel__icon--vault">
                                            <i class="fa fa-archive"/>
                                        </span>
                                        <span>
                                            <strong>Case Vault</strong>
                                            <small>Batch PDF packs (Notice 1 · IO1 · Award)</small>
                                        </span>
                                    </button>
                                    <span class="bn-ops-panel__badge"
                                          t-out="fmtInt(state.data.case_vault.ready_count || 0) + ' ready'"/>
                                </div>

                                <div class="bn-vault-stats">
                                    <span class="bn-vault-stat">
                                        <i class="fa fa-folder-open-o"/>
                                        <t t-out="fmtInt(state.data.case_vault.total_count || 0)"/> batches
                                    </span>
                                    <span class="bn-vault-stat bn-vault-stat--live"
                                          t-if="state.data.case_vault.building_count">
                                        <i class="fa fa-cog fa-spin"/>
                                        <t t-out="fmtInt(state.data.case_vault.building_count)"/> building
                                    </span>
                                </div>

                                <div class="bn-vault-table-wrap" t-if="state.data.case_vault.batches.length">
                                    <table class="bn-vault-table">
                                        <thead>
                                            <tr>
                                                <th>Batch</th>
                                                <th class="col-num">Cases</th>
                                                <th>Status</th>
                                                <th>Last built</th>
                                                <th>Documents</th>
                                                <th class="col-actions"/>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="state.data.case_vault.batches" t-as="vault" t-key="vault.id">
                                                <tr t-attf-class="bn-vault-row bn-vault-row--{{ vault.vault_state }}">
                                                    <td class="col-batch">
                                                        <button type="button"
                                                                class="btn btn-link btn-sm p-0"
                                                                t-out="vault.batch_number"
                                                                t-on-click="() => this.openVaultRecord(vault.id)"/>
                                                    </td>
                                                    <td class="col-num" t-out="fmtInt(vault.case_count || 0)"/>
                                                    <td>
                                                        <span t-attf-class="bn-vault-badge bn-vault-badge--{{ vault.vault_state }}"
                                                              t-out="vault.vault_state_label"/>
                                                    </td>
                                                    <td t-out="fmtDateTime(vault.last_built_at)"/>
                                                    <td>
                                                        <div class="bn-vault-docs" t-if="vault.downloads.length">
                                                            <t t-foreach="vault.downloads" t-as="dl" t-key="dl.label">
                                                                <button type="button"
                                                                        class="btn btn-sm btn-outline-success"
                                                                        t-on-click="(ev) => this.downloadJobFile(ev, dl.url)">
                                                                    <i class="fa fa-download"/>
                                                                    <span t-out="dl.label"/>
                                                                </button>
                                                            </t>
                                                        </div>
                                                        <span t-else="" class="text-muted">—</span>
                                                    </td>
                                                    <td class="col-actions">
                                                        <button type="button"
                                                                class="btn btn-sm btn-outline-primary"
                                                                title="Queue PDF rebuild"
                                                                t-if="vault.can_build"
                                                                t-on-click="(ev) => this.queueVaultBuild(ev, vault.id)">
                                                            Build
                                                        </button>
                                                        <button type="button"
                                                                class="btn btn-sm btn-outline-danger"
                                                                title="Stop build"
                                                                t-if="vault.can_stop"
                                                                t-on-click="(ev) => this.stopVaultBuild(ev, vault.id)">
                                                            Stop
                                                        </button>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                                <div t-else="" class="bn-muted-empty bn-muted-empty--compact">
                                    No vault batches yet. Import a portfolio or sync from Case Vault.
                                </div>
                            </div>
                        </div>
                    </div>
                </t>

                <t t-else="">
                    <div class="bn-muted-empty">No dashboard data.</div>
                </t>
            </div>
        </div>
    </t>

</templates>
