<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="bharatnyay_core.BharatnyayDashboard">
        <div class="o_bharatnyay_dashboard">
            <div class="bn-wrap">
                <div class="bn-header">
                    <div class="bn-title-block">
                        <h1>Portfolio dashboard</h1>
                        <p>Live roll-up from your loan sheet — exposure, mix, and branch spread.</p>
                    </div>
                    <div class="bn-header-actions">
                        <input type="search"
                               class="bn-search"
                               placeholder="Global search by loan number…"
                               t-att-value="state.search"
                               t-on-input="onSearchInput"
                               t-on-keydown="onSearchKeydown"/>
                        <button type="button"
                                class="bn-icon-btn"
                                title="Search loan"
                                t-on-click="onSearchSubmit">
                            <i class="fa fa-search"/>
                        </button>
                        <button type="button"
                                class="bn-icon-btn"
                                title="Refresh"
                                t-on-click="onRefresh">
                            <i class="fa fa-refresh"/>
                        </button>
                        <button type="button"
                                class="bn-icon-btn"
                                title="Open loan sheet"
                                t-on-click="openLoanList">
                            <i class="fa fa-table"/>
                        </button>
                    </div>
                </div>

                <t t-if="state.loading">
                    <div class="bn-muted-empty">
                        <i class="fa fa-spinner fa-spin fa-2x mb-2"/>
                        <div>Loading portfolio metrics…</div>
                    </div>
                </t>

                <t t-elif="state.error">
                    <div class="bn-muted-empty bn-error">
                        <span t-out="state.error"/>
                    </div>
                </t>

                <t t-elif="state.data">
                    <div class="bn-kpi-grid">
                        <div class="bn-kpi-card bn-accent-border">
                            <div class="bn-kpi-label">Total loans</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.total_loans)"/>
                            <div class="bn-kpi-trend">Rows in portfolio</div>
                        </div>
                        <div class="bn-kpi-card">
                            <div class="bn-kpi-label">Active exposure</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.active_exposure_rows)"/>
                            <div class="bn-kpi-trend bn-good">POS &gt; 0</div>
                        </div>
                        <div class="bn-kpi-card">
                            <div class="bn-kpi-label">Milestones</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.delivered_or_lok)"/>
                            <div class="bn-kpi-trend">Delivered / Lok date</div>
                        </div>
                        <div class="bn-kpi-card">
                            <div class="bn-kpi-label">Exposure rate</div>
                            <div class="bn-kpi-value" t-out="state.data.kpis.pos_ratio_pct + '%'"/>
                            <div class="bn-kpi-trend">Rows with outstanding POS</div>
                        </div>
                        <div class="bn-kpi-card">
                            <div class="bn-kpi-label">Customers</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.unique_customers)"/>
                            <div class="bn-kpi-trend">Distinct names (approx.)</div>
                        </div>
                        <div class="bn-kpi-card">
                            <div class="bn-kpi-label">Total POS</div>
                            <div class="bn-kpi-value" t-out="fmtMoney(state.data.kpis.total_pos_amount)"/>
                            <div class="bn-kpi-trend">Outstanding principal (sum)</div>
                        </div>
                    </div>

                    <div class="bn-kpi-grid bn-kpi-phase mt-3">
                        <div class="bn-kpi-card">
                            <div class="bn-kpi-label">Hearings today</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.hearings_today || 0)"/>
                            <div class="bn-kpi-trend">Scheduled hearing lines</div>
                        </div>
                        <div class="bn-kpi-card">
                            <div class="bn-kpi-label">Dispatch backlog</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.pending_dispatch || 0)"/>
                            <div class="bn-kpi-trend">Notice sent, not delivered</div>
                        </div>
                        <div class="bn-kpi-card">
                            <div class="bn-kpi-label">Draft invoices</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.draft_invoices || 0)"/>
                            <div class="bn-kpi-trend">Billing annexures</div>
                        </div>
                        <div class="bn-kpi-card">
                            <div class="bn-kpi-label">No arbitrator</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.cases_without_arbitrator || 0)"/>
                            <div class="bn-kpi-trend">Appointment stage</div>
                        </div>
                        <div class="bn-kpi-card">
                            <div class="bn-kpi-label">Award pending</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.pending_award_upload || 0)"/>
                            <div class="bn-kpi-trend">Final award, no doc</div>
                        </div>
                        <div class="bn-kpi-card">
                            <div class="bn-kpi-label">Loan activities due</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.loan_activities_due || 0)"/>
                            <div class="bn-kpi-trend">Open Odoo activities</div>
                        </div>
                    </div>

                    <div class="bn-stage-strip">
                        <t t-foreach="state.data.stage_cards || []" t-as="s" t-key="s.key">
                            <button type="button"
                                    class="bn-stage-card"
                                    t-att-data-stage="s.key"
                                    t-attf-style="--stg: {{ s.color }};"
                                    t-on-click="openStageCases">
                                <div class="bn-stage-top">
                                    <span class="bn-stage-ico"><i t-attf-class="fa {{ s.icon }}"/></span>
                                    <span class="bn-stage-name" t-out="s.label"/>
                                </div>
                                <div class="bn-stage-value">
                                    <span class="n" t-out="fmtInt(s.count)"/>
                                    <span class="p" t-out="s.percent + '%'"/>
                                </div>
                                <div class="bn-stage-meter">
                                    <span t-attf-style="width: {{ s.percent }}%"/>
                                </div>
                            </button>
                        </t>
                    </div>

                    <div class="bn-chart-row">
                        <div class="bn-panel">
                            <div class="bn-panel-head">
                                <h2>Monthly volume (new rows)</h2>
                                <span class="hint">By create month</span>
                            </div>
                            <div class="bn-bar-chart" t-if="state.data.monthly_created.length">
                                <t t-foreach="state.data.monthly_created" t-as="m" t-key="m.period">
                                    <div class="bn-bar-slot">
                                        <div class="bn-bar" t-attf-style="height: {{ barHeight(m.count) }}%"/>
                                        <span class="label" t-out="shortMonth(m.period)"/>
                                    </div>
                                </t>
                            </div>
                            <div t-else="" class="bn-muted-empty">Not enough dated rows yet.</div>
                        </div>
                        <div class="bn-panel">
                            <div class="bn-panel-head">
                                <h2>Product / class mix</h2>
                                <span class="hint">By product class or label</span>
                            </div>
                            <div class="bn-pie-wrap" t-if="state.data.product_mix.length">
                                <div class="bn-pie" t-attf-style="background: {{ state.pieStyle }}"/>
                                <ul>
                                    <t t-foreach="state.data.product_mix" t-as="s" t-key="s.label">
                                        <li>
                                            <span class="sq" t-attf-style="background: {{ s.color }}"/>
                                            <span t-out="s.label"/>
                                            <span class="pct" t-out="s.percent + '%'"/>
                                        </li>
                                    </t>
                                </ul>
                            </div>
                            <div t-else="" class="bn-muted-empty">No classification data.</div>
                        </div>
                    </div>

                    <div class="bn-panel">
                        <div class="bn-panel-head">
                            <h2>Branch snapshot</h2>
                            <span class="hint">Top branches by loan count</span>
                        </div>
                        <div class="bn-entities-scroll" t-if="state.data.entity_cards.length">
                            <t t-foreach="state.data.entity_cards" t-as="e" t-key="e.title + '_' + e_index">
                                <article class="bn-entity-card">
                                    <header>
                                        <div class="ico"><i class="fa fa-building"/></div>
                                        <div>
                                            <h3 t-out="e.title"/>
                                            <span class="sub">Branch distribution</span>
                                        </div>
                                    </header>
                                    <dl class="grid2">
                                        <div>
                                            <dt>Total</dt>
                                            <dd t-out="fmtInt(e.total)"/>
                                        </div>
                                        <div>
                                            <dt>Exposure</dt>
                                            <dd t-out="fmtInt(e.active_exposure)"/>
                                        </div>
                                        <div>
                                            <dt>Settled hint</dt>
                                            <dd class="bn-ok" t-out="fmtInt(e.settled_hint)"/>
                                        </div>
                                        <div>
                                            <dt>POS sum</dt>
                                            <dd class="bn-money" t-out="fmtMoney(e.pos_amount)"/>
                                        </div>
                                    </dl>
                                </article>
                            </t>
                        </div>
                        <div t-else="" class="bn-muted-empty">No branch assignment — link branches on import.</div>
                    </div>
                </t>

                <t t-else="">
                    <div class="bn-muted-empty">No dashboard data.</div>
                </t>
            </div>
        </div>
    </t>

    <t t-name="bharatnyay_core.CaseManagerDashboard">
        <div class="o_bharatnyay_dashboard o_bn_role_dashboard">
            <div class="bn-wrap">
                <div class="bn-header">
                    <div class="bn-title-block">
                        <h1>Case Manager dashboard</h1>
                        <p>Case pipeline and arbitration billing</p>
                    </div>
                    <div class="bn-header-actions bn-date-filter">
                        <label class="bn-date-label">From</label>
                        <input type="date" class="bn-date-input" t-att-value="state.date_from" t-on-change="onDateFrom"/>
                        <label class="bn-date-label">To</label>
                        <input type="date" class="bn-date-input" t-att-value="state.date_to" t-on-change="onDateTo"/>
                        <button type="button" class="btn btn-primary btn-sm" t-on-click="applyDateFilter">Apply</button>
                        <button type="button" class="bn-icon-btn" title="Refresh" t-on-click="onRefresh">
                            <i class="fa fa-refresh"/>
                        </button>
                    </div>
                </div>
                <t t-if="state.loading">
                    <div class="bn-muted-empty"><i class="fa fa-spinner fa-spin fa-2x mb-2"/><div>Loading...</div></div>
                </t>
                <t t-elif="state.error">
                    <div class="bn-muted-empty bn-error"><span t-out="state.error"/></div>
                </t>
                <t t-elif="state.data">
                    <div class="bn-section-title">Case pipeline</div>
                    <div class="bn-bucket-strip">
                        <t t-foreach="state.data.bucket_cards || []" t-as="b" t-key="b.key">
                            <button type="button" class="bn-stage-card"
                                    t-att-data-bucket="b.key"
                                    t-attf-style="--stg: {{ b.color }};"
                                    t-on-click="openBucket">
                                <div class="bn-stage-top">
                                    <span class="bn-stage-ico"><i t-attf-class="fa {{ b.icon }}"/></span>
                                    <span class="bn-stage-name" t-out="b.label"/>
                                </div>
                                <div class="bn-stage-value">
                                    <span class="n" t-out="fmtInt(b.count)"/>
                                    <span class="p" t-out="percentLabel(b.percent)"/>
                                </div>
                                <div class="bn-stage-meter">
                                    <span t-attf-style="width: {{ b.percent }}%"/>
                                </div>
                            </button>
                        </t>
                    </div>
                    <div class="bn-section-title mt-3">Payments and invoices</div>
                    <div class="bn-kpi-grid bn-kpi-grid--4">
                        <div class="bn-kpi-card bn-kpi-card--click" data-filter="due" t-on-click="openInvoices">
                            <div class="bn-kpi-label">Cases due for invoice</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.cases_due_for_invoice)"/>
                            <div class="bn-kpi-trend">Milestone reached, not invoiced</div>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--click" data-filter="draft" t-on-click="openInvoices">
                            <div class="bn-kpi-label">Draft invoices</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.draft_invoices)"/>
                            <div class="bn-kpi-trend">In date range</div>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--click" data-filter="paid" t-on-click="openInvoices">
                            <div class="bn-kpi-label">Invoices paid</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.paid_invoices)"/>
                            <div class="bn-kpi-trend">Posted and paid</div>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--accent">
                            <div class="bn-kpi-label">Total due amount</div>
                            <div class="bn-kpi-value" t-out="fmtMoney(state.data.kpis.total_due_amount)"/>
                            <div class="bn-kpi-trend">Outstanding residual</div>
                        </div>
                    </div>
                    <div class="bn-kpi-grid bn-kpi-grid--3 bn-kpi-phase mt-2">
                        <div class="bn-kpi-card bn-kpi-card--success">
                            <div class="bn-kpi-label">Total received</div>
                            <div class="bn-kpi-value" t-out="fmtMoney(state.data.kpis.total_received_amount)"/>
                            <div class="bn-kpi-trend">Paid in selected period</div>
                        </div>
                        <div class="bn-kpi-card">
                            <div class="bn-kpi-label">Total cases</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.total_cases)"/>
                        </div>
                        <div class="bn-kpi-card">
                            <div class="bn-kpi-label">Hearings today</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.hearings_today)"/>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>

    <t t-name="bharatnyay_core.ArbitratorDashboard">
        <div class="o_bharatnyay_dashboard o_bn_role_dashboard">
            <div class="bn-wrap">
                <div class="bn-header">
                    <div class="bn-title-block">
                        <h1>Arbitrator dashboard</h1>
                        <p>My cases, hearings, and awards</p>
                    </div>
                    <div class="bn-header-actions bn-date-filter">
                        <label class="bn-date-label">From</label>
                        <input type="date" class="bn-date-input" t-att-value="state.date_from" t-on-change="onDateFrom"/>
                        <label class="bn-date-label">To</label>
                        <input type="date" class="bn-date-input" t-att-value="state.date_to" t-on-change="onDateTo"/>
                        <button type="button" class="btn btn-primary btn-sm" t-on-click="applyDateFilter">Apply</button>
                        <button type="button" class="bn-icon-btn" title="Refresh" t-on-click="onRefresh">
                            <i class="fa fa-refresh"/>
                        </button>
                        <button type="button" class="btn btn-secondary btn-sm" t-on-click="openMyCases">All my cases</button>
                    </div>
                </div>
                <t t-if="state.loading">
                    <div class="bn-muted-empty"><i class="fa fa-spinner fa-spin fa-2x mb-2"/><div>Loading...</div></div>
                </t>
                <t t-elif="state.error">
                    <div class="bn-muted-empty bn-error"><span t-out="state.error"/></div>
                </t>
                <t t-elif="state.data">
                    <div class="bn-kpi-grid bn-kpi-grid--4 bn-kpi-phase mb-3">
                        <div class="bn-kpi-card bn-kpi-card--accent">
                            <div class="bn-kpi-label">My cases</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.total_cases)"/>
                        </div>
                        <div class="bn-kpi-card">
                            <div class="bn-kpi-label">Hearings today</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.hearings_today)"/>
                        </div>
                        <div class="bn-kpi-card">
                            <div class="bn-kpi-label">Awards uploaded</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.awards_uploaded)"/>
                        </div>
                        <div class="bn-kpi-card">
                            <div class="bn-kpi-label">Award pending</div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.awards_pending)"/>
                        </div>
                    </div>
                    <div class="bn-section-title">My case pipeline</div>
                    <div class="bn-bucket-strip">
                        <t t-foreach="state.data.bucket_cards || []" t-as="b" t-key="b.key">
                            <button type="button" class="bn-stage-card"
                                    t-att-data-bucket="b.key"
                                    t-attf-style="--stg: {{ b.color }};"
                                    t-on-click="openBucket">
                                <div class="bn-stage-top">
                                    <span class="bn-stage-ico"><i t-attf-class="fa {{ b.icon }}"/></span>
                                    <span class="bn-stage-name" t-out="b.label"/>
                                </div>
                                <div class="bn-stage-value">
                                    <span class="n" t-out="fmtInt(b.count)"/>
                                    <span class="p" t-out="percentLabel(b.percent)"/>
                                </div>
                                <div class="bn-stage-meter">
                                    <span t-attf-style="width: {{ b.percent }}%"/>
                                </div>
                            </button>
                        </t>
                    </div>
                    <div class="bn-row-panels mt-3">
                        <div class="bn-panel-card">
                            <div class="bn-section-title">Upcoming hearings</div>
                            <t t-if="state.data.upcoming_hearings.length === 0">
                                <div class="bn-muted-empty bn-muted-empty--sm">No upcoming hearings scheduled.</div>
                            </t>
                            <t t-else="">
                                <t t-foreach="state.data.upcoming_hearings" t-as="h" t-key="h.id">
                                    <button type="button" class="bn-hearing-row"
                                            t-att-data-loan-id="h.loan_id"
                                            t-on-click="openLoan">
                                        <div class="bn-hearing-row__main">
                                            <strong t-out="h.loan_number"/>
                                            <span t-out="h.customer_name"/>
                                        </div>
                                        <div class="bn-hearing-row__dt" t-out="hearingDtLabel(h.hearing_datetime)"/>
                                    </button>
                                </t>
                            </t>
                        </div>
                        <div class="bn-panel-card bn-panel-card--payments">
                            <div class="bn-section-title">Payments (my cases)</div>
                            <div class="bn-kpi-grid bn-kpi-grid--4 bn-kpi-grid--compact">
                                <div class="bn-kpi-card bn-kpi-card--click" data-filter="due" t-on-click="openInvoices">
                                    <div class="bn-kpi-label">Payment due</div>
                                    <div class="bn-kpi-value" t-out="fmtMoney(state.data.kpis.total_due_amount)"/>
                                </div>
                                <div class="bn-kpi-card bn-kpi-card--success bn-kpi-card--click" data-filter="paid" t-on-click="openInvoices">
                                    <div class="bn-kpi-label">Payment received</div>
                                    <div class="bn-kpi-value" t-out="fmtMoney(state.data.kpis.total_received_amount)"/>
                                </div>
                                <div class="bn-kpi-card bn-kpi-card--click" data-filter="draft" t-on-click="openInvoices">
                                    <div class="bn-kpi-label">Draft invoices</div>
                                    <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.draft_invoices)"/>
                                </div>
                                <div class="bn-kpi-card">
                                    <div class="bn-kpi-label">Cases not invoiced</div>
                                    <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.cases_due_for_invoice)"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>
