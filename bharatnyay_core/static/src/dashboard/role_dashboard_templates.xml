<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="bharatnyay_core.DashboardFilterBar">
        <div t-att-class="'bn-filter-bar bn-filter-bar--inline ' + (filterBarClass or '')">
            <label class="bn-filter-pill" title="Notice region">
                <i class="fa fa-globe bn-filter-ico" aria-hidden="true"/>
                <span class="bn-filter-k">Region</span>
                <select class="bn-filter-select bn-filter-select--compact"
                        t-att-value="state.filter_region"
                        t-on-change="onFilterRegionChange">
                    <option value="">All</option>
                    <t t-foreach="state.filter_options.regions || []" t-as="r" t-key="r.id">
                        <option t-att-value="r.id" t-out="r.name"/>
                    </t>
                </select>
            </label>
            <label class="bn-filter-pill" title="State">
                <i class="fa fa-map-marker bn-filter-ico" aria-hidden="true"/>
                <span class="bn-filter-k">State</span>
                <select class="bn-filter-select bn-filter-select--compact"
                        t-att-value="state.filter_state"
                        t-on-change="onFilterStateChange">
                    <option value="">All</option>
                    <t t-foreach="state.filter_options.states || []" t-as="s" t-key="s.id">
                        <option t-att-value="s.id" t-out="s.name"/>
                    </t>
                </select>
            </label>
            <label class="bn-filter-pill" title="Batch">
                <i class="fa fa-cubes bn-filter-ico" aria-hidden="true"/>
                <span class="bn-filter-k">Batch</span>
                <select class="bn-filter-select bn-filter-select--compact"
                        t-att-value="state.filter_batch"
                        t-on-change="onFilterBatchChange">
                    <option value="">All</option>
                    <t t-foreach="state.filter_options.batches || []" t-as="b" t-key="b.key">
                        <option t-att-value="b.key" t-out="b.label"/>
                    </t>
                </select>
            </label>
        </div>
    </t>

    <t t-name="bharatnyay_core.DashboardRoleHeader">
        <div class="bn-header">
            <div class="bn-title-block">
                <h1 t-out="title"/>
                <p t-out="subtitle"/>
            </div>
            <div class="bn-header-actions bn-date-filter">
                <t t-call="bharatnyay_core.DashboardFilterBar"/>
                <label class="bn-date-label">From</label>
                <input type="date" class="bn-date-input" t-att-value="state.date_from" t-on-change="onDateFrom"/>
                <label class="bn-date-label">To</label>
                <input type="date" class="bn-date-input" t-att-value="state.date_to" t-on-change="onDateTo"/>
                <button type="button" class="btn btn-primary btn-sm" t-on-click="applyDateFilter">Apply</button>
                <button type="button" class="bn-icon-btn" title="Refresh" t-on-click="onRefresh">
                    <i class="fa fa-refresh"/>
                </button>
                <t t-if="showMyCasesBtn">
                    <button type="button" class="btn btn-secondary btn-sm" t-on-click="openMyCases">All my cases</button>
                </t>
            </div>
        </div>
    </t>

    <t t-name="bharatnyay_core.DashboardStageCardStrip">
        <div class="bn-stage-strip bn-stage-strip--flow">
            <t t-foreach="state.data.stage_cards || []" t-as="s" t-key="s.key">
                <div class="bn-stage-flow__step">
                    <button type="button"
                            class="bn-stage-card bn-stage-card--fill"
                            t-att-class="{
                                'bn-stage-card--billable': s.creates_unbilled_charge,
                                'bn-stage-card--empty': !s.count,
                            }"
                            t-attf-style="--bn-tank-fill: {{ s.percent }}%;"
                            t-att-data-stage="s.key"
                            t-on-click="openStageCases">
                        <span t-if="s.creates_unbilled_charge"
                              class="bn-stage-bill-badge"
                              t-att-title="s.billing_badge_title">
                            <i t-attf-class="fa {{ s.billing_badge_icon }}"/>
                        </span>
                        <div class="bn-stage-top">
                            <span class="bn-stage-ico"><i t-attf-class="fa {{ s.icon }}"/></span>
                            <span class="bn-stage-name" t-out="s.label"/>
                        </div>
                        <div class="bn-stage-value">
                            <span class="n" t-out="fmtInt(s.count)"/>
                            <span class="p" t-out="s.percent + '%'"/>
                        </div>
                        <div class="bn-stage-meter">
                            <span t-attf-style="width: {{ s.percent }}%"/>
                        </div>
                        <span t-if="s.creates_unbilled_charge"
                              class="bn-stage-bill-caption"
                              t-out="s.billing_badge_title"/>
                    </button>
                    <span t-if="!s_last" class="bn-stage-flow__connector" aria-hidden="true">
                        <span class="bn-stage-flow__pipe"/>
                        <i class="fa fa-chevron-right"/>
                    </span>
                </div>
            </t>
        </div>
    </t>

    <t t-name="bharatnyay_core.DashboardHearingAwardStrip">
        <div class="bn-section-title mt-2">Interim proceedings</div>
        <p class="bn-stage-strip-hint">
            Your assigned cases at hearing milestones and final award stage — click a card to open the list.
        </p>
        <div class="bn-stage-strip bn-stage-strip--hearing">
            <t t-foreach="state.data.hearing_stage_cards || []" t-as="s" t-key="s.key">
                <button type="button"
                        class="bn-stage-card bn-stage-card--fill"
                        t-att-class="{
                            'bn-stage-card--billable': s.creates_unbilled_charge,
                            'bn-stage-card--empty': !s.count,
                        }"
                        t-attf-style="--bn-tank-fill: {{ s.percent }}%;"
                        t-att-data-stage="s.key"
                        t-on-click="openStageCases">
                    <span t-if="s.creates_unbilled_charge"
                          class="bn-stage-bill-badge"
                          t-att-title="s.billing_badge_title">
                        <i t-attf-class="fa {{ s.billing_badge_icon }}"/>
                    </span>
                    <div class="bn-stage-top">
                        <span class="bn-stage-ico"><i t-attf-class="fa {{ s.icon }}"/></span>
                        <span class="bn-stage-name" t-out="s.label"/>
                    </div>
                    <div class="bn-stage-value">
                        <span class="n" t-out="fmtInt(s.count)"/>
                        <span class="p" t-out="s.percent + '%'"/>
                    </div>
                    <div class="bn-stage-meter">
                        <span t-attf-style="width: {{ s.percent }}%"/>
                    </div>
                </button>
            </t>
        </div>
    </t>

    <t t-name="bharatnyay_core.DashboardPanelRecentCases">
        <div class="bn-panel">
            <div class="bn-panel-head">
                <div class="bn-panel-head__title">
                    <span class="bn-panel-icon"><i class="fa fa-list-ul"/></span>
                    <h2>My cases</h2>
                </div>
                <button type="button" class="btn btn-link btn-sm p-0" t-on-click="openMyCases">View all</button>
            </div>
            <div class="bn-panel-body bn-panel-body--list">
                <t t-if="!(state.data.recent_cases || []).length">
                    <div class="bn-muted-empty bn-muted-empty--sm">No assigned cases yet.</div>
                </t>
                <t t-else="">
                    <t t-foreach="state.data.recent_cases" t-as="c" t-key="c.id">
                        <button type="button" class="bn-case-row"
                                t-att-data-loan-id="c.id"
                                t-on-click="openLoan">
                            <div class="bn-case-row__main">
                                <strong t-out="c.loan_number"/>
                                <span t-out="c.customer_name"/>
                            </div>
                            <div class="bn-case-row__meta">
                                <span class="bn-case-row__stage"
                                      t-attf-style="--stage-color: {{ c.milestone_color }}"
                                      t-out="c.milestone_label"/>
                                <span t-if="c.hearing_datetime" class="bn-case-row__dt"
                                      t-out="hearingDtLabel(c.hearing_datetime)"/>
                            </div>
                        </button>
                    </t>
                </t>
            </div>
        </div>
    </t>

    <t t-name="bharatnyay_core.DashboardPanelInvoiceSummary">
        <div class="bn-panel">
            <div class="bn-panel-head">
                <div class="bn-panel-head__title">
                    <span class="bn-panel-icon"><i class="fa fa-money"/></span>
                    <h2>My invoices</h2>
                </div>
                <span class="hint">Scoped to your assigned cases</span>
            </div>
            <div class="bn-panel-body">
                <div class="bn-invoice-summary">
                    <button type="button" class="bn-invoice-summary__card bn-invoice-summary__card--paid"
                            data-filter="paid"
                            t-on-click="openInvoices">
                        <span class="bn-invoice-summary__label">Paid</span>
                        <span class="bn-invoice-summary__amount" t-out="fmtMoney(state.data.kpis.paid_invoice_amount || 0)"/>
                        <span class="bn-invoice-summary__sub" t-out="fmtInt(state.data.kpis.paid_invoices || 0) + ' invoices'"/>
                    </button>
                    <button type="button" class="bn-invoice-summary__card bn-invoice-summary__card--unpaid"
                            data-filter="unpaid"
                            t-on-click="openInvoices">
                        <span class="bn-invoice-summary__label">Unpaid</span>
                        <span class="bn-invoice-summary__amount" t-out="fmtMoney(state.data.kpis.unpaid_invoice_amount || 0)"/>
                        <span class="bn-invoice-summary__sub" t-out="fmtInt(state.data.kpis.unpaid_invoices || 0) + ' invoices'"/>
                    </button>
                </div>
            </div>
        </div>
    </t>

    <t t-name="bharatnyay_core.DashboardPodStatusCard">
        <button type="button"
                t-attf-class="bn-stage-card bn-stage-card--fill bn-stage-card--pod bn-stage-card--pod-{{ p.document_type }} {{ p.pod_status === 'pending' ? 'bn-stage-card--pod-pending' : 'bn-stage-card--pod-done' }} {{ p.billable ? 'bn-stage-card--billable' : '' }} {{ !p.count ? 'bn-stage-card--empty' : '' }}"
                t-attf-style="--bn-tank-fill: {{ p.percent }}%;"
                t-att-data-pod-key="p.key"
                t-on-click="openPodStatusCases">
            <span t-if="p.billable"
                  class="bn-stage-bill-badge"
                  title="Delivery confirmed — billable">
                <i class="fa fa-check"/>
            </span>
            <div class="bn-stage-top">
                <span class="bn-stage-ico"><i t-attf-class="fa {{ p.icon }}"/></span>
                <span class="bn-stage-name" t-out="p.label"/>
            </div>
            <div class="bn-pod-status" t-out="p.status_label"/>
            <div class="bn-stage-value">
                <span class="n" t-out="fmtInt(p.count)"/>
                <span class="p" t-out="p.percent + '%'"/>
            </div>
            <div class="bn-stage-meter">
                <span t-attf-style="width: {{ p.percent }}%"/>
            </div>
            <span t-if="p.doc_total"
                  class="bn-stage-bill-caption"
                  t-out="fmtInt(p.count) + ' of ' + fmtInt(p.doc_total) + ' at this stage'"/>
        </button>
    </t>

    <t t-name="bharatnyay_core.DashboardPodStatusStrip">
        <div class="bn-section-title mt-2">Postal delivery (POD)</div>
        <p class="bn-stage-strip-hint">
            Notice 1, Hearing 1 &amp; Award — pending vs confirmed delivery (billable when POD is done).
            <span class="bn-stage-flow-hint">Pending → done within each milestone.</span>
        </p>
        <div class="bn-stage-strip bn-stage-strip--pod bn-stage-strip--pod-flow">
            <t t-foreach="state.data.pod_status_groups || []" t-as="g" t-key="g.key">
                <div class="bn-pod-flow__group">
                    <t t-set="p" t-value="g.pending"/>
                    <t t-call="bharatnyay_core.DashboardPodStatusCard"/>
                    <span class="bn-pod-flow__connector bn-stage-flow__connector" aria-hidden="true">
                        <span class="bn-stage-flow__pipe"/>
                        <i class="fa fa-chevron-right"/>
                    </span>
                    <t t-set="p" t-value="g.done"/>
                    <t t-call="bharatnyay_core.DashboardPodStatusCard"/>
                </div>
            </t>
        </div>
    </t>

    <t t-name="bharatnyay_core.DashboardPipeline">
        <div class="bn-section-title mt-2">Case pipeline</div>
        <p class="bn-stage-strip-hint">
            <i class="fa fa-file-text-o" title="Unbilled billing"/>
            Badge — unbilled charge when leaving milestone. Background fill height = share of total caseload.
            <span class="bn-stage-flow-hint">Cases move left → right through the pipeline.</span>
        </p>
        <t t-call="bharatnyay_core.DashboardStageCardStrip"/>
        <t t-call="bharatnyay_core.DashboardPodStatusStrip"/>
    </t>

    <t t-name="bharatnyay_core.DashboardPanelBatchVolumeStacked">
        <div class="bn-panel">
            <div class="bn-panel-head bn-panel-head--batch-volume">
                <div class="bn-panel-head__title">
                    <span class="bn-panel-icon"><i class="fa fa-bar-chart"/></span>
                    <h2>Batch volume</h2>
                </div>
                <div class="bn-segment-toggle" role="radiogroup" aria-label="Batch volume split">
                    <label class="bn-segment-toggle__item">
                        <input type="radio"
                               name="batchVolumeMode"
                               value="payment"
                               t-att-checked="state.batchVolumeMode === 'payment'"
                               t-on-change="onBatchVolumeModeChange"/>
                        <span>Payment</span>
                    </label>
                    <label class="bn-segment-toggle__item">
                        <input type="radio"
                               name="batchVolumeMode"
                               value="stage"
                               t-att-checked="state.batchVolumeMode === 'stage'"
                               t-on-change="onBatchVolumeModeChange"/>
                        <span>Stages</span>
                    </label>
                </div>
            </div>
            <div class="bn-panel-body">
                <t t-if="batchVolumeHasData()">
                    <div class="bn-bar-chart bn-bar-chart--batch">
                        <t t-if="state.batchVolumeMode === 'payment'">
                            <t t-foreach="state.data.batch_volume" t-as="b" t-key="b.batch">
                                <button type="button"
                                        class="bn-bar-slot"
                                        t-att-data-batch="b.batch_key"
                                        t-att-title="batchBarTitle(b)"
                                        t-on-click="openBatchCases">
                                    <div class="bn-bar-stack" t-attf-style="height: {{ batchBarHeight(b.count) }}%;">
                                        <div t-if="b.paid_cases"
                                             class="bn-bar-seg bn-bar-seg--paid"
                                             t-attf-style="height: {{ batchSegPct(b, 'paid_cases') }}%;"
                                             t-att-title="'Paid: ' + fmtInt(b.paid_cases)"/>
                                        <div t-if="b.unpaid_cases"
                                             class="bn-bar-seg bn-bar-seg--unpaid"
                                             t-attf-style="height: {{ batchSegPct(b, 'unpaid_cases') }}%;"
                                             t-att-title="'Unpaid: ' + fmtInt(b.unpaid_cases)"/>
                                        <div t-if="b.other_cases"
                                             class="bn-bar-seg bn-bar-seg--other"
                                             t-attf-style="height: {{ batchSegPct(b, 'other_cases') }}%;"
                                             t-att-title="'Not invoiced: ' + fmtInt(b.other_cases)"/>
                                    </div>
                                    <span class="label" t-out="shortBatchLabel(b.batch)"/>
                                    <span class="bn-bar-count" t-out="fmtInt(b.count)"/>
                                </button>
                            </t>
                        </t>
                        <t t-else="">
                            <t t-foreach="state.data.batch_volume_stages || []" t-as="b" t-key="b.batch">
                                <button type="button"
                                        class="bn-bar-slot"
                                        t-att-data-batch="b.batch_key"
                                        t-att-title="batchBarTitleStage(b)"
                                        t-on-click="openBatchCases">
                                    <div class="bn-bar-stack" t-attf-style="height: {{ batchBarHeight(b.count) }}%;">
                                        <t t-foreach="b.segments || []" t-as="seg" t-key="seg.key">
                                            <div class="bn-bar-seg bn-bar-seg--stage"
                                                 t-att-data-stage="seg.key"
                                                 t-attf-style="height: {{ batchSegPctCount(b, seg.count) }}%; background-color: {{ seg.color }};"
                                                 t-att-title="seg.label + ': ' + fmtInt(seg.count)"
                                                 t-on-click="openBatchStageCases"/>
                                        </t>
                                    </div>
                                    <span class="label" t-out="shortBatchLabel(b.batch)"/>
                                    <span class="bn-bar-count" t-out="fmtInt(b.count)"/>
                                </button>
                            </t>
                        </t>
                    </div>
                    <div class="bn-bar-legend" t-if="state.batchVolumeMode === 'payment'">
                        <span class="bn-bar-legend__item"><i class="sq sq--paid"/> Paid</span>
                        <span class="bn-bar-legend__item"><i class="sq sq--unpaid"/> Unpaid</span>
                        <span class="bn-bar-legend__item"><i class="sq sq--other"/> Not invoiced</span>
                    </div>
                    <div class="bn-bar-legend" t-else="">
                        <t t-foreach="state.data.batch_volume_stage_legend || []" t-as="leg" t-key="leg.key">
                            <span class="bn-bar-legend__item">
                                <i class="sq" t-attf-style="background: {{ leg.color }};"/>
                                <span t-out="leg.label"/>
                            </span>
                        </t>
                    </div>
                </t>
                <div t-else="" class="bn-muted-empty">No batch data yet.</div>
            </div>
        </div>
    </t>

    <t t-name="bharatnyay_core.DashboardPanelBatchVolume">
        <t t-call="bharatnyay_core.DashboardPanelBatchVolumeStacked"/>
    </t>

    <t t-name="bharatnyay_core.DashboardPanelUpcomingHearings">
        <div class="bn-panel">
            <div class="bn-panel-head">
                <div class="bn-panel-head__title">
                    <span class="bn-panel-icon"><i class="fa fa-calendar"/></span>
                    <h2>Upcoming hearings</h2>
                </div>
                <span class="hint">Next scheduled sessions</span>
            </div>
            <div class="bn-panel-body bn-panel-body--list">
                <t t-if="!(state.data.upcoming_hearings || []).length">
                    <div class="bn-muted-empty bn-muted-empty--sm">No upcoming hearings scheduled.</div>
                </t>
                <t t-else="">
                    <t t-foreach="state.data.upcoming_hearings" t-as="h" t-key="h.id">
                        <button type="button" class="bn-hearing-row"
                                t-att-data-loan-id="h.loan_id"
                                t-on-click="openLoan">
                            <div class="bn-hearing-row__main">
                                <strong t-out="h.loan_number"/>
                                <span t-out="h.customer_name"/>
                            </div>
                            <div class="bn-hearing-row__dt" t-out="hearingDtLabel(h.hearing_datetime)"/>
                        </button>
                    </t>
                </t>
            </div>
        </div>
    </t>

    <t t-name="bharatnyay_core.DashboardPanelCaseStatus">
        <div class="bn-panel">
            <div class="bn-panel-head">
                <div class="bn-panel-head__title">
                    <span class="bn-panel-icon"><i class="fa fa-tasks"/></span>
                    <h2>Case status</h2>
                </div>
                <span class="hint">Notice 1–3, hearings, award</span>
            </div>
            <div class="bn-panel-body">
                <div class="bn-pie-wrap" t-if="state.data.workflow_mix.length">
                    <div class="bn-pie" t-attf-style="background: {{ state.workflowPieStyle }}"/>
                    <ul>
                        <t t-foreach="state.data.workflow_mix" t-as="s" t-key="s.key">
                            <li class="bn-pie-legend-item bn-pie-legend-item--click"
                                t-att-data-stage="s.key"
                                t-on-click="openStageCases">
                                <span class="sq" t-attf-style="background: {{ s.color }}"/>
                                <span class="lbl" t-out="s.label"/>
                                <span class="pct" t-out="s.percent + '%'"/>
                            </li>
                        </t>
                    </ul>
                </div>
                <div t-else="" class="bn-muted-empty">No workflow data.</div>
            </div>
        </div>
    </t>

    <t t-name="bharatnyay_core.DashboardPanelPaymentStatus">
        <div class="bn-panel">
            <div class="bn-panel-head">
                <div class="bn-panel-head__title">
                    <span class="bn-panel-icon"><i class="fa fa-credit-card"/></span>
                    <h2>Payment status</h2>
                </div>
                <span class="hint">Arbitration invoices</span>
            </div>
            <div class="bn-panel-body">
                <div class="bn-pie-wrap" t-if="state.data.payment_mix.length">
                    <div class="bn-pie" t-attf-style="background: {{ state.paymentPieStyle }}"/>
                    <ul>
                        <t t-foreach="state.data.payment_mix" t-as="s" t-key="s.filter">
                            <li class="bn-pie-legend-item bn-pie-legend-item--click"
                                t-att-data-filter="s.filter"
                                t-on-click="openInvoices">
                                <span class="sq" t-attf-style="background: {{ s.color }}"/>
                                <span class="lbl" t-out="s.label"/>
                                <span class="pct" t-out="s.percent + '%'"/>
                            </li>
                        </t>
                    </ul>
                </div>
                <div t-else="" class="bn-muted-empty">No invoice data.</div>
            </div>
        </div>
    </t>

    <t t-name="bharatnyay_core.DashboardBreakdownRow2">
        <div class="bn-chart-row bn-chart-row--3 mt-2">
            <div class="bn-panel">
                <div class="bn-panel-head">
                    <div class="bn-panel-head__title">
                        <span class="bn-panel-icon"><i class="fa fa-building-o"/></span>
                        <h2>Branch mix</h2>
                    </div>
                    <span class="hint">Click a branch to filter cases</span>
                </div>
                <div class="bn-panel-body">
                    <div class="bn-pie-wrap" t-if="state.data.branch_mix.length">
                        <div class="bn-pie" t-attf-style="background: {{ state.branchPieStyle }}"/>
                        <ul>
                            <t t-foreach="state.data.branch_mix" t-as="s" t-key="s.label">
                                <li t-att-class="s.id !== undefined ? 'bn-pie-legend-item bn-pie-legend-item--click' : 'bn-pie-legend-item'"
                                    t-att-data-mix-kind="'branch'"
                                    t-att-data-mix-id="s.id"
                                    t-on-click="openMixCases">
                                    <span class="sq" t-attf-style="background: {{ s.color }}"/>
                                    <span class="lbl" t-out="s.label"/>
                                    <span class="pct" t-out="s.percent + '%'"/>
                                </li>
                            </t>
                        </ul>
                    </div>
                    <div t-else="" class="bn-muted-empty">No branch data.</div>
                </div>
            </div>
            <div class="bn-panel">
                <div class="bn-panel-head">
                    <div class="bn-panel-head__title">
                        <span class="bn-panel-icon"><i class="fa fa-cubes"/></span>
                        <h2>Product mix</h2>
                    </div>
                    <span class="hint">By product class</span>
                </div>
                <div class="bn-panel-body">
                    <div class="bn-pie-wrap" t-if="state.data.product_mix.length">
                        <div class="bn-pie" t-attf-style="background: {{ state.pieStyle }}"/>
                        <ul>
                            <t t-foreach="state.data.product_mix" t-as="s" t-key="s.label">
                                <li class="bn-pie-legend-item">
                                    <span class="sq" t-attf-style="background: {{ s.color }}"/>
                                    <span class="lbl" t-out="s.label"/>
                                    <span class="pct" t-out="s.percent + '%'"/>
                                </li>
                            </t>
                        </ul>
                    </div>
                    <div t-else="" class="bn-muted-empty">No classification data.</div>
                </div>
            </div>
            <div class="bn-panel">
                <div class="bn-panel-head">
                    <div class="bn-panel-head__title">
                        <span class="bn-panel-icon"><i class="fa fa-map-marker"/></span>
                        <h2>Location mix</h2>
                    </div>
                    <span class="hint">Click a location to filter cases</span>
                </div>
                <div class="bn-panel-body">
                    <div class="bn-pie-wrap" t-if="state.data.location_mix.length">
                        <div class="bn-pie" t-attf-style="background: {{ state.locationPieStyle }}"/>
                        <ul>
                            <t t-foreach="state.data.location_mix" t-as="s" t-key="s.label">
                                <li t-att-class="s.id !== undefined ? 'bn-pie-legend-item bn-pie-legend-item--click' : 'bn-pie-legend-item'"
                                    t-att-data-mix-kind="'location'"
                                    t-att-data-mix-id="s.id"
                                    t-on-click="openMixCases">
                                    <span class="sq" t-attf-style="background: {{ s.color }}"/>
                                    <span class="lbl" t-out="s.label"/>
                                    <span class="pct" t-out="s.percent + '%'"/>
                                </li>
                            </t>
                        </ul>
                    </div>
                    <div t-else="" class="bn-muted-empty">No location data.</div>
                </div>
            </div>
        </div>
    </t>

    <t t-name="bharatnyay_core.CaseManagerDashboard">
        <div class="o_bharatnyay_dashboard o_bn_role_dashboard">
            <div class="bn-wrap">
                <t t-set="title" t-value="'Case Manager dashboard'"/>
                <t t-set="subtitle" t-value="state.data?.scope_label || 'Cases assigned to you — pipeline, hearings, and billing'"/>
                <t t-set="showMyCasesBtn" t-value="true"/>
                <t t-call="bharatnyay_core.DashboardRoleHeader"/>

                <t t-if="state.loading">
                    <div class="bn-muted-empty">
                        <i class="fa fa-spinner fa-spin fa-2x mb-2"/>
                        <div>Loading dashboard…</div>
                    </div>
                </t>
                <t t-elif="state.error">
                    <div class="bn-muted-empty bn-error"><span t-out="state.error"/></div>
                </t>
                <t t-elif="state.data">
                    <div class="bn-kpi-grid bn-kpi-grid--7">
                        <div class="bn-kpi-card bn-kpi-card--click bn-kpi-card--tone-blue"
                             t-att-class="{'bn-kpi-card--empty': !(state.data.kpis.total_cases || 0)}"
                             t-on-click="openMyCases">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-briefcase"/></span>
                                <div class="bn-kpi-label">My cases</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.total_cases)"/>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--click bn-kpi-card--tone-green"
                             t-att-class="{'bn-kpi-card--empty': !(state.data.kpis.total_batches || 0)}"
                             t-on-click="openTotalBatches">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-cubes"/></span>
                                <div class="bn-kpi-label">Total batches</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.total_batches || 0)"/>
                            <div class="bn-kpi-trend">Distinct import batches</div>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--click bn-kpi-card--tone-cyan"
                             t-att-class="{'bn-kpi-card--empty': !(state.data.kpis.postal_status_pending_count || 0)}"
                             t-on-click="openPendingPostalStatus">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-envelope-o"/></span>
                                <div class="bn-kpi-label">Awaiting POD status</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.postal_status_pending_count || 0)"/>
                            <div class="bn-kpi-trend"
                                 t-out="fmtMoney(state.data.kpis.postal_status_pending_amount || 0) + ' · ' + fmtInt(state.data.kpis.postal_status_pending_notice_1 || 0) + ' N1, ' + fmtInt(state.data.kpis.postal_status_pending_interim_1 || 0) + ' IO1'"/>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--click bn-kpi-card--tone-teal"
                             t-att-class="{'bn-kpi-card--empty': !(state.data.kpis.paid_invoice_amount || 0) and !(state.data.kpis.paid_invoices || 0)}"
                             data-filter="paid"
                             t-on-click="openInvoices">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-check-circle"/></span>
                                <div class="bn-kpi-label">Payment received</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtMoney(state.data.kpis.paid_invoice_amount || 0)"/>
                            <div class="bn-kpi-trend" t-out="fmtInt(state.data.kpis.paid_invoices || 0) + ' invoices'"/>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--click bn-kpi-card--tone-amber"
                             t-att-class="{'bn-kpi-card--empty': !(state.data.kpis.unpaid_invoice_amount || 0) and !(state.data.kpis.unpaid_invoices || 0)}"
                             data-filter="unpaid"
                             t-on-click="openInvoices">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-file-text-o"/></span>
                                <div class="bn-kpi-label">Payment due</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtMoney(state.data.kpis.unpaid_invoice_amount || 0)"/>
                            <div class="bn-kpi-trend" t-out="fmtInt(state.data.kpis.unpaid_invoices || 0) + ' invoices'"/>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--click bn-kpi-card--tone-rose"
                             t-att-class="{'bn-kpi-card--empty': !(state.data.kpis.unbilled_cases || 0)}"
                             t-on-click="openUnbilledCases">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-clock-o"/></span>
                                <div class="bn-kpi-label">Unbilled cases</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.unbilled_cases || 0)"/>
                            <div class="bn-kpi-trend" t-out="fmtInt(state.data.kpis.pending_billing_charges || 0) + ' pending charges'"/>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--tone-purple"
                             t-att-class="{'bn-kpi-card--empty': !(state.data.kpis.hearings_today || 0)}">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-gavel" title="Hearings today"/></span>
                                <div class="bn-kpi-label">Hearings today</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.hearings_today || 0)"/>
                        </div>
                    </div>

                    <div class="bn-chart-row bn-chart-row--2 mt-2">
                        <t t-call="bharatnyay_core.DashboardPanelRecentCases"/>
                        <t t-call="bharatnyay_core.DashboardPanelInvoiceSummary"/>
                    </div>

                    <t t-call="bharatnyay_core.DashboardPipeline"/>

                    <div class="bn-section-title mt-3">Portfolio breakdown</div>
                    <div class="bn-chart-row bn-chart-row--3">
                        <t t-call="bharatnyay_core.DashboardPanelBatchVolume"/>
                        <t t-call="bharatnyay_core.DashboardPanelCaseStatus"/>
                        <t t-call="bharatnyay_core.DashboardPanelPaymentStatus"/>
                    </div>
                    <t t-call="bharatnyay_core.DashboardBreakdownRow2"/>
                </t>
            </div>
        </div>
    </t>

    <t t-name="bharatnyay_core.ArbitratorDashboard">
        <div class="o_bharatnyay_dashboard o_bn_role_dashboard">
            <div class="bn-wrap">
                <t t-set="title" t-value="'Arbitrator dashboard'"/>
                <t t-set="subtitle" t-value="state.data?.scope_label || 'Cases assigned to you — hearings, awards, and invoices'"/>
                <t t-set="showMyCasesBtn" t-value="true"/>
                <t t-call="bharatnyay_core.DashboardRoleHeader"/>

                <t t-if="state.loading">
                    <div class="bn-muted-empty">
                        <i class="fa fa-spinner fa-spin fa-2x mb-2"/>
                        <div>Loading dashboard…</div>
                    </div>
                </t>
                <t t-elif="state.error">
                    <div class="bn-muted-empty bn-error"><span t-out="state.error"/></div>
                </t>
                <t t-elif="state.data">
                    <div class="bn-kpi-grid bn-kpi-grid--6">
                        <div class="bn-kpi-card bn-kpi-card--click bn-kpi-card--tone-blue"
                             t-att-class="{'bn-kpi-card--empty': !(state.data.kpis.total_cases || 0)}"
                             t-on-click="openMyCases">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-briefcase"/></span>
                                <div class="bn-kpi-label">My cases</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.total_cases)"/>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--tone-purple"
                             t-att-class="{'bn-kpi-card--empty': !(state.data.kpis.hearings_today || 0)}">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-gavel" title="Hearings today"/></span>
                                <div class="bn-kpi-label">Hearings today</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.hearings_today || 0)"/>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--tone-green"
                             t-att-class="{'bn-kpi-card--empty': !(state.data.kpis.upcoming_hearings_count || 0)}">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-calendar-check-o"/></span>
                                <div class="bn-kpi-label">Upcoming hearings</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.upcoming_hearings_count || 0)"/>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--click bn-kpi-card--tone-teal"
                             t-att-class="{'bn-kpi-card--empty': !(state.data.kpis.paid_invoice_amount || 0) and !(state.data.kpis.paid_invoices || 0)}"
                             data-filter="paid"
                             t-on-click="openInvoices">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-check-circle"/></span>
                                <div class="bn-kpi-label">Paid invoices</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtMoney(state.data.kpis.paid_invoice_amount || 0)"/>
                            <div class="bn-kpi-trend" t-out="fmtInt(state.data.kpis.paid_invoices || 0) + ' invoices'"/>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--click bn-kpi-card--tone-amber"
                             t-att-class="{'bn-kpi-card--empty': !(state.data.kpis.unpaid_invoice_amount || 0) and !(state.data.kpis.unpaid_invoices || 0)}"
                             data-filter="unpaid"
                             t-on-click="openInvoices">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-file-text-o"/></span>
                                <div class="bn-kpi-label">Unpaid invoices</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtMoney(state.data.kpis.unpaid_invoice_amount || 0)"/>
                            <div class="bn-kpi-trend" t-out="fmtInt(state.data.kpis.unpaid_invoices || 0) + ' invoices'"/>
                        </div>
                        <div class="bn-kpi-card bn-kpi-card--tone-indigo"
                             t-att-class="{'bn-kpi-card--empty': !(state.data.kpis.awards_uploaded || 0) and !(state.data.kpis.awards_pending || 0)}">
                            <div class="bn-kpi-card__head">
                                <span class="bn-kpi-icon"><i class="fa fa-trophy"/></span>
                                <div class="bn-kpi-label">Final awards</div>
                            </div>
                            <div class="bn-kpi-value" t-out="fmtInt(state.data.kpis.awards_uploaded || 0)"/>
                            <div class="bn-kpi-trend" t-out="fmtInt(state.data.kpis.awards_pending || 0) + ' pending upload'"/>
                        </div>
                    </div>

                    <t t-call="bharatnyay_core.DashboardHearingAwardStrip"/>

                    <div class="bn-chart-row bn-chart-row--2 mt-2">
                        <t t-call="bharatnyay_core.DashboardPanelRecentCases"/>
                        <t t-call="bharatnyay_core.DashboardPanelUpcomingHearings"/>
                    </div>

                    <t t-call="bharatnyay_core.DashboardPipeline"/>

                    <div class="bn-section-title mt-3">Billing</div>
                    <div class="bn-chart-row bn-chart-row--2 mt-2">
                        <t t-call="bharatnyay_core.DashboardPanelInvoiceSummary"/>
                    </div>
                </t>
            </div>
        </div>
    </t>

</templates>
