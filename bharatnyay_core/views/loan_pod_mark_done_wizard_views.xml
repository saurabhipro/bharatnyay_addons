<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bharat_loan_pod_mark_done_wizard_form" model="ir.ui.view">
        <field name="name">bharat.loan.pod.mark.done.wizard.form</field>
        <field name="model">bharat.loan.pod.mark.done.wizard</field>
        <field name="arch" type="xml">
            <form string="Mark POD delivered" class="bn-milestone-advance-wizard">
                <sheet>
                    <div class="bn-milestone-advance-wizard__hero">
                        <div class="bn-milestone-advance-wizard__hero-icon">
                            <i class="fa fa-check-circle" title="POD delivered"/>
                        </div>
                        <div class="bn-milestone-advance-wizard__hero-body">
                            <h1 class="bn-milestone-advance-wizard__title">Mark POD delivered</h1>
                            <p class="bn-milestone-advance-wizard__subtitle">
                                Set
                                <span class="bn-milestone-advance-wizard__count">
                                    <field name="dispatch_count" readonly="1" nolabel="1" class="oe_inline"/>
                                </span>
                                pending delivery row(s) to <b>Delivered</b> and accrue unbilled charges
                                for Notice 1, Hearing 1, and Award in the current filter.
                            </p>
                        </div>
                    </div>

                    <div class="bn-milestone-advance-wizard__filters"
                         invisible="not filter_region_id and not filter_state_id and not filter_batch_number">
                        <div class="bn-milestone-advance-wizard__filters-label">Current filter</div>
                        <span class="bn-milestone-advance-wizard__filter-chip" invisible="not filter_region_id">
                            <i class="fa fa-map-marker" title="Region"/>
                            <field name="filter_region_id" readonly="1" nolabel="1" class="oe_inline"/>
                        </span>
                        <span class="bn-milestone-advance-wizard__filter-chip" invisible="not filter_state_id">
                            <i class="fa fa-flag" title="State"/>
                            <field name="filter_state_id" readonly="1" nolabel="1" class="oe_inline"/>
                        </span>
                        <span class="bn-milestone-advance-wizard__filter-chip" invisible="not filter_batch_number">
                            <i class="fa fa-database" title="Batch"/>
                            <field name="filter_batch_number" readonly="1" nolabel="1" class="oe_inline"/>
                        </span>
                    </div>

                    <div class="bn-milestone-advance-wizard__section-title">Rows to update</div>
                    <div class="bn-milestone-advance-wizard__options">
                        <div class="bn-milestone-advance-wizard__option">
                            <div class="bn-milestone-advance-wizard__option-icon bn-milestone-advance-wizard__option-icon--email">
                                <i class="fa fa-envelope-o" title="Notice 1"/>
                            </div>
                            <div class="bn-milestone-advance-wizard__option-body">
                                <strong>Notice 1 — POD pending</strong>
                                <span class="bn-milestone-advance-wizard__option-hint">
                                    <field name="notice_1_count" readonly="1" nolabel="1" class="oe_inline fw-bold"/>
                                    case(s) will be marked delivered and billed.
                                </span>
                            </div>
                        </div>
                        <div class="bn-milestone-advance-wizard__option">
                            <div class="bn-milestone-advance-wizard__option-icon bn-milestone-advance-wizard__option-icon--pdf">
                                <i class="fa fa-video-camera" title="Hearing 1"/>
                            </div>
                            <div class="bn-milestone-advance-wizard__option-body">
                                <strong>Hearing 1 — POD pending</strong>
                                <span class="bn-milestone-advance-wizard__option-hint">
                                    <field name="interim_1_count" readonly="1" nolabel="1" class="oe_inline fw-bold"/>
                                    case(s) will be marked delivered and billed.
                                </span>
                            </div>
                        </div>
                        <div class="bn-milestone-advance-wizard__option">
                            <div class="bn-milestone-advance-wizard__option-icon bn-milestone-advance-wizard__option-icon--sms">
                                <i class="fa fa-trophy" title="Award"/>
                            </div>
                            <div class="bn-milestone-advance-wizard__option-body">
                                <strong>Award — POD pending</strong>
                                <span class="bn-milestone-advance-wizard__option-hint">
                                    <field name="award_count" readonly="1" nolabel="1" class="oe_inline fw-bold"/>
                                    case(s) will be marked delivered and billed.
                                </span>
                            </div>
                        </div>
                    </div>
                </sheet>
                <footer class="bn-milestone-advance-wizard__footer">
                    <button name="action_confirm" type="object"
                            string="Mark delivered &amp; accrue charges" class="btn-primary" icon="fa-check"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bharat_loan_pod_mark_done_wizard" model="ir.actions.act_window">
        <field name="name">Mark POD delivered</field>
        <field name="res_model">bharat.loan.pod.mark.done.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
