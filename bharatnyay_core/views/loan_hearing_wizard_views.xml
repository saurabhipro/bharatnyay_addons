<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bharat_loan_hearing_schedule_wizard_form" model="ir.ui.view">
        <field name="name">bharat.loan.hearing.schedule.wizard.form</field>
        <field name="model">bharat.loan.hearing.schedule.wizard</field>
        <field name="arch" type="xml">
            <form string="Schedule Hearing" class="bn-hearing-wizard">
                <field name="hearing_reschedule" invisible="1"/>
                <field name="grid_selected_date" invisible="1"/>
                <field name="calendar_week_start" invisible="1"/>
                <field name="scheduler_week_start" invisible="1"/>
                <field name="slot_board_json" invisible="1"/>
                <field name="week_board_json" invisible="1"/>
                <field name="selected_slot_range_display" invisible="1"/>

                <div class="bn-hearing-wizard__panel bn-hearing-wizard__panel--top">
                    <div class="bn-hearing-wizard__topbar">
                        <div class="bn-hearing-wizard__topbar-block bn-hearing-wizard__topbar-block--case">
                            <span class="bn-hearing-wizard__kicker">Case</span>
                            <field name="loan_id" readonly="1" nolabel="1" class="bn-hearing-wizard__case-name"/>
                        </div>

                        <div class="bn-hearing-wizard__topbar-divider" invisible="use_manual_time"/>

                        <div class="bn-hearing-wizard__topbar-block bn-hearing-wizard__topbar-block--selection"
                             invisible="use_manual_time">
                            <span class="bn-hearing-wizard__kicker">Selected</span>
                            <field name="scheduler_selection_label"
                                   readonly="1"
                                   nolabel="1"
                                   class="bn-hearing-wizard__selection-pill"/>
                        </div>

                        <div class="bn-hearing-wizard__topbar-divider" invisible="use_manual_time"/>

                        <div class="bn-hearing-wizard__topbar-block bn-hearing-wizard__topbar-block--controls">
                            <field name="scheduler_view_mode"
                                   widget="radio"
                                   options="{'horizontal': true}"
                                   invisible="use_manual_time"
                                   nolabel="1"/>
                            <field name="scheduler_date"
                                   invisible="use_manual_time"
                                   nolabel="1"
                                   placeholder="Day"/>
                            <field name="use_manual_time" nolabel="1"/>
                            <field name="hearing_datetime"
                                   invisible="not use_manual_time"
                                   nolabel="1"
                                   force_save="1"/>
                        </div>
                    </div>
                </div>

                <div class="bn-hearing-wizard__split" invisible="use_manual_time">
                    <div class="bn-hearing-wizard__split-col bn-hearing-wizard__split-col--calendar">
                        <div class="bn-hearing-wizard__panel bn-hearing-wizard__panel--calendar">
                            <div class="bn-hearing-wizard__panel-title">Pick a slot · Mon–Fri · 09:00–17:00 · 30 min</div>
                            <field name="grid_selected_index"
                                   widget="bn_hearing_scheduler"
                                   nolabel="1"
                                   class="bn-hearing-wizard__scheduler-field"/>
                        </div>
                    </div>

                    <div class="bn-hearing-wizard__split-col bn-hearing-wizard__split-col--side">
                        <div class="bn-hearing-wizard__panel bn-hearing-wizard__panel--attendees">
                            <div class="bn-hearing-wizard__teams-header">
                                <i class="fa fa-video-camera" title="Video hearing"/>
                                <span>Video hearing invitees</span>
                            </div>

                            <div class="bn-hearing-wizard__attendee-block">
                                <div class="bn-hearing-wizard__attendee-label">
                                    <i class="fa fa-gavel"/> Arbitrator &amp; lender team
                                </div>
                                <field name="invite_user_ids"
                                       widget="many2many_tags"
                                       nolabel="1"
                                       options="{'no_create': True}"
                                       placeholder="Select Odoo users…"/>
                            </div>

                            <div class="bn-hearing-wizard__attendee-block">
                                <div class="bn-hearing-wizard__attendee-label">
                                    <i class="fa fa-users"/> Borrower &amp; lender contacts
                                </div>
                                <field name="external_attendee_partner_ids"
                                       widget="many2many_tags"
                                       nolabel="1"
                                       placeholder="Select contacts…"/>
                            </div>

                            <div class="bn-hearing-wizard__attendee-block">
                                <div class="bn-hearing-wizard__attendee-label">
                                    <i class="fa fa-envelope-o"/> Additional emails
                                </div>
                                <field name="external_attendee_emails"
                                       nolabel="1"
                                       placeholder="counsel@firm.com"
                                       class="bn-hearing-wizard__email-input"/>
                            </div>

                            <div class="bn-hearing-wizard__hint">
                                Defaults: arbitrator, case manager (lender), borrower and lender company.
                                Remove tags or add more before saving.
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bn-hearing-wizard__panel bn-hearing-wizard__panel--attendees" invisible="not use_manual_time">
                    <div class="bn-hearing-wizard__teams-header">
                        <i class="fa fa-video-camera"/>
                        <span>Video hearing invitees</span>
                    </div>
                    <field name="invite_user_ids" widget="many2many_tags" nolabel="1" options="{'no_create': True}"/>
                    <field name="external_attendee_partner_ids" widget="many2many_tags" nolabel="1"/>
                    <field name="external_attendee_emails" nolabel="1" class="bn-hearing-wizard__email-input"/>
                </div>

                <div class="bn-hearing-wizard__panel bn-hearing-wizard__panel--outcome" invisible="hearing_reschedule">
                    <field name="was_user_present"/>
                    <field name="is_final_award"/>
                </div>

                <footer class="bn-hearing-wizard__footer">
                    <button string="Schedule &amp; Move to Final Award" type="object" name="action_schedule"
                            class="btn-primary" invisible="hearing_reschedule or not is_final_award"/>
                    <button string="Schedule &amp; Move to Hearing" type="object" name="action_schedule"
                            class="btn-primary" invisible="hearing_reschedule or is_final_award"/>
                    <button string="Save new time" type="object" name="action_schedule"
                            class="btn-primary" invisible="not hearing_reschedule"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_bharat_loan_interim_award_wizard_form" model="ir.ui.view">
        <field name="name">bharat.loan.interim.award.wizard.form</field>
        <field name="model">bharat.loan.interim.award.wizard</field>
        <field name="arch" type="xml">
            <form string="Pass Interim Award" class="bn-interim-award-wizard">
                <field name="currency_id" invisible="1"/>
                <field name="draft_pdf_filename" invisible="1"/>
                <field name="purpose" invisible="1"/>
                <field name="typical_loan_type" invisible="1"/>
                <field name="passed_by" invisible="1"/>
                <field name="common_directions" invisible="1"/>

                <div class="bn-interim-award-wizard__split">
                    <div class="bn-interim-award-wizard__panel bn-interim-award-wizard__panel--meta">
                        <div class="bn-interim-award-wizard__panel-title">Order details</div>
                        <group>
                            <field name="loan_id"/>
                            <field name="order_type"/>
                            <field name="interim_award_amount"/>
                            <field name="interim_award_notes"
                                   placeholder="Additional procedural directions, deposit orders, timelines, …"/>
                            <field name="was_user_present"/>
                            <field name="is_final_award"/>
                        </group>
                    </div>

                    <div class="bn-interim-award-wizard__panel bn-interim-award-wizard__panel--editor">
                        <div class="bn-interim-award-wizard__panel-title">Interim order draft</div>
                        <div class="bn-interim-award-wizard__toolbar">
                            <button string="Reload from template" type="object" name="action_reload_template"
                                    class="btn-secondary" icon="fa-refresh"/>
                            <button string="Preview PDF" type="object" name="action_preview_pdf"
                                    class="btn-secondary" icon="fa-eye"/>
                            <button string="Download draft PDF" type="object" name="action_download_draft_pdf"
                                    class="btn-secondary" icon="fa-download"/>
                        </div>
                        <field name="draft_body_html" nolabel="1" class="bn-interim-award-wizard__editor"
                               placeholder="Select an interim order type to load the draft template, then edit the order text here."/>
                        <div class="bn-interim-award-wizard__preview" invisible="not draft_pdf">
                            <div class="bn-interim-award-wizard__panel-title">PDF preview</div>
                            <field name="draft_pdf" filename="draft_pdf_filename" widget="pdf_viewer" nolabel="1"/>
                        </div>
                        <div class="bn-interim-award-wizard__upload">
                            <div class="bn-interim-award-wizard__panel-title">Signed copy (optional)</div>
                            <field name="signed_order_pdf" filename="signed_order_pdf_filename"/>
                            <field name="signed_order_pdf_filename" invisible="1"/>
                            <p class="bn-interim-award-wizard__hint">
                                Preview and download the draft, sign it offline, then upload the executed PDF before recording.
                                If no signed copy is uploaded, the generated draft PDF is saved on the case.
                            </p>
                        </div>
                    </div>
                </div>

                <footer class="bn-interim-award-wizard__footer">
                    <button string="Record final award" type="object" name="action_confirm"
                            class="btn-primary" invisible="not is_final_award"/>
                    <button string="Record interim &amp; stay in Hearing" type="object" name="action_confirm"
                            class="btn-primary" invisible="is_final_award"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
