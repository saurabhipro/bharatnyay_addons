<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bharat_loan_hearing_schedule_wizard_form" model="ir.ui.view">
        <field name="name">bharat.loan.hearing.schedule.wizard.form</field>
        <field name="model">bharat.loan.hearing.schedule.wizard</field>
        <field name="arch" type="xml">
            <form string="Schedule Hearing" class="bn-hearing-wizard">
                <field name="hearing_reschedule" invisible="1"/>
                <field name="grid_selected_date" invisible="1"/>
                <field name="calendar_week_start" invisible="1"/>
                <field name="scheduler_week_start" invisible="1"/>
                <field name="slot_board_json" invisible="1"/>
                <field name="week_board_json" invisible="1"/>
                <field name="selected_slot_range_display" invisible="1"/>
                <field name="invite_user_ids" invisible="1"/>
                <field name="external_attendee_partner_ids" invisible="1"/>

                <div class="bn-hearing-wizard__panel bn-hearing-wizard__panel--top">
                    <div class="bn-hearing-wizard__topbar">
                        <div class="bn-hearing-wizard__topbar-block bn-hearing-wizard__topbar-block--case">
                            <span class="bn-hearing-wizard__kicker">Case</span>
                            <field name="loan_id" readonly="1" nolabel="1" class="bn-hearing-wizard__case-name"/>
                        </div>

                        <div class="bn-hearing-wizard__topbar-divider" invisible="use_manual_time"/>

                        <div class="bn-hearing-wizard__topbar-block bn-hearing-wizard__topbar-block--selection"
                             invisible="use_manual_time">
                            <span class="bn-hearing-wizard__kicker">Selected</span>
                            <field name="scheduler_selection_label"
                                   readonly="1"
                                   nolabel="1"
                                   class="bn-hearing-wizard__selection-pill"/>
                        </div>

                        <div class="bn-hearing-wizard__topbar-divider" invisible="use_manual_time"/>

                        <div class="bn-hearing-wizard__topbar-block bn-hearing-wizard__topbar-block--controls">
                            <field name="scheduler_view_mode"
                                   widget="radio"
                                   options="{'horizontal': true}"
                                   invisible="use_manual_time"
                                   nolabel="1"/>
                            <field name="scheduler_date"
                                   invisible="use_manual_time"
                                   nolabel="1"
                                   placeholder="Day"/>
                            <field name="use_manual_time" nolabel="1"/>
                            <field name="hearing_datetime"
                                   invisible="not use_manual_time"
                                   nolabel="1"/>
                        </div>
                    </div>
                </div>

                <div class="bn-hearing-wizard__panel bn-hearing-wizard__panel--calendar" invisible="use_manual_time">
                    <div class="bn-hearing-wizard__panel-title">Pick a slot · Mon–Fri · 09:00–17:00 · 30 min</div>
                    <field name="grid_selected_index"
                           widget="bn_hearing_scheduler"
                           nolabel="1"/>
                </div>

                <div class="bn-hearing-wizard__panel bn-hearing-wizard__panel--attendees">
                    <div class="bn-hearing-wizard__teams-header">
                        <i class="fa fa-video-camera" title="Video hearing"/>
                        <span>Invite people to the video hearing</span>
                    </div>
                    <field name="external_attendee_emails"
                           nolabel="1"
                           placeholder="name@company.com, counsel@firm.com"
                           class="bn-hearing-wizard__email-input"/>
                    <div class="bn-hearing-wizard__hint">Separate multiple emails with commas or new lines. Calendar invites are sent automatically.</div>
                </div>

                <div class="bn-hearing-wizard__panel bn-hearing-wizard__panel--outcome" invisible="hearing_reschedule">
                    <field name="was_user_present"/>
                    <field name="is_final_award"/>
                </div>

                <footer class="bn-hearing-wizard__footer">
                    <button string="Schedule &amp; Move to Final Award" type="object" name="action_schedule"
                            class="btn-primary" invisible="hearing_reschedule or not is_final_award"/>
                    <button string="Schedule &amp; Move to Hearing" type="object" name="action_schedule"
                            class="btn-primary" invisible="hearing_reschedule or is_final_award"/>
                    <button string="Save new time" type="object" name="action_schedule"
                            class="btn-primary" invisible="not hearing_reschedule"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_bharat_loan_interim_award_wizard_form" model="ir.ui.view">
        <field name="name">bharat.loan.interim.award.wizard.form</field>
        <field name="model">bharat.loan.interim.award.wizard</field>
        <field name="arch" type="xml">
            <form string="Pass Interim Award">
                <group>
                    <field name="loan_id"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="order_type"/>
                    <field name="purpose"/>
                    <field name="typical_loan_type"/>
                    <field name="passed_by"/>
                    <field name="common_directions"/>
                    <field name="interim_award_amount"/>
                    <field name="interim_award_notes"
                           placeholder="Additional procedural directions, deposit orders, timelines, …"/>
                    <field name="was_user_present"/>
                    <field name="is_final_award"/>
                </group>
                <footer>
                    <button string="Record final award" type="object" name="action_confirm"
                            class="btn-primary" invisible="not is_final_award"/>
                    <button string="Record interim &amp; stay in Hearing" type="object" name="action_confirm"
                            class="btn-primary" invisible="is_final_award"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
