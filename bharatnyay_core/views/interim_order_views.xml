<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bharat_loan_interim_order_search" model="ir.ui.view">
        <field name="name">bharat.loan.interim.order.search</field>
        <field name="model">bharat.loan.interim.order</field>
        <field name="arch" type="xml">
            <search string="Interim orders">
                <field name="loan_id"/>
                <field name="order_type"/>
                <field name="purpose"/>
                <field name="passed_by"/>
                <separator/>
                <filter string="This month" name="this_month" date="order_date"/>
            </search>
        </field>
    </record>

    <record id="view_bharat_loan_interim_order_list" model="ir.ui.view">
        <field name="name">bharat.loan.interim.order.list</field>
        <field name="model">bharat.loan.interim.order</field>
        <field name="arch" type="xml">
            <list string="Interim orders" default_order="order_date desc">
                <field name="order_date"/>
                <field name="order_type"/>
                <field name="purpose"/>
                <field name="passed_by"/>
                <field name="amount"/>
                <field name="loan_id" optional="hide"/>
                <field name="typical_loan_type" optional="hide"/>
                <field name="created_by_id" optional="hide"/>
                <field name="common_directions" optional="hide"/>
                <field name="notes" optional="hide"/>
                <field name="order_pdf_filename" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_bharat_loan_interim_order_form" model="ir.ui.view">
        <field name="name">bharat.loan.interim.order.form</field>
        <field name="model">bharat.loan.interim.order</field>
        <field name="arch" type="xml">
            <form string="Interim order" class="bn-interim-order-form">
                <sheet>
                    <div class="bn-interim-order-form__meta">
                        <group>
                            <group>
                                <field name="loan_id"/>
                                <field name="order_date"/>
                                <field name="order_type"/>
                                <field name="purpose"/>
                                <field name="typical_loan_type"/>
                                <field name="passed_by"/>
                            </group>
                            <group>
                                <field name="hearing_line_id"/>
                                <field name="amount"/>
                                <field name="created_by_id" readonly="1"/>
                                <field name="signed_on" readonly="1"/>
                                <field name="is_signed" readonly="1"/>
                                <field name="common_directions"/>
                                <field name="notes"/>
                            </group>
                        </group>
                    </div>
                    <div class="bn-interim-order-form__draft" invisible="not draft_body_html">
                        <separator string="Draft order body"/>
                        <field name="draft_body_html" widget="html" readonly="1" nolabel="1"/>
                    </div>
                    <div class="bn-interim-order-form__pdf" invisible="not order_pdf">
                        <div class="bn-interim-order-form__pdf-label">
                            <i class="fa fa-file-pdf-o" title="Interim order PDF"/>
                            <span>Interim order PDF</span>
                        </div>
                        <field name="order_pdf" filename="order_pdf_filename" widget="pdf_viewer" nolabel="1"/>
                        <field name="order_pdf_filename" invisible="1"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
