<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bharat_loan_notice_response_wizard_form" model="ir.ui.view">
        <field name="name">bharat.loan.notice.response.wizard.form</field>
        <field name="model">bharat.loan.notice.response.wizard</field>
        <field name="arch" type="xml">
            <form string="Record respondent reply">
                <group string="Notice">
                    <field name="notice_line_id" invisible="1"/>
                    <field name="loan_display"/>
                    <field name="notice_label_display"/>
                    <field name="subject_display"/>
                </group>
                <group string="Respondent reply">
                    <field name="response_pdf" filename="response_pdf_filename"/>
                    <field name="response_pdf_filename" invisible="1"/>
                    <field name="response_received_on" required="True"/>
                    <field name="response_notes" placeholder="Brief notes about the respondent's reply"/>
                </group>
                <footer>
                    <button string="Save" type="object" name="action_save" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
