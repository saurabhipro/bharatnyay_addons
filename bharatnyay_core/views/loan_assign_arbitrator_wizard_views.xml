<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bharat_loan_assign_arbitrator_wizard_form" model="ir.ui.view">
        <field name="name">bharat.loan.assign.arbitrator.wizard.form</field>
        <field name="model">bharat.loan.assign.arbitrator.wizard</field>
        <field name="arch" type="xml">
            <form string="Assign Arbitrator">
                <group>
                    <field name="loan_id"/>
                    <field name="user_id"
                           domain="[('bharat_role', '=', 'arbitrator')]"
                           options="{'no_create': True}"/>
                </group>
                <footer>
                    <button string="Submit" type="object" name="action_submit" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
