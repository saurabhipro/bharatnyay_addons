<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Regions -->
    <record id="view_bharat_region_search" model="ir.ui.view">
        <field name="name">bharat.region.search</field>
        <field name="model">bharat.region</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
    <record id="view_bharat_region_tree" model="ir.ui.view">
        <field name="name">bharat.region.list</field>
        <field name="model">bharat.region</field>
        <field name="arch" type="xml">
            <list string="Regions" editable="bottom">
                <field name="name"/>
                <field name="code" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_bharat_region_form" model="ir.ui.view">
        <field name="name">bharat.region.form</field>
        <field name="model">bharat.region</field>
        <field name="arch" type="xml">
            <form string="Region">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_bharat_region" model="ir.actions.act_window">
        <field name="name">Regions</field>
        <field name="res_model">bharat.region</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bharat_region_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Define regions used on loans (same set as your sheet).</p>
        </field>
    </record>

    <!-- Indian states (res.country.state) -->
    <record id="view_bharat_country_state_search" model="ir.ui.view">
        <field name="name">res.country.state.search.bharatnyay</field>
        <field name="model">res.country.state</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="region_id"/>
                <field name="country_id"/>
            </search>
        </field>
    </record>
    <record id="view_bharat_country_state_tree" model="ir.ui.view">
        <field name="name">res.country.state.list.bharatnyay</field>
        <field name="model">res.country.state</field>
        <field name="arch" type="xml">
            <list string="States">
                <field name="name"/>
                <field name="region_id" required="1" options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
                <field name="code" optional="show"/>
                <field name="country_id" optional="hide"/>
            </list>
        </field>
    </record>
    <record id="view_bharat_country_state_form" model="ir.ui.view">
        <field name="name">res.country.state.form.bharatnyay</field>
        <field name="model">res.country.state</field>
        <field name="arch" type="xml">
            <form string="State">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="country_id" readonly="1" options="{'no_create': True}"/>
                        <field name="region_id" required="1" options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_bharat_country_state" model="ir.actions.act_window">
        <field name="name">States</field>
        <field name="res_model">res.country.state</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_bharat_country_state_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_bharat_country_state_form')}),
        ]"/>
        <field name="search_view_id" ref="view_bharat_country_state_search"/>
        <field name="domain" eval="[('country_id', '=', ref('base.in'))]"/>
        <field name="context" eval="{'default_country_id': ref('base.in')}"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Indian states and union territories for loan geography.</p>
        </field>
    </record>

    <!-- Locations (Region → State → Location) -->
    <record id="view_bharat_loan_location_search" model="ir.ui.view">
        <field name="name">bharat.loan_location.search</field>
        <field name="model">bharat.loan_location</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="region_id"/>
                <field name="state_id"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
    <record id="view_bharat_loan_location_tree" model="ir.ui.view">
        <field name="name">bharat.loan_location.list</field>
        <field name="model">bharat.loan_location</field>
        <field name="arch" type="xml">
            <list string="Locations">
                <field name="region_id" optional="show"/>
                <field name="state_id" optional="show"/>
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_bharat_loan_location_form" model="ir.ui.view">
        <field name="name">bharat.loan_location.form</field>
        <field name="model">bharat.loan_location</field>
        <field name="arch" type="xml">
            <form string="Location">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Location name"/></h1>
                    </div>
                    <group string="Geography">
                        <group>
                            <field name="region_id" required="1" options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
                            <field name="state_id" required="1"
                                   options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                                   domain="[('country_id.code', '=', 'IN'), ('region_id', '!=', False), ('region_id', '=', region_id)]"/>
                        </group>
                        <group>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_bharat_loan_location" model="ir.actions.act_window">
        <field name="name">Locations</field>
        <field name="res_model">bharat.loan_location</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_bharat_loan_location_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_bharat_loan_location_form')}),
        ]"/>
        <field name="search_view_id" ref="view_bharat_loan_location_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">City or office locations under a state (e.g. CHANDIGARH).</p>
        </field>
    </record>

    <!-- Branches (Region → State → Location → Branch) -->
    <record id="view_bharat_branch_search" model="ir.ui.view">
        <field name="name">bharat.branch.search</field>
        <field name="model">bharat.branch</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="region_id"/>
                <field name="borrower_state_id"/>
                <field name="location_id"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
    <record id="view_bharat_branch_tree" model="ir.ui.view">
        <field name="name">bharat.branch.list</field>
        <field name="model">bharat.branch</field>
        <field name="arch" type="xml">
            <list string="Branches">
                <field name="region_id" optional="show"/>
                <field name="borrower_state_id" optional="show"/>
                <field name="location_id" optional="show"/>
                <field name="name"/>
                <field name="code" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_bharat_branch_form" model="ir.ui.view">
        <field name="name">bharat.branch.form</field>
        <field name="model">bharat.branch</field>
        <field name="arch" type="xml">
            <form string="Branch">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Branch name"/></h1>
                    </div>
                    <group string="Geography">
                        <group>
                            <field name="region_id" required="1" options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
                            <field name="borrower_state_id" string="State" required="1"
                                   options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                                   domain="[('country_id.code', '=', 'IN'), ('region_id', '!=', False), ('region_id', '=', region_id)]"/>
                            <field name="location_id" required="1"
                                   options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                                   domain="[('region_id', '=', region_id), ('state_id', '=', borrower_state_id)]"/>
                        </group>
                        <group>
                            <field name="code"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_bharat_branch" model="ir.actions.act_window">
        <field name="name">Branches</field>
        <field name="res_model">bharat.branch</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_bharat_branch_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_bharat_branch_form')}),
        ]"/>
        <field name="search_view_id" ref="view_bharat_branch_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Branches under a location (e.g. CHANDIGARH-SECTOR40).</p>
        </field>
    </record>

    <!-- Product class -->
    <record id="view_bharat_product_class_search" model="ir.ui.view">
        <field name="name">bharat.product_class.search</field>
        <field name="model">bharat.product_class</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
    <record id="view_bharat_product_class_tree" model="ir.ui.view">
        <field name="name">bharat.product_class.list</field>
        <field name="model">bharat.product_class</field>
        <field name="arch" type="xml">
            <list string="Product classes" editable="bottom">
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_bharat_product_class_form" model="ir.ui.view">
        <field name="name">bharat.product_class.form</field>
        <field name="model">bharat.product_class</field>
        <field name="arch" type="xml">
            <form string="Product class">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_bharat_product_class" model="ir.actions.act_window">
        <field name="name">Product classes</field>
        <field name="res_model">bharat.product_class</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bharat_product_class_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Examples: SELF EMP, SALARIED…</p>
        </field>
    </record>

    <!-- Write-off -->
    <record id="view_bharat_writeoff_search" model="ir.ui.view">
        <field name="name">bharat.writeoff.search</field>
        <field name="model">bharat.writeoff</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
    <record id="view_bharat_writeoff_tree" model="ir.ui.view">
        <field name="name">bharat.writeoff.list</field>
        <field name="model">bharat.writeoff</field>
        <field name="arch" type="xml">
            <list string="Write-offs" editable="bottom">
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_bharat_writeoff_form" model="ir.ui.view">
        <field name="name">bharat.writeoff.form</field>
        <field name="model">bharat.writeoff</field>
        <field name="arch" type="xml">
            <form string="Write-off">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_bharat_writeoff" model="ir.actions.act_window">
        <field name="name">Write-offs</field>
        <field name="res_model">bharat.writeoff</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bharat_writeoff_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Write-off buckets as on the sheet (e.g. WRITEOFF).</p>
        </field>
    </record>

    <!-- Law firms -->
    <record id="view_bharat_law_firm_search" model="ir.ui.view">
        <field name="name">bharat.law_firm.search</field>
        <field name="model">bharat.law_firm</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="phone"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
    <record id="view_bharat_law_firm_tree" model="ir.ui.view">
        <field name="name">bharat.law_firm.list</field>
        <field name="model">bharat.law_firm</field>
        <field name="arch" type="xml">
            <list string="Law firms" editable="bottom">
                <field name="name"/>
                <field name="phone" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_bharat_law_firm_form" model="ir.ui.view">
        <field name="name">bharat.law_firm.form</field>
        <field name="model">bharat.law_firm</field>
        <field name="arch" type="xml">
            <form string="Law firm">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <field name="name"/>
                        <field name="phone" widget="phone"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_bharat_law_firm" model="ir.actions.act_window">
        <field name="name">Law firms</field>
        <field name="res_model">bharat.law_firm</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bharat_law_firm_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Panels or counsels instructed on Lok Adalat rows.</p>
        </field>
    </record>

    <!-- Loan stages (master) -->
    <record id="view_bharat_loan_stage_search" model="ir.ui.view">
        <field name="name">bharat.loan.stage.search</field>
        <field name="model">bharat.loan.stage</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
    <record id="view_bharat_loan_stage_tree" model="ir.ui.view">
        <field name="name">bharat.loan.stage.list</field>
        <field name="model">bharat.loan.stage</field>
        <field name="arch" type="xml">
            <list string="Loan stages" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="section" optional="show"/>
                <field name="phase" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_bharat_loan_stage_form" model="ir.ui.view">
        <field name="name">bharat.loan.stage.form</field>
        <field name="model">bharat.loan.stage</field>
        <field name="arch" type="xml">
            <form string="Loan stage">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="section"/>
                        <field name="phase"/>
                        <field name="active"/>
                        <field name="fold"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_bharat_loan_stage" model="ir.actions.act_window">
        <field name="name">Loan stages</field>
        <field name="res_model">bharat.loan.stage</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bharat_loan_stage_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Define loan workflow stages once, then assign them to each company.</p>
        </field>
    </record>

    <!-- Workflow milestones (Move to next stage pipeline) -->
    <record id="view_bharat_loan_milestone_search" model="ir.ui.view">
        <field name="name">bharat.loan.milestone.search</field>
        <field name="model">bharat.loan.milestone</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
    <record id="view_bharat_loan_milestone_tree" model="ir.ui.view">
        <field name="name">bharat.loan.milestone.list</field>
        <field name="model">bharat.loan.milestone</field>
        <field name="arch" type="xml">
            <list string="Workflow milestones" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="section" optional="show"/>
                <field name="phase" optional="show"/>
                <field name="auto_invoice_on_exit" widget="boolean_toggle"/>
                <field name="auto_assign_case_manager" widget="boolean_toggle" optional="show"/>
                <field name="auto_assign_arbitrator" widget="boolean_toggle" optional="show"/>
                <field name="is_arbitrator" widget="boolean_toggle" optional="hide"/>
                <field name="locks_case" widget="boolean_toggle" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_bharat_loan_milestone_form" model="ir.ui.view">
        <field name="name">bharat.loan.milestone.form</field>
        <field name="model">bharat.loan.milestone</field>
        <field name="arch" type="xml">
            <form string="Workflow milestone">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="section"/>
                            <field name="phase"/>
                            <field name="fold"/>
                            <field name="is_arbitrator"/>
                            <field name="locks_case"/>
                            <field name="active"/>
                        </group>
                        <group string="Automation on entry / exit">
                            <field name="auto_invoice_on_exit"/>
                            <field name="auto_assign_case_manager"/>
                            <field name="auto_assign_arbitrator"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_bharat_loan_milestone" model="ir.actions.act_window">
        <field name="name">Workflow milestones</field>
        <field name="res_model">bharat.loan.milestone</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bharat_loan_milestone_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure the “Move to next stage” pipeline: invoice on exit, auto-assign case manager / arbitrator on entry.
            </p>
        </field>
    </record>
</odoo>
