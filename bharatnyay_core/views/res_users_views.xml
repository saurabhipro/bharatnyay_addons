<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bharat_res_users_role_search" model="ir.ui.view">
        <field name="name">res.users.bharatnyay.role.search</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="email"/>
                <field name="bharat_role"/>
                <filter string="Has role" name="has_role" domain="[('bharat_role', '!=', False)]"/>
                <filter string="Admins" name="role_admin" domain="[('bharat_role', '=', 'admin')]"/>
                <filter string="Case managers" name="role_cm" domain="[('bharat_role', '=', 'case_manager')]"/>
                <filter string="Arbitrators" name="role_arb" domain="[('bharat_role', '=', 'arbitrator')]"/>
                <filter string="Borrowers" name="role_borrower" domain="[('bharat_role', '=', 'borrower')]"/>
                <filter string="Lenders" name="role_lender" domain="[('bharat_role', '=', 'lender')]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Role" name="grp_role" context="{'group_by': 'bharat_role'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_bharat_res_users_role_list" model="ir.ui.view">
        <field name="name">res.users.bharatnyay.role.list</field>
        <field name="model">res.users</field>
        <field name="priority">32</field>
        <field name="arch" type="xml">
            <list string="User roles">
                <field name="name"/>
                <field name="email"/>
                <field name="bharat_role" string="Role"/>
                <field name="company_id" string="Lender" optional="show"/>
                <field name="bharat_branch_ids" widget="many2many_tags" optional="show"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_bharat_res_users_role_form" model="ir.ui.view">
        <field name="name">res.users.bharatnyay.role.form</field>
        <field name="model">res.users</field>
        <field name="priority">32</field>
        <field name="arch" type="xml">
            <form string="User role">
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar"
                           options="{'zoom': true, 'preview_image': 'avatar_128'}"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_bharat_loans" type="object"
                                class="oe_stat_button" icon="fa-briefcase"
                                invisible="not bharat_role">
                            <field name="bharat_loan_count" widget="statinfo" string="Cases"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group string="User">
                            <field name="name"/>
                            <field name="email" widget="email"/>
                            <field name="login" readonly="id"/>
                        </group>
                        <group string="Role">
                            <field name="bharat_role" string="Operational role"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <group string="Lender scope" invisible="bharat_role != 'lender'">
                        <field name="company_id" string="Lender / company" options="{'no_create': True}"/>
                        <field name="company_ids" string="Allowed lenders" widget="many2many_tags" options="{'no_create': True}"/>
                    </group>
                    <group string="Location scope" invisible="bharat_role == 'lender'">
                        <field name="bharat_region_id" options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
                        <field name="bharat_borrower_state_id" string="State"
                               options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                               domain="[('country_id.code', '=', 'IN'), ('region_id', '!=', False), ('region_id', '=', bharat_region_id)]"/>
                        <field name="bharat_location_ids" string="Locations"
                               widget="many2many_tags"
                               options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                               domain="[('region_id', '=', bharat_region_id), ('state_id', '=', bharat_borrower_state_id)]"/>
                        <field name="bharat_branch_ids" string="Branches"
                               widget="many2many_tags"
                               options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                               domain="[('region_id', '=', bharat_region_id), ('borrower_state_id', '=', bharat_borrower_state_id)]"/>
                    </group>
                    <group>
                        <field name="bharat_role_note" placeholder="Optional notes (scope, escalation, panel details)…"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_bharat_user_role_assignment" model="ir.actions.act_window">
        <field name="name">User roles</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('share', '=', False)]</field>
        <field name="context">{'default_share': False}</field>
        <field name="search_view_id" ref="view_bharat_res_users_role_search"/>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_bharat_res_users_role_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_bharat_res_users_role_form')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Assign operational roles by geography and location.</p>
            <p>Map internal users as Admin, Case Manager, Arbitrator, Borrower, or Lender. The matching access group is applied automatically.</p>
        </field>
    </record>
</odoo>
