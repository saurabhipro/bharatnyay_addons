<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bharat_loan_billing_event_tree" model="ir.ui.view">
        <field name="name">bharat.loan.billing.event.tree</field>
        <field name="model">bharat.loan.billing.event</field>
        <field name="arch" type="xml">
            <list string="Billing charges" create="0" delete="0">
                <field name="accrual_date"/>
                <field name="batch_number"/>
                <field name="loan_number"/>
                <field name="case_number"/>
                <field name="customer_name"/>
                <field name="milestone_label"/>
                <field name="unit_price"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'pending'"
                       decoration-success="state == 'invoiced'"/>
                <field name="move_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_bharat_loan_billing_event_search" model="ir.ui.view">
        <field name="name">bharat.loan.billing.event.search</field>
        <field name="model">bharat.loan.billing.event</field>
        <field name="arch" type="xml">
            <search string="Billing charges">
                <field name="batch_number"/>
                <field name="loan_number"/>
                <field name="case_number"/>
                <field name="milestone_code"/>
                <filter string="Pending invoice" name="pending" domain="[('state', '=', 'pending')]"/>
                <filter string="Invoiced" name="invoiced" domain="[('state', '=', 'invoiced')]"/>
                <group expand="0" string="Group by">
                    <filter string="Batch" name="grp_batch" context="{'group_by': 'batch_number'}"/>
                    <filter string="Milestone" name="grp_milestone" context="{'group_by': 'milestone_label'}"/>
                    <filter string="Status" name="grp_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_bharat_loan_billing_event_pending" model="ir.actions.act_window">
        <field name="name">Pending billing charges</field>
        <field name="res_model">bharat.loan.billing.event</field>
        <field name="view_mode">list</field>
        <field name="domain">[('state', '=', 'pending')]</field>
        <field name="context">{'search_default_grp_batch': 1, 'search_default_grp_milestone': 1}</field>
    </record>

    <record id="action_bharat_consolidated_billing_wizard" model="ir.actions.act_window">
        <field name="name">Bill batch (consolidated)</field>
        <field name="res_model">bharat.arbitration.invoice.line.loader.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_bharat_arbitration_invoice_annexure_line_tree" model="ir.ui.view">
        <field name="name">bharat.arbitration.invoice.annexure.line.tree</field>
        <field name="model">bharat.arbitration.invoice.annexure.line</field>
        <field name="arch" type="xml">
            <list string="Annexure" create="0" delete="0" edit="0">
                <field name="sequence" widget="handle"/>
                <field name="loan_number"/>
                <field name="case_number"/>
                <field name="customer_name"/>
                <field name="milestone_label"/>
                <field name="unit_price"/>
                <field name="quantity"/>
                <field name="amount"/>
            </list>
        </field>
    </record>
</odoo>
