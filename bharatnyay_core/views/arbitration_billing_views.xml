<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Post office status master -->
    <record id="view_bharat_post_office_status_search" model="ir.ui.view">
        <field name="name">bharat.post.office.status.search</field>
        <field name="model">bharat.post.office.status</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter string="Accrues billing" name="billing" domain="[('triggers_billing', '=', True)]"/>
                <filter string="Locks case" name="lock" domain="[('locks_case', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
    <record id="view_bharat_post_office_status_tree" model="ir.ui.view">
        <field name="name">bharat.post.office.status.list</field>
        <field name="model">bharat.post.office.status</field>
        <field name="arch" type="xml">
            <list string="Post office statuses" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="is_delivered"/>
                <field name="triggers_billing"/>
                <field name="locks_case"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_bharat_post_office_status_form" model="ir.ui.view">
        <field name="name">bharat.post.office.status.form</field>
        <field name="model">bharat.post.office.status</field>
        <field name="arch" type="xml">
            <form string="Post office status">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Status name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group string="Automation">
                            <field name="is_delivered"/>
                            <field name="triggers_billing"/>
                            <field name="locks_case"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_bharat_post_office_status" model="ir.actions.act_window">
        <field name="name">Post office status</field>
        <field name="res_model">bharat.post.office.status</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure POD / delivery statuses and when they accrue unbilled charges or lock cases.
            </p>
        </field>
    </record>

    <!-- Postal dispatch on case -->
    <record id="view_bharat_loan_postal_dispatch_tree" model="ir.ui.view">
        <field name="name">bharat.loan.postal.dispatch.list</field>
        <field name="model">bharat.loan.postal.dispatch</field>
        <field name="arch" type="xml">
            <list create="0" delete="0">
                <field name="loan_number"/>
                <field name="document_label"/>
                <field name="pod"/>
                <field name="dispatch_date"/>
                <field name="delivery_date"/>
                <field name="post_office_status_id"/>
                <field name="billing_milestone_code" optional="hide"/>
                <field name="billing_accrued"/>
                <field name="loan_id" optional="hide"/>
            </list>
        </field>
    </record>
    <record id="view_bharat_loan_postal_dispatch_search" model="ir.ui.view">
        <field name="name">bharat.loan.postal.dispatch.search</field>
        <field name="model">bharat.loan.postal.dispatch</field>
        <field name="arch" type="xml">
            <search>
                <field name="loan_number"/>
                <field name="pod"/>
                <field name="document_type"/>
                <field name="post_office_status_id"/>
                <filter string="Notice 1" name="notice_1" domain="[('document_type', '=', 'notice_1')]"/>
                <filter string="Interim order 1" name="interim_1" domain="[('document_type', '=', 'interim_order_1')]"/>
                <filter string="Awaiting billable status" name="pending_status"
                        domain="[('billing_accrued', '=', False), '|', ('post_office_status_id', '=', False), ('post_office_status_id.triggers_billing', '=', False)]"/>
            </search>
        </field>
    </record>
    <record id="action_bharat_loan_postal_dispatch" model="ir.actions.act_window">
        <field name="name">Postal dispatches</field>
        <field name="res_model">bharat.loan.postal.dispatch</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bharat_loan_postal_dispatch_search"/>
    </record>

    <!-- Unbilled bills + billing events -->
    <record id="view_bharat_loan_billing_event_search" model="ir.ui.view">
        <field name="name">bharat.loan.billing.event.search</field>
        <field name="model">bharat.loan.billing.event</field>
        <field name="arch" type="xml">
            <search>
                <field name="loan_number"/>
                <field name="case_number"/>
                <field name="customer_name"/>
                <field name="batch_number"/>
                <field name="milestone_code"/>
                <filter string="Pending invoice" name="pending" domain="[('state', '=', 'pending')]"/>
                <filter string="Invoiced" name="invoiced" domain="[('state', '=', 'invoiced')]"/>
                <filter string="Postal delivery" name="delivery" domain="[('accrual_trigger', '=', 'delivery')]"/>
                <filter string="Milestone exit" name="milestone" domain="[('accrual_trigger', '=', 'milestone_exit')]"/>
                <group expand="0" string="Group By">
                    <filter string="Batch" name="grp_batch" context="{'group_by': 'batch_number'}"/>
                    <filter string="Milestone" name="grp_milestone" context="{'group_by': 'milestone_label'}"/>
                    <filter string="Status" name="grp_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="view_bharat_loan_billing_event_tree" model="ir.ui.view">
        <field name="name">bharat.loan.billing.event.list</field>
        <field name="model">bharat.loan.billing.event</field>
        <field name="arch" type="xml">
            <list create="0" delete="0">
                <field name="accrual_date"/>
                <field name="loan_number"/>
                <field name="case_number" optional="show"/>
                <field name="customer_name" optional="hide"/>
                <field name="batch_number"/>
                <field name="milestone_label"/>
                <field name="accrual_trigger" optional="show"/>
                <field name="unit_price" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'pending'"
                       decoration-success="state == 'invoiced'"
                       decoration-muted="state == 'cancelled'"/>
                <field name="move_id" optional="show"/>
            </list>
        </field>
    </record>
    <record id="view_bharat_loan_billing_event_form" model="ir.ui.view">
        <field name="name">bharat.loan.billing.event.form</field>
        <field name="model">bharat.loan.billing.event</field>
        <field name="arch" type="xml">
            <form string="Billing charge" create="0" delete="0">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="pending,invoiced"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="loan_id" readonly="1"/>
                            <field name="batch_number" readonly="1"/>
                            <field name="milestone_label" readonly="1"/>
                            <field name="milestone_code" readonly="1"/>
                            <field name="accrual_trigger" readonly="1"/>
                        </group>
                        <group>
                            <field name="accrual_date" readonly="1"/>
                            <field name="product_id" readonly="1"/>
                            <field name="unit_price" readonly="1"/>
                            <field name="postal_dispatch_id" readonly="1"/>
                            <field name="move_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_bharat_loan_billing_event_pending" model="ir.actions.act_window">
        <field name="name">Unbilled bills</field>
        <field name="res_model">bharat.loan.billing.event</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'pending')]</field>
        <field name="context">{'search_default_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Pending arbitration charges waiting for consolidated batch invoicing.
            </p>
            <p>Charges accrue when a case exits a workflow milestone, or when a postal dispatch
            reaches a status marked “Accrue unbilled charge” in Post office status master.</p>
        </field>
    </record>
    <record id="action_bharat_loan_billing_event_all" model="ir.actions.act_window">
        <field name="name">All billing charges</field>
        <field name="res_model">bharat.loan.billing.event</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_bharat_arbitration_invoices" model="ir.actions.act_window">
        <field name="name">Invoices</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('move_type', '=', 'out_invoice'),
            ('bharat_arbitration_invoice', '=', True),
        ]</field>
        <field name="context">{'default_move_type': 'out_invoice', 'default_bharat_arbitration_invoice': True}</field>
    </record>
</odoo>
