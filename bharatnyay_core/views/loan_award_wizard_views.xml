<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bharat_loan_award_upload_wizard_form" model="ir.ui.view">
        <field name="name">bharat.loan.award.upload.wizard.form</field>
        <field name="model">bharat.loan.award.upload.wizard</field>
        <field name="arch" type="xml">
            <form string="Upload signed award">
                <group string="Case">
                    <field name="loan_id" invisible="1"/>
                    <field name="award_document_id" invisible="1"/>
                    <field name="case_display"/>
                    <field name="loan_display"/>
                </group>
                <group string="Signed award letter">
                    <field name="signed_award_pdf" filename="signed_award_pdf_filename"/>
                    <field name="signed_award_pdf_filename" invisible="1"/>
                    <field name="signed_on"/>
                    <field name="award_notes" placeholder="Optional notes about the signed award"/>
                </group>
                <footer>
                    <button string="Save" type="object" name="action_save" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
