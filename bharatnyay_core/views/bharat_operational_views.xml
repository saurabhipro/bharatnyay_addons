<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bharat_arbitrator_blockout_tree" model="ir.ui.view">
        <field name="name">bharat.arbitrator.blockout.list</field>
        <field name="model">bharat.arbitrator.blockout</field>
        <field name="arch" type="xml">
            <list string="Arbitrator block-outs">
                <field name="user_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="view_bharat_arbitrator_blockout_form" model="ir.ui.view">
        <field name="name">bharat.arbitrator.blockout.form</field>
        <field name="model">bharat.arbitrator.blockout</field>
        <field name="arch" type="xml">
            <form string="Block-out">
                <sheet>
                    <group>
                        <field name="user_id"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_bharat_arbitrator_blockout" model="ir.actions.act_window">
        <field name="name">Arbitrator calendar block-outs</field>
        <field name="res_model">bharat.arbitrator.blockout</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_bharat_postal_import_wizard_form" model="ir.ui.view">
        <field name="name">bharat.postal.tracking.import.wizard.form</field>
        <field name="model">bharat.postal.tracking.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Postal tracking import">
                <group>
                    <field name="dry_run"/>
                    <field name="raw_text" widget="text" placeholder="Tracking No,Dispatch Date,Delivery Status,Delivery Date&#10;ABC123,01-01-2026,Delivered,05-01-2026"/>
                </group>
                <footer>
                    <button name="action_import" string="Run import" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bharat_postal_import_wizard" model="ir.actions.act_window">
        <field name="name">Import POD status</field>
        <field name="res_model">bharat.loan.portfolio.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_import_type': 'pod_status'}</field>
    </record>

    <record id="view_bharat_loan_portfolio_import_wizard_form" model="ir.ui.view">
        <field name="name">bharat.loan.portfolio.import.wizard.form</field>
        <field name="model">bharat.loan.portfolio.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Excel" class="o_bn_import_wizard">
                <field name="import_state" invisible="1"/>
                <field name="update_existing" invisible="1"/>
                <field name="dry_run" invisible="1"/>
                <field name="filename" invisible="1"/>

                <div class="bn-import-wrap" invisible="result_html">
                    <div class="bn-import-head">
                        <div class="bn-import-head__icon">
                            <i class="fa fa-file-excel-o" title="Excel import"/>
                        </div>
                        <div>
                            <h2>Import Excel</h2>
                            <p>Choose what you are uploading, attach your .xlsx file, and click Import now.</p>
                        </div>
                    </div>

                    <div class="bn-import-step">
                        <span class="bn-import-step__num">1</span>
                        <span class="bn-import-step__label">Import type</span>
                    </div>
                    <div class="bn-import-type">
                        <field name="import_type" widget="radio" nolabel="1"/>
                    </div>

                    <div class="bn-import-step">
                        <span class="bn-import-step__num">2</span>
                        <span class="bn-import-step__label">Excel file (.xlsx)</span>
                    </div>
                    <div class="bn-import-file">
                        <field name="data_file" filename="filename" nolabel="1"/>
                    </div>

                    <div class="bn-import-help" invisible="import_type != 'portfolio'">
                        <strong>Portfolio / Lok Adalat</strong> — imports new cases and refreshes existing loan numbers.
                        <ul>
                            <li>Valid rows save immediately; failed rows are listed after import.</li>
                            <li>Requires a <strong>Loan Number</strong> column in your sheet.</li>
                            <li>Case Vault PDFs are queued automatically for new import batches.</li>
                        </ul>
                    </div>
                    <div class="bn-import-help" invisible="import_type != 'pod_status'">
                        <strong>POD status</strong> — updates Notice 1, Interim Order 1, and Award delivery tracking.
                        <ul>
                            <li>Required: <strong>Loan Number</strong>, notice/document type, POD or delivery status.</li>
                            <li>Optional: dispatch date and delivery date columns.</li>
                        </ul>
                    </div>
                </div>

                <div class="bn-import-result" invisible="not result_html">
                    <field name="result_summary" invisible="1"/>
                    <field name="result_html" nolabel="1" widget="html"/>
                    <div class="bn-import-errors" invisible="not error_log">
                        <div class="bn-import-errors__head">
                            <i class="fa fa-exclamation-circle"/>
                            <span>Failed rows</span>
                        </div>
                        <field name="error_log" nolabel="1" widget="text"/>
                    </div>
                </div>

                <footer>
                    <button name="action_import" string="Import now" type="object"
                            class="btn-primary" icon="fa-upload"
                            invisible="result_html"/>
                    <button name="action_import" string="Import again" type="object"
                            class="btn-secondary" icon="fa-refresh"
                            invisible="not result_html"/>
                    <button name="action_view_cases" string="Open Cases" type="object"
                            class="btn-secondary" icon="fa-table"
                            invisible="import_state != 'done'"/>
                    <button name="action_done" string="Done" type="object"
                            class="btn-primary"
                            invisible="not result_html"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"
                            invisible="result_html"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bharat_loan_portfolio_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Excel</field>
        <field name="res_model">bharat.loan.portfolio.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_bharat_arbitration_invoice_loader_wizard_form" model="ir.ui.view">
        <field name="name">bharat.arbitration.invoice.line.loader.wizard.form</field>
        <field name="model">bharat.arbitration.invoice.line.loader.wizard</field>
        <field name="arch" type="xml">
            <form string="Create consolidated invoice" class="bn-consolidated-invoice-wizard">
                <sheet>
                    <field name="currency_id" invisible="1"/>
                    <field name="company_ids" invisible="1"/>
                    <field name="batch_ids" invisible="1"/>
                    <field name="milestone_ids" invisible="1"/>
                    <field name="move_id" invisible="1"/>
                    <field name="scope_summary" invisible="1"/>
                    <field name="preview_hint" invisible="1"/>

                    <div class="bn-consolidated-invoice-wizard__hero">
                        <div class="bn-consolidated-invoice-wizard__hero-icon">
                            <i class="fa fa-file-text-o" title="Consolidated invoice"/>
                        </div>
                        <div class="bn-consolidated-invoice-wizard__hero-body">
                            <h1 class="bn-consolidated-invoice-wizard__title">Create consolidated invoice</h1>
                            <p class="bn-consolidated-invoice-wizard__subtitle">
                                <span class="bn-consolidated-invoice-wizard__stage"
                                      invisible="not billing_stage_label">
                                    <field name="billing_stage_label" readonly="1" nolabel="1" class="oe_inline"/>
                                </span>
                                <span class="bn-consolidated-invoice-wizard__subtitle-lead">
                                    Bill pending unbilled charges for the current dashboard scope.
                                </span>
                            </p>
                        </div>
                    </div>

                    <div class="bn-consolidated-invoice-wizard__stats">
                        <div class="bn-consolidated-invoice-wizard__stat">
                            <span class="bn-consolidated-invoice-wizard__stat-k">Pending charges</span>
                            <field name="preview_case_count" readonly="1" nolabel="1"
                                   class="bn-consolidated-invoice-wizard__stat-v"/>
                        </div>
                        <div class="bn-consolidated-invoice-wizard__stat">
                            <span class="bn-consolidated-invoice-wizard__stat-k">Estimated total</span>
                            <field name="preview_total_amount" readonly="1" nolabel="1"
                                   widget="monetary"
                                   class="bn-consolidated-invoice-wizard__stat-v"/>
                        </div>
                        <div class="bn-consolidated-invoice-wizard__stat">
                            <span class="bn-consolidated-invoice-wizard__stat-k">Lenders</span>
                            <field name="preview_lender_count" readonly="1" nolabel="1"
                                   class="bn-consolidated-invoice-wizard__stat-v"/>
                        </div>
                    </div>

                    <div class="bn-consolidated-invoice-wizard__scope"
                         invisible="not scope_detail">
                        <div class="bn-consolidated-invoice-wizard__scope-label">Selection scope</div>
                        <field name="scope_detail" readonly="1" nolabel="1"
                               class="bn-consolidated-invoice-wizard__scope-text"/>
                    </div>

                    <div class="bn-consolidated-invoice-wizard__empty"
                         invisible="preview_case_count">
                        <i class="fa fa-info-circle" title="No charges"/>
                        <span>No pending unbilled charges match this selection.</span>
                    </div>

                    <div class="bn-consolidated-invoice-wizard__info"
                         invisible="not preview_case_count">
                        <i class="fa fa-lightbulb-o" title="How it works"/>
                        <div>
                            <strong>What happens next</strong>
                            <p>
                                Bills all <b>pending</b> unbilled charges in scope. Batches and billing
                                stages are picked automatically. Creates one posted invoice per lender
                                with summary lines and a full case annexure.
                            </p>
                        </div>
                    </div>
                </sheet>
                <footer class="bn-consolidated-invoice-wizard__footer">
                    <button name="action_apply" string="Create consolidated invoice" type="object"
                            class="btn-primary"
                            invisible="not preview_case_count"
                            icon="fa-file-text-o"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bharat_consolidated_billing_wizard" model="ir.actions.act_window">
        <field name="name">Create consolidated invoice</field>
        <field name="res_model">bharat.arbitration.invoice.line.loader.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_bharat_loan_billing_test_wizard_form" model="ir.ui.view">
        <field name="name">bharat.loan.billing.test.wizard.form</field>
        <field name="model">bharat.loan.billing.test.wizard</field>
        <field name="arch" type="xml">
            <form string="Accrue unbilled charge (test)">
                <group>
                    <group>
                        <field name="batch_id" options="{'no_create': True}"/>
                        <field name="loan_ids" widget="many2many_tags"/>
                        <field name="milestone_id" options="{'no_create': True}"/>
                    </group>
                    <group>
                        <field name="preview_count" readonly="1"/>
                        <field name="preview_hint" readonly="1" nolabel="1" colspan="2"/>
                    </group>
                </group>
                <div class="alert alert-warning" role="alert">
                    <b>Testing only.</b> Queues pending unbilled charges without moving the case
                    workflow or postal delivery. Configure one billing product per stage under
                    <i>Arbitration billing products</i>.
                </div>
                <footer>
                    <button name="action_apply" string="Create unbilled charges" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bharat_loan_billing_test_wizard" model="ir.actions.act_window">
        <field name="name">Accrue unbilled charge (test)</field>
        <field name="res_model">bharat.loan.billing.test.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
