<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bharat_arbitrator_blockout_tree" model="ir.ui.view">
        <field name="name">bharat.arbitrator.blockout.list</field>
        <field name="model">bharat.arbitrator.blockout</field>
        <field name="arch" type="xml">
            <list string="Arbitrator block-outs">
                <field name="user_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="view_bharat_arbitrator_blockout_form" model="ir.ui.view">
        <field name="name">bharat.arbitrator.blockout.form</field>
        <field name="model">bharat.arbitrator.blockout</field>
        <field name="arch" type="xml">
            <form string="Block-out">
                <sheet>
                    <group>
                        <field name="user_id"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_bharat_arbitrator_blockout" model="ir.actions.act_window">
        <field name="name">Arbitrator calendar block-outs</field>
        <field name="res_model">bharat.arbitrator.blockout</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_bharat_postal_import_wizard_form" model="ir.ui.view">
        <field name="name">bharat.postal.tracking.import.wizard.form</field>
        <field name="model">bharat.postal.tracking.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Postal tracking import">
                <group>
                    <field name="dry_run"/>
                    <field name="raw_text" widget="text" placeholder="Tracking No,Dispatch Date,Delivery Status,Delivery Date&#10;ABC123,01-01-2026,Delivered,05-01-2026"/>
                </group>
                <footer>
                    <button name="action_import" string="Run import" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bharat_postal_import_wizard" model="ir.actions.act_window">
        <field name="name">Import postal tracking</field>
        <field name="res_model">bharat.postal.tracking.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_bharat_loan_portfolio_import_wizard_form" model="ir.ui.view">
        <field name="name">bharat.loan.portfolio.import.wizard.form</field>
        <field name="model">bharat.loan.portfolio.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import portfolio Excel">
                <header>
                    <field name="import_state" widget="statusbar" statusbar_visible="idle,done"/>
                </header>
                <group>
                    <field name="data_file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                    <field name="update_existing"/>
                    <field name="dry_run"/>
                </group>
                <div class="alert alert-info" role="alert" invisible="result_summary">
                    Upload your Lok Adalat / portfolio Excel (.xlsx only). Valid rows are imported immediately.
                    Wrong rows are listed below — all other rows are still saved.
                    If import fails with a memory error, open the file in Excel, delete blank rows far below your data, and save again.
                </div>
                <group string="Result" invisible="not result_summary">
                    <field name="result_summary" nolabel="1" widget="text"/>
                </group>
                <group string="Failed rows only" invisible="not error_log">
                    <field name="error_log" nolabel="1" widget="text"/>
                </group>
                <footer>
                    <button name="action_import" string="Import" type="object" class="btn-primary"/>
                    <button name="action_view_cases" string="Open Cases" type="object"
                            class="btn-secondary" invisible="import_state != 'done'"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bharat_loan_portfolio_import_wizard" model="ir.actions.act_window">
        <field name="name">Import portfolio Excel</field>
        <field name="res_model">bharat.loan.portfolio.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_bharat_arbitration_invoice_loader_wizard_form" model="ir.ui.view">
        <field name="name">bharat.arbitration.invoice.line.loader.wizard.form</field>
        <field name="model">bharat.arbitration.invoice.line.loader.wizard</field>
        <field name="arch" type="xml">
            <form string="Bill batch (consolidated)">
                <group>
                    <group>
                        <field name="batch_number" placeholder="e.g. BN-2026-001"/>
                        <field name="milestone_code"/>
                    </group>
                    <group>
                        <field name="preview_case_count" readonly="1" string="Pending cases"/>
                        <field name="preview_total_amount" readonly="1"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="move_id" placeholder="Optional — leave empty to create new invoice"/>
                    </group>
                </group>
                <field name="preview_hint" readonly="1" nolabel="1" class="text-muted"/>
                <div class="alert alert-info" role="alert">
                    Creates <b>one posted invoice</b> with a single summary line (qty = case count)
                    and a full <b>annexure</b> listing every loan, case number, borrower, and rate per action.
                    Charges accrue automatically when cases exit each milestone (Move to next stage).
                </div>
                <footer>
                    <button name="action_apply" string="Create consolidated invoice" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
