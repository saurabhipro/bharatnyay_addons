<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bharat_arbitrator_blockout_tree" model="ir.ui.view">
        <field name="name">bharat.arbitrator.blockout.list</field>
        <field name="model">bharat.arbitrator.blockout</field>
        <field name="arch" type="xml">
            <list string="Arbitrator block-outs">
                <field name="user_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="view_bharat_arbitrator_blockout_form" model="ir.ui.view">
        <field name="name">bharat.arbitrator.blockout.form</field>
        <field name="model">bharat.arbitrator.blockout</field>
        <field name="arch" type="xml">
            <form string="Block-out">
                <sheet>
                    <group>
                        <field name="user_id"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_bharat_arbitrator_blockout" model="ir.actions.act_window">
        <field name="name">Arbitrator calendar block-outs</field>
        <field name="res_model">bharat.arbitrator.blockout</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_bharat_postal_import_wizard_form" model="ir.ui.view">
        <field name="name">bharat.postal.tracking.import.wizard.form</field>
        <field name="model">bharat.postal.tracking.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Postal tracking import">
                <group>
                    <field name="dry_run"/>
                    <field name="raw_text" widget="text" placeholder="Tracking No,Dispatch Date,Delivery Status,Delivery Date&#10;ABC123,01-01-2026,Delivered,05-01-2026"/>
                </group>
                <footer>
                    <button name="action_import" string="Run import" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bharat_postal_import_wizard" model="ir.actions.act_window">
        <field name="name">Import POD status</field>
        <field name="res_model">bharat.loan.portfolio.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_import_type': 'pod_status'}</field>
    </record>

    <record id="view_bharat_loan_portfolio_import_wizard_form" model="ir.ui.view">
        <field name="name">bharat.loan.portfolio.import.wizard.form</field>
        <field name="model">bharat.loan.portfolio.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Excel" class="o_bn_import_wizard">
                <field name="import_state" invisible="1"/>
                <field name="update_existing" invisible="1"/>
                <field name="dry_run" invisible="1"/>
                <field name="filename" invisible="1"/>

                <div class="bn-import-wrap" invisible="result_summary">
                    <div class="bn-import-head">
                        <div class="bn-import-head__icon">
                            <i class="fa fa-file-excel-o" title="Excel import"/>
                        </div>
                        <div>
                            <h2>Import Excel</h2>
                            <p>Choose what you are uploading, attach your .xlsx file, and click Import now.</p>
                        </div>
                    </div>

                    <div class="bn-import-step">
                        <span class="bn-import-step__num">1</span>
                        <span class="bn-import-step__label">Import type</span>
                    </div>
                    <div class="bn-import-type">
                        <field name="import_type" widget="radio" nolabel="1" options="{'horizontal': true}"/>
                    </div>

                    <div class="bn-import-step">
                        <span class="bn-import-step__num">2</span>
                        <span class="bn-import-step__label">Excel file (.xlsx)</span>
                    </div>
                    <div class="bn-import-file">
                        <field name="data_file" filename="filename" nolabel="1"/>
                    </div>

                    <div class="bn-import-help" invisible="import_type != 'portfolio'">
                        <strong>Portfolio / Lok Adalat</strong> — imports new cases and refreshes existing loan numbers.
                        <ul>
                            <li>Valid rows save immediately; failed rows are listed after import.</li>
                            <li>Requires a <strong>Loan Number</strong> column in your sheet.</li>
                            <li>Case Vault PDFs are queued automatically for new import batches.</li>
                        </ul>
                    </div>
                    <div class="bn-import-help" invisible="import_type != 'pod_status'">
                        <strong>POD status</strong> — updates Notice 1, Interim Order 1, and Award delivery tracking.
                        <ul>
                            <li>Required: <strong>Loan Number</strong>, notice/document type, POD or delivery status.</li>
                            <li>Optional: dispatch date and delivery date columns.</li>
                        </ul>
                    </div>
                </div>

                <div class="bn-import-result" invisible="not result_summary">
                    <div class="bn-import-result__badge" invisible="import_state != 'done'">
                        <i class="fa fa-check"/> Import completed
                    </div>
                    <group string="Summary">
                        <field name="result_summary" nolabel="1" widget="text"/>
                    </group>
                    <group string="Failed rows" invisible="not error_log">
                        <field name="error_log" nolabel="1" widget="text"/>
                    </group>
                </div>

                <footer>
                    <button name="action_import" string="Import now" type="object"
                            class="btn-primary" icon="fa-upload"
                            invisible="result_summary"/>
                    <button name="action_import" string="Import again" type="object"
                            class="btn-primary" icon="fa-refresh"
                            invisible="not result_summary"/>
                    <button name="action_view_cases" string="Open Cases" type="object"
                            class="btn-secondary" icon="fa-table"
                            invisible="import_state != 'done'"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bharat_loan_portfolio_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Excel</field>
        <field name="res_model">bharat.loan.portfolio.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_bharat_arbitration_invoice_loader_wizard_form" model="ir.ui.view">
        <field name="name">bharat.arbitration.invoice.line.loader.wizard.form</field>
        <field name="model">bharat.arbitration.invoice.line.loader.wizard</field>
        <field name="arch" type="xml">
            <form string="Bill batch (consolidated)">
                <group>
                    <group>
                        <field name="batch_number" placeholder="e.g. BN-2026-001"/>
                        <field name="milestone_code"/>
                    </group>
                    <group>
                        <field name="preview_case_count" readonly="1" string="Pending cases"/>
                        <field name="preview_total_amount" readonly="1"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="move_id" placeholder="Optional — leave empty to create new invoice"/>
                    </group>
                </group>
                <field name="preview_hint" readonly="1" nolabel="1" class="text-muted"/>
                <div class="alert alert-info" role="alert">
                    Creates <b>one posted invoice</b> with a single summary line (qty = case count)
                    and a full <b>annexure</b> listing every loan, case number, borrower, and rate per action.
                    Charges accrue automatically when cases exit each milestone (Move to next stage).
                </div>
                <footer>
                    <button name="action_apply" string="Create consolidated invoice" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bharat_consolidated_billing_wizard" model="ir.actions.act_window">
        <field name="name">Bill batch (consolidated)</field>
        <field name="res_model">bharat.arbitration.invoice.line.loader.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
