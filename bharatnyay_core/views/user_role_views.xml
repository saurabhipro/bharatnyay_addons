<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bharat_user_role_assignment_search" model="ir.ui.view">
        <field name="name">bharat.user.role.assignment.search</field>
        <field name="model">bharat.user.role.assignment</field>
        <field name="arch" type="xml">
            <search>
                <field name="user_id"/>
                <field name="role"/>
                <field name="region_id"/>
                <field name="borrower_state_id"/>
                <field name="branch_id"/>
                <field name="location_id"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Role" name="grp_role" context="{'group_by': 'role'}"/>
                    <filter string="User" name="grp_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Branch" name="grp_branch" context="{'group_by': 'branch_id'}"/>
                    <filter string="Location" name="grp_location" context="{'group_by': 'location_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_bharat_user_role_assignment_tree" model="ir.ui.view">
        <field name="name">bharat.user.role.assignment.list</field>
        <field name="model">bharat.user.role.assignment</field>
        <field name="arch" type="xml">
            <list string="User Role Assignments" editable="bottom">
                <field name="user_id"/>
                <field name="role"/>
                <field name="region_id" optional="show"/>
                <field name="borrower_state_id" optional="show"/>
                <field name="branch_id" optional="show"/>
                <field name="location_id" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_bharat_user_role_assignment_form" model="ir.ui.view">
        <field name="name">bharat.user.role.assignment.form</field>
        <field name="model">bharat.user.role.assignment</field>
        <field name="arch" type="xml">
            <form string="User Role Assignment">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="role"/>
                            <field name="active"/>
                        </group>
                        <group string="Location scope">
                            <field name="region_id"/>
                            <field name="borrower_state_id"/>
                            <field name="branch_id"/>
                            <field name="location_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" placeholder="Optional scope notes, escalation notes, panel details..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_bharat_user_role_assignment" model="ir.actions.act_window">
        <field name="name">User roles</field>
        <field name="res_model">bharat.user.role.assignment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bharat_user_role_assignment_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Assign operational roles by geography/location.</p>
            <p>Use this to map users as Case Manager, Arbitrator, Borrower, or Lender at region/state/branch/location level.</p>
        </field>
    </record>
</odoo>
