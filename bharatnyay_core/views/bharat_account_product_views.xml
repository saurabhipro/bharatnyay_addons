<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_template_form_bharat_arbitration" model="ir.ui.view">
        <field name="name">product.template.form.bharat.arbitration</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='list_price']" position="after">
                <field name="bharat_arbitration_stage"/>
            </xpath>
        </field>
    </record>

    <record id="product_template_tree_arbitration_billing" model="ir.ui.view">
        <field name="name">product.template.list.bharat.arbitration</field>
        <field name="model">product.template</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <list string="Products" multi_edit="1">
                <field name="currency_id" column_invisible="True"/>
                <field name="cost_currency_id" column_invisible="True"/>
                <field name="is_favorite" widget="boolean_favorite" optional="show" nolabel="1"/>
                <field name="name" string="Product Name"/>
                <field name="list_price" string="Sales Price" widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
                <field name="standard_price" string="Cost" widget="monetary"
                       options="{'currency_field': 'cost_currency_id'}" readonly="1"/>
                <field name="bharat_arbitration_stage" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="action_product_template_arbitration_billing" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('bharatnyay_core.product_template_tree_arbitration_billing')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('product.product_template_only_form_view')}),
        ]"/>
        <field name="domain">[('bharat_arbitration_stage', '!=', False)]</field>
        <field name="context">{'default_type': 'service', 'default_bharat_arbitration_stage': 'notice_1'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create one service product per arbitration milestone.
            </p>
            <p>
                Set <b>Arbitration billing stage</b> and set <b>Sales price</b> in <b>USD</b> (set product currency to USD
                or price in USD per your accounting setup). NBFC-specific amounts: use partner <b>pricelists</b>.
            </p>
        </field>
    </record>

    <record id="view_move_form_bharat_arbitration" model="ir.ui.view">
        <field name="name">account.move.form.bharat.arbitration</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_arbitration_line_loader"
                        string="Create consolidated invoice"
                        type="object"
                        class="btn-secondary"
                        invisible="move_type != 'out_invoice' or state != 'draft'"/>
                <button name="action_print_arbitration_annexure"
                        string="Print annexure"
                        type="object"
                        class="btn-secondary"
                        invisible="not bharat_annexure_line_ids"/>
            </xpath>
            <xpath expr="//field[@name='ref']" position="after">
                <field name="bharat_loan_id" readonly="1"
                       invisible="not bharat_loan_id"/>
                <field name="bharat_loan_number" readonly="1"
                       invisible="not bharat_loan_id"/>
                <field name="bharat_case_number" readonly="1"
                       invisible="not bharat_case_number"/>
                <field name="bharat_milestone_code" readonly="1"
                       invisible="not bharat_milestone_code"/>
                <field name="bharat_invoice_batch_ref"
                       readonly="state != 'draft'"
                       invisible="not bharat_invoice_batch_ref and not bharat_arbitration_invoice"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Annexure" name="bharat_annexure"
                      invisible="not bharat_annexure_line_ids">
                    <field name="bharat_annexure_case_count" readonly="1"/>
                    <field name="bharat_annexure_line_ids" nolabel="1" readonly="1">
                        <list create="0" delete="0" edit="0">
                            <field name="loan_number"/>
                            <field name="case_number"/>
                            <field name="customer_name"/>
                            <field name="milestone_label"/>
                            <field name="unit_price"/>
                            <field name="quantity"/>
                            <field name="amount"/>
                        </list>
                    </field>
                </page>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <field name="bharat_arbitration_invoice" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_invoice_tree_bharat_arbitration" model="ir.ui.view">
        <field name="name">account.invoice.list.bharat.arbitration</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_partner_display_name']" position="after">
                <field name="bharat_invoice_batch_ref" string="Batch no" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
