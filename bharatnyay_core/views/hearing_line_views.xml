<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bharat_loan_hearing_line_search" model="ir.ui.view">
        <field name="name">bharat.loan.hearing.line.search</field>
        <field name="model">bharat.loan.hearing.line</field>
        <field name="arch" type="xml">
            <search string="Hearings">
                <field name="batch_number"/>
                <field name="loan_number"/>
                <field name="case_number"/>
                <field name="customer_name"/>
                <field name="loan_id"/>
                <field name="arbitrator_id"/>
                <field name="calendar_event_id"/>
                <field name="hearing_datetime"/>
                <field name="hearing_slot_label"/>
                <separator/>
                <filter string="Today" name="today" date="hearing_datetime"/>
                <filter string="Scheduled" name="scheduled" domain="[('status', '=', 'scheduled')]"/>
                <filter string="Conducted" name="conducted" domain="[('status', '=', 'conducted')]"/>
                <separator/>
                <filter string="Batch" name="group_batch" context="{'group_by': 'batch_number'}"/>
                <filter string="Arbitrator" name="group_arbitrator" context="{'group_by': 'arbitrator_id'}"/>
                <filter string="Milestone" name="group_milestone" context="{'group_by': 'milestone_code'}"/>
                <filter string="Slot" name="group_slot" context="{'group_by': 'hearing_slot_label'}"/>
            </search>
        </field>
    </record>

    <record id="view_bharat_loan_hearing_line_tree" model="ir.ui.view">
        <field name="name">bharat.loan.hearing.line.list</field>
        <field name="model">bharat.loan.hearing.line</field>
        <field name="arch" type="xml">
            <list string="Hearings" default_order="batch_number, hearing_datetime asc" multi_edit="0">
                <button name="action_join_meeting" type="object" string="Join" class="btn-link" title="Join Odoo meeting"/>
                <button name="action_reschedule_hearing" type="object" string="Reschedule" class="btn-link"/>
                <field name="batch_number"/>
                <field name="loan_number"/>
                <field name="case_number" optional="show"/>
                <field name="customer_name" optional="show"/>
                <field name="hearing_datetime"/>
                <field name="hearing_slot_label" string="Slot number"/>
                <field name="hearing_slot_time_label" string="Slot time" optional="show"/>
                <field name="minutes_remaining" optional="show"/>
                <field name="arbitrator_id" optional="show"/>
                <field name="milestone_code" optional="hide"/>
                <field name="loan_id" optional="hide"/>
                <field name="calendar_event_id" optional="hide"/>
                <field name="invitees" optional="hide"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_bharat_loan_hearing_line_calendar" model="ir.ui.view">
        <field name="name">bharat.loan.hearing.line.calendar</field>
        <field name="model">bharat.loan.hearing.line</field>
        <field name="arch" type="xml">
            <calendar string="Hearings"
                      date_start="hearing_datetime"
                      mode="week"
                      color="batch_number"
                      event_open_popup="true"
                      quick_create="false">
                <field name="batch_number"/>
                <field name="loan_number"/>
                <field name="customer_name"/>
                <field name="loan_id"/>
                <field name="calendar_event_id"/>
            </calendar>
        </field>
    </record>

    <record id="view_bharat_loan_hearing_line_form" model="ir.ui.view">
        <field name="name">bharat.loan.hearing.line.form</field>
        <field name="model">bharat.loan.hearing.line</field>
        <field name="arch" type="xml">
            <form string="Hearing">
                <header>
                    <button name="action_join_meeting" type="object" string="Join meeting" class="btn-primary"/>
                    <button name="action_reschedule_hearing" type="object" string="Reschedule hearing"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="batch_number" readonly="1"/>
                            <field name="loan_number" readonly="1"/>
                            <field name="case_number" readonly="1"/>
                            <field name="loan_id" readonly="1"/>
                            <field name="customer_name" readonly="1"/>
                            <field name="arbitrator_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="hearing_datetime"/>
                            <field name="hearing_slot_label" readonly="1"/>
                            <field name="hearing_slot_time_label" readonly="1"/>
                            <field name="minutes_remaining" readonly="1"/>
                            <field name="calendar_event_id" readonly="1"/>
                            <field name="invitees"/>
                            <field name="notes"/>
                            <field name="created_by_id" readonly="1"/>
                            <field name="status"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_bharat_loan_hearing_line_batch" model="ir.actions.act_window">
        <field name="name">Hearings by batch</field>
        <field name="res_model">bharat.loan.hearing.line</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="search_view_id" ref="view_bharat_loan_hearing_line_search"/>
        <field name="context">{'search_default_group_batch': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hearings match this filter.
            </p>
            <p>
                Use <b>Batch</b> grouping to review hearings batch-wise. Switch to calendar for the week view.
            </p>
        </field>
    </record>

    <record id="action_bharat_loan_hearing_line_arbitrator_today" model="ir.actions.act_window">
        <field name="name">Today's hearings</field>
        <field name="res_model">bharat.loan.hearing.line</field>
        <field name="view_mode">calendar,list,form</field>
        <field name="search_view_id" ref="view_bharat_loan_hearing_line_search"/>
        <field name="domain">[('loan_id.arbitrator_id', '=', uid)]</field>
        <field name="context">{'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hearings match this filter.
            </p>
            <p>
                Open the week view to browse other dates. Only loans where you are the arbitrator appear here.
            </p>
        </field>
    </record>
</odoo>
