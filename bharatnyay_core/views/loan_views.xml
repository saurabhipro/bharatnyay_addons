<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bharat_loan_search" model="ir.ui.view">
        <field name="name">bharat.loan.search</field>
        <field name="model">bharat.loan</field>
        <field name="arch" type="xml">
            <search>
                <!-- Omnibox: one chip searches loan #, BharatNyay case #, batch, borrower, respondent A/C -->
                <field name="loan_number"
                       string="Loan / case # / borrower"
                       filter_domain="['|', '|', '|', '|', '|', '|',
                                       ('loan_number', 'ilike', self),
                                       ('case_number', 'ilike', self),
                                       ('batch_number', 'ilike', self),
                                       ('customer_name', 'ilike', self),
                                       ('respondent_loan_reference', 'ilike', self),
                                       ('borrower_phone', 'ilike', self),
                                       ('borrower_email', 'ilike', self)]"/>
                <field name="case_number" string="BharatNyay case #"/>
                <field name="batch_number"/>
                <field name="company_id"/>
                <field name="customer_name"/>
                <field name="region_id"/>
                <field name="borrower_state_id"/>
                <field name="branch_id"/>
                <field name="location_id"/>
                <field name="product_class_id"/>
                <field name="law_firm_id"/>
                <field name="product"/>
                <field name="case_manager_id"/>
                <field name="workflow_phase"/>
                <field name="milestone_id"/>
                <field name="milestone_code"/>
                <field name="respondent_name"/>
                <separator/>
                <filter string="Has claim" name="has_claim" domain="[('claim_amount','&gt;',0)]"/>
                <filter string="Commencement" name="wf_commencement" domain="[('milestone_code','=','commencement')]"/>
                <filter string="Notice 1" name="wf_notice_1" domain="[('milestone_code','=','notice_1')]"/>
                <filter string="Notice 2" name="wf_notice_2" domain="[('milestone_code','=','notice_2')]"/>
                <filter string="Notice 3" name="wf_notice_3" domain="[('milestone_code','=','notice_3')]"/>
                <filter string="Hearing 1" name="wf_hearing_1" domain="[('milestone_code','=','hearing_1')]"/>
                <filter string="Hearing 2" name="wf_hearing_2" domain="[('milestone_code','=','hearing_2')]"/>
                <filter string="Hearing 3" name="wf_hearing_3" domain="[('milestone_code','=','hearing_3')]"/>
                <filter string="Award" name="wf_award" domain="[('milestone_code','=','award')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Region" name="grp_region" context="{'group_by': 'region_id'}"/>
                    <filter string="State" name="grp_state" context="{'group_by': 'borrower_state_id'}"/>
                    <filter string="Branch" name="grp_branch" context="{'group_by': 'branch_id'}"/>
                    <filter string="Product class" name="grp_pclass" context="{'group_by': 'product_class_id'}"/>
                    <filter string="Product" name="grp_product" context="{'group_by': 'product'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_bharat_loan_tree" model="ir.ui.view">
        <field name="name">bharat.loan.list</field>
        <field name="model">bharat.loan</field>
        <field name="arch" type="xml">
            <list string="Loans">
                <header>
                    <button name="%(bharatnyay_core.action_bharat_loan_portfolio_import_wizard)d"
                            type="action"
                            string="Import Excel"
                            class="btn-secondary"
                            display="always"
                            icon="fa-upload"/>
                </header>
                <field name="case_number"/>
                <field name="batch_number" optional="show"/>
                <field name="company_id" optional="show"/>
                <field name="loan_number"/>
                <field name="customer_name"/>
                <field name="region_id" optional="hide"/>
                <field name="borrower_state_id" optional="hide"/>
                <field name="branch_id" optional="show"/>
                <field name="location_id" string="Location" optional="show"/>
                <field name="financed_amount" sum="Financed"/>
                <field name="current_pos" sum="POS"/>
                <field name="milestone_id" string="Milestone" optional="show"/>
                <field name="state_display" string="Milestone" optional="hide"/>
                <field name="milestone_code" column_invisible="1"/>
                <field name="workflow_section" optional="hide"/>
                <field name="workflow_phase" optional="hide"/>
                <field name="claim_amount" sum="Claim"/>
                <field name="lok_adalat_date" optional="show"/>
                <field name="disbursement_date" optional="show"/>
                <field name="case_manager_id" optional="show"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_bharat_loan_kanban" model="ir.ui.view">
        <field name="name">bharat.loan.kanban</field>
        <field name="model">bharat.loan</field>
        <field name="arch" type="xml">
            <kanban default_group_by="milestone_id" records_draggable="1">
                <field name="loan_number"/>
                <field name="customer_name"/>
                <field name="milestone_id"/>
                <field name="branch_id"/>
                <field name="current_pos"/>
                <field name="claim_amount"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="o_kanban_record_top">
                                <strong><field name="loan_number"/></strong>
                            </div>
                            <div><field name="customer_name"/></div>
                            <div class="text-muted"><field name="branch_id"/></div>
                            <div class="mt-2">
                                <span class="me-3">POS: <field name="current_pos" widget="monetary"/></span>
                                <span>Claim: <field name="claim_amount" widget="monetary"/></span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_bharat_loan_calendar" model="ir.ui.view">
        <field name="name">bharat.loan.calendar</field>
        <field name="model">bharat.loan</field>
        <field name="arch" type="xml">
            <calendar string="Loan Calendar" date_start="deliver_date" color="milestone_id" mode="month">
                <field name="loan_number"/>
                <field name="customer_name"/>
                <field name="milestone_id"/>
                <field name="branch_id"/>
                <field name="deliver_status"/>
            </calendar>
        </field>
    </record>

    <record id="view_bharat_loan_form" model="ir.ui.view">
        <field name="name">bharat.loan.form</field>
        <field name="model">bharat.loan</field>
        <field name="arch" type="xml">
            <form string="Loan" class="o_bharat_loan_form">
                <header>
                    <field name="company_id" invisible="1"/>
                    <field name="allowed_milestone_ids" invisible="1"/>
                    <field name="state_is_arbitrator" invisible="1"/>
                    <field name="is_case_locked" invisible="1"/>
                    <field name="milestone_code" invisible="1"/>
                    <field name="can_move_to_next_stage" invisible="1"/>
                    <field name="next_milestone_label" invisible="1"/>
                    <field name="milestone_id" widget="statusbar"
                           domain="[('id', 'in', allowed_milestone_ids)]"
                           readonly="1"
                           options="{'clickable': '0'}"/>
                    <button name="action_move_to_next_stage" type="object"
                            string="Move to next stage" class="oe_highlight"
                            invisible="is_case_locked or not can_move_to_next_stage"
                            confirm="Advance this case to the next workflow milestone?"/>
                    <button name="action_reschedule_hearing" type="object" string="Reschedule hearing"
                            invisible="is_case_locked or milestone_code not in ('hearing_1', 'hearing_2', 'hearing_3')"/>
                    <button name="action_send_hearing_video_link" type="object" string="Send Hearing Link"
                            invisible="is_case_locked or milestone_code not in ('hearing_1', 'hearing_2', 'hearing_3')"/>
                    <button name="action_join_hearing_meeting" type="object" string="Join Meeting Online"
                            invisible="is_case_locked or milestone_code not in ('hearing_1', 'hearing_2', 'hearing_3')"/>
                    <button name="action_pass_interim_award" type="object" string="Pass Interim Award"
                            invisible="is_case_locked or milestone_code not in ('hearing_1', 'hearing_2', 'hearing_3')"/>
                    <button name="action_download_award_letter" type="object" string="Download award letter"
                            class="oe_highlight"
                            invisible="milestone_code != 'award'"/>
                    <button name="action_upload_signed_award" type="object" string="Upload signed award"
                            invisible="milestone_code != 'award'"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_notice_lines" type="object" class="oe_stat_button" icon="fa-envelope-o">
                            <field name="notice_count" widget="statinfo" string="Notices"/>
                        </button>
                        <button name="action_open_hearing_lines" type="object" class="oe_stat_button" icon="fa-video-camera">
                            <field name="hearing_log_count" widget="statinfo" string="Hearings"/>
                        </button>
                        <button name="action_open_interim_orders" type="object" class="oe_stat_button" icon="fa-gavel">
                            <field name="interim_order_count" widget="statinfo" string="Interim orders"/>
                        </button>
                        <button name="action_open_award_documents" type="object" class="oe_stat_button" icon="fa-trophy">
                            <field name="award_document_count" widget="statinfo" string="Awards"/>
                        </button>
                        <button name="action_open_arbitration_invoices" type="object" class="oe_stat_button" icon="fa-file-text-o"
                                invisible="arbitration_invoice_count == 0">
                            <field name="arbitration_invoice_count" widget="statinfo" string="Invoices"/>
                        </button>
                    </div>
                   
                    <field name="workflow_section" invisible="1"/>

                    <div class="bn-loan-hero">
                        <div class="bn-hero-inner">
                            <div class="bn-hero-head">
                                <div class="bn-hero-ids">
                                    <span class="bn-id-pill">
                                        <span class="bn-id-pill__k">Case</span>
                                        <field name="case_number" readonly="1" nolabel="1"/>
                                    </span>
                                    <span class="bn-id-pill">
                                        <span class="bn-id-pill__k">Batch</span>
                                        <field name="batch_number" readonly="1" nolabel="1"/>
                                    </span>
                                </div>
                                <span class="bn-stage-pill">
                                    <field name="state_display" readonly="1" nolabel="1"/>
                                </span>
                            </div>
                            <div class="bn-hero-main">
                                <div class="bn-customer">
                                    <field name="customer_name" readonly="1" nolabel="1" placeholder="Customer name"/>
                                </div>
                                <div class="bn-hero-sub">
                                    <span class="bn-hero-sub__item">
                                        <i class="fa fa-file-text-o" title="Loan number" aria-hidden="true"/>
                                        <field name="loan_number" readonly="1" nolabel="1"/>
                                    </span>
                                    <span class="bn-hero-sub__dot" aria-hidden="true">·</span>
                                    <span class="bn-hero-sub__item">
                                        <i class="fa fa-map-marker" title="Location" aria-hidden="true"/>
                                        <field name="location_id" readonly="1" nolabel="1"/>
                                    </span>
                                    <span class="bn-hero-sub__dot" aria-hidden="true">·</span>
                                    <span class="bn-hero-sub__item">
                                        <i class="fa fa-tag" title="Product class" aria-hidden="true"/>
                                        <field name="product_class_id" readonly="1" nolabel="1"/>
                                    </span>
                                </div>
                            </div>
                            <div class="bn-hero-metrics">
                                <div class="bn-metric bn-metric--financed">
                                    <span class="bn-metric__label">Financed</span>
                                    <field name="hero_financed_display" readonly="1" nolabel="1" class="bn-metric__value"/>
                                </div>
                                <div class="bn-metric bn-metric--pos">
                                    <span class="bn-metric__label">Current POS</span>
                                    <field name="hero_pos_display" readonly="1" nolabel="1" class="bn-metric__value"/>
                                </div>
                                <div class="bn-metric bn-metric--claim">
                                    <span class="bn-metric__label">Claim</span>
                                    <field name="hero_claim_display" readonly="1" nolabel="1" class="bn-metric__value"/>
                                </div>
                                <div class="bn-metric bn-metric--disbursed">
                                    <span class="bn-metric__label">Disbursed</span>
                                    <field name="hero_disburse_display" readonly="1" nolabel="1" class="bn-metric__value"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <field name="currency_id" invisible="1"/>
                    <field name="case_manager_manual" invisible="1"/>
                    <div class="bn-form-body">

                        <!-- Imported data (read-only) — 3 columns, no Amounts (shown in hero) -->
                        <div class="bn-section">
                            <div class="bn-section__head">
                                <span class="bn-section__title">Loan data</span>
                                <span class="bn-section__badge">Imported (read-only)</span>
                            </div>
                            <div class="bn-section__body">
                                <div class="bn-import-grid">
                                    <div class="bn-import-col">
                                        <div class="bn-import-col__heading"><i class="fa fa-user-o"/> Borrower</div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">Email</span>
                                            <field name="borrower_email" readonly="1" nolabel="1" widget="email" class="bn-import-row__v"/>
                                        </div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">Phone</span>
                                            <field name="borrower_phone" readonly="1" nolabel="1" widget="phone" class="bn-import-row__v"/>
                                        </div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">State</span>
                                            <field name="borrower_state_id" readonly="1" nolabel="1" class="bn-import-row__v"/>
                                        </div>
                                        <div class="bn-import-row" invisible="not borrower_address">
                                            <span class="bn-import-row__k">Address</span>
                                            <field name="borrower_address" readonly="1" nolabel="1" class="bn-import-row__v"/>
                                        </div>
                                    </div>
                                    <div class="bn-import-col">
                                        <div class="bn-import-col__heading"><i class="fa fa-map-marker"/> Geography</div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">Region</span>
                                            <field name="region_id" readonly="1" nolabel="1" class="bn-import-row__v"/>
                                        </div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">Location</span>
                                            <field name="location_id" readonly="1" nolabel="1" class="bn-import-row__v"/>
                                        </div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">Branch</span>
                                            <field name="branch_id" readonly="1" nolabel="1" class="bn-import-row__v"/>
                                        </div>
                                    </div>
                                    <div class="bn-import-col">
                                        <div class="bn-import-col__heading"><i class="fa fa-briefcase"/> Product / Legal</div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">Product class</span>
                                            <field name="product_class_id" readonly="1" nolabel="1" class="bn-import-row__v"/>
                                        </div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">Product code</span>
                                            <field name="product" readonly="1" nolabel="1" class="bn-import-row__v"/>
                                        </div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">Write-off</span>
                                            <field name="writeoff_id" readonly="1" nolabel="1" class="bn-import-row__v"/>
                                        </div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">Law firm</span>
                                            <field name="law_firm_id" readonly="1" nolabel="1" class="bn-import-row__v"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Case management (editable) -->
                        <div class="bn-section bn-section--edit">
                            <div class="bn-section__head">
                                <span class="bn-section__title">Case management</span>
                                <span class="bn-section__badge bn-section__badge--edit">Editable</span>
                            </div>
                            <div class="bn-section__body">
                                <div class="bn-import-grid">
                                    <div class="bn-import-col">
                                        <div class="bn-import-col__heading"><i class="fa fa-building-o"/> Assignment</div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">Lender / company</span>
                                            <field name="company_id" readonly="is_case_locked" nolabel="1" class="bn-import-row__v"/>
                                        </div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">Case manager</span>
                                            <field name="case_manager_id" options="{'no_create': True}" readonly="is_case_locked" nolabel="1" class="bn-import-row__v"/>
                                        </div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">Arbitrator</span>
                                            <field name="arbitrator_id" options="{'no_create': True}" readonly="is_case_locked" nolabel="1" class="bn-import-row__v"/>
                                        </div>
                                    </div>
                                    <div class="bn-import-col">
                                        <div class="bn-import-col__heading"><i class="fa fa-calendar"/> Dates</div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">Deliver date</span>
                                            <field name="deliver_date" readonly="is_case_locked" nolabel="1" class="bn-import-row__v"/>
                                        </div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">Lok Adalat date</span>
                                            <field name="lok_adalat_date" readonly="is_case_locked" nolabel="1" class="bn-import-row__v"/>
                                        </div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">Deliver status</span>
                                            <field name="deliver_status" readonly="is_case_locked" nolabel="1" class="bn-import-row__v"/>
                                        </div>
                                    </div>
                                    <div class="bn-import-col">
                                        <div class="bn-import-col__heading"><i class="fa fa-info-circle"/> Details</div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">Notice hand</span>
                                            <field name="notice_hand" readonly="is_case_locked" nolabel="1" class="bn-import-row__v"/>
                                        </div>
                                        <div class="bn-import-row">
                                            <span class="bn-import-row__k">Respondent ref.</span>
                                            <field name="respondent_loan_reference" readonly="is_case_locked" nolabel="1" class="bn-import-row__v"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <notebook class="bn-loan-notebook" readonly="is_case_locked">
                        <page string="Notices" name="page_notices">
                            <group string="All notices sent / responses">
                                <field name="notice_line_ids" nolabel="1" readonly="is_case_locked">
                                    <list create="0" delete="0" edit="0" multi_edit="0">
                                        <field name="notice_number"/>
                                        <field name="notice_label" readonly="1"/>
                                        <field name="sent_on"/>
                                        <field name="sent_by_id"/>
                                        <field name="recipient_partner_id"/>
                                        <field name="sent_to"/>
                                        <field name="subject"/>
                                        <field name="notice_pdf_filename"/>
                                        <field name="response_received_on" readonly="1"/>
                                        <field name="response_pdf_filename" readonly="1"/>
                                        <button name="action_record_response" type="object" string="Record reply"
                                                class="btn-link" icon="fa-inbox"
                                                invisible="parent.is_case_locked"/>
                                    </list>
                                    <form string="Notice" create="0" edit="0" delete="0">
                                        <header>
                                            <button name="action_record_response" type="object"
                                                    string="Record respondent reply" class="btn-primary"
                                                    invisible="parent.is_case_locked"/>
                                        </header>
                                        <sheet>
                                            <!-- compact meta strip -->
                                            <div class="bn-notice-meta">
                                                <span class="bn-notice-meta__item">
                                                    <span class="bn-notice-meta__k">Notice</span>
                                                    <field name="notice_label" readonly="1" nolabel="1"/>
                                                </span>
                                                <span class="bn-notice-meta__sep">·</span>
                                                <span class="bn-notice-meta__item">
                                                    <span class="bn-notice-meta__k">Sent</span>
                                                    <field name="sent_on" readonly="1" nolabel="1"/>
                                                </span>
                                                <span class="bn-notice-meta__sep">·</span>
                                                <span class="bn-notice-meta__item">
                                                    <span class="bn-notice-meta__k">To</span>
                                                    <field name="sent_to" readonly="1" nolabel="1"/>
                                                </span>
                                                <span class="bn-notice-meta__sep" invisible="not response_received_on">·</span>
                                                <span class="bn-notice-meta__item bn-notice-meta__item--replied" invisible="not response_received_on">
                                                    <i class="fa fa-check-circle"/>
                                                    <span class="bn-notice-meta__k">Replied</span>
                                                    <field name="response_received_on" readonly="1" nolabel="1"/>
                                                </span>
                                            </div>

                                            <!-- PDFs side by side -->
                                            <div class="bn-notice-pdfs">
                                                <div class="bn-notice-pdf-col">
                                                    <div class="bn-notice-pdf-col__label">Notice PDF</div>
                                                    <field name="notice_pdf" filename="notice_pdf_filename" widget="pdf_viewer" nolabel="1"/>
                                                    <field name="notice_pdf_filename" invisible="1"/>
                                                </div>
                                                <div class="bn-notice-pdf-col" invisible="not response_pdf">
                                                    <div class="bn-notice-pdf-col__label">Response PDF</div>
                                                    <field name="response_pdf" filename="response_pdf_filename" widget="pdf_viewer" readonly="1" nolabel="1"/>
                                                    <field name="response_pdf_filename" invisible="1"/>
                                                </div>
                                            </div>
                                        </sheet>
                                    </form>
                                </field>
                            </group>
                        </page>
                        <page string="Hearing" name="page_hearing">
                            <group>
                                <group string="Schedule">
                                    <field name="hearing_datetime"/>
                                    <field name="hearing_link_type"/>
                                    <field name="hearing_video_url" widget="url"
                                           invisible="hearing_link_type == 'odoo'"/>
                                    <field name="hearing_invite_user_ids" widget="many2many_tags"
                                           options="{'no_create': True}"/>
                                    <field name="hearing_notes"/>
                                </group>
                                <group string="Interim award">
                                    <field name="interim_award_date"/>
                                    <field name="interim_award_amount"/>
                                    <field name="interim_award_notes"/>
                                </group>
                            </group>
                            <separator string="Hearing log"/>
                            <field name="hearing_line_ids" nolabel="1" readonly="is_case_locked">
                                <list create="0" delete="0" edit="0">
                                    <field name="hearing_datetime"/>
                                    <field name="link_type"/>
                                    <field name="meeting_link" widget="url"/>
                                    <field name="invitees"/>
                                    <field name="created_by_id"/>
                                </list>
                                <form string="Hearing detail" create="0" edit="0" delete="0">
                                    <group>
                                        <group>
                                            <field name="hearing_datetime"/>
                                            <field name="link_type"/>
                                            <field name="meeting_link" widget="url"/>
                                            <field name="invitees"/>
                                            <field name="created_by_id"/>
                                        </group>
                                        <group>
                                            <field name="notes"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                            <separator string="Interim orders"/>
                            <field name="interim_order_ids" nolabel="1" readonly="is_case_locked">
                                <list create="0" delete="0" edit="0">
                                    <field name="order_date"/>
                                    <field name="order_type"/>
                                    <field name="purpose" optional="show"/>
                                    <field name="passed_by" optional="show"/>
                                    <field name="amount"/>
                                    <field name="common_directions" optional="hide"/>
                                    <field name="notes" optional="hide"/>
                                    <field name="order_pdf_filename" optional="hide"/>
                                </list>
                                <form string="Interim order" create="0" edit="0" delete="0">
                                    <group>
                                        <group>
                                            <field name="order_date"/>
                                            <field name="order_type"/>
                                            <field name="purpose"/>
                                            <field name="typical_loan_type"/>
                                            <field name="passed_by"/>
                                            <field name="hearing_line_id"/>
                                            <field name="amount"/>
                                            <field name="created_by_id"/>
                                        </group>
                                        <group>
                                            <field name="common_directions"/>
                                            <field name="order_pdf" filename="order_pdf_filename" widget="pdf_viewer"/>
                                            <field name="order_pdf_filename" invisible="1"/>
                                            <field name="notes"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Awards" name="page_awards">
                            <field name="award_document_ids" nolabel="1">
                                <list create="0" delete="0">
                                    <field name="award_type"/>
                                    <field name="award_date"/>
                                    <field name="draft_generated_on" optional="show"/>
                                    <field name="is_signed" widget="boolean"/>
                                    <field name="signed_on" optional="show"/>
                                    <field name="created_by_id" optional="hide"/>
                                    <field name="award_notes" optional="hide"/>
                                    <button name="action_download_award_letter" type="object"
                                            string="Download draft" icon="fa-download"
                                            invisible="award_type != 'final'"/>
                                    <button name="action_upload_signed_award" type="object"
                                            string="Upload signed" icon="fa-upload"
                                            invisible="award_type != 'final'"/>
                                </list>
                                <form string="Award document" create="0" delete="0">
                                    <header>
                                        <button name="action_download_award_letter" type="object"
                                                string="Download award letter" class="oe_highlight"
                                                invisible="award_type != 'final'"/>
                                        <button name="action_upload_signed_award" type="object"
                                                string="Upload signed award"
                                                invisible="award_type != 'final'"/>
                                    </header>
                                    <group>
                                        <group>
                                            <field name="award_type" readonly="1"/>
                                            <field name="award_date" readonly="1"/>
                                            <field name="created_by_id" readonly="1"/>
                                            <field name="draft_generated_on" readonly="1"/>
                                            <field name="signed_on" readonly="1"/>
                                            <field name="is_signed" readonly="1"/>
                                        </group>
                                        <group>
                                            <field name="draft_award_pdf" filename="draft_award_pdf_filename"
                                                   widget="pdf_viewer" readonly="1"/>
                                            <field name="draft_award_pdf_filename" invisible="1"/>
                                            <field name="award_pdf" filename="award_pdf_filename"
                                                   widget="pdf_viewer" readonly="1"
                                                   string="Signed award PDF"/>
                                            <field name="award_pdf_filename" invisible="1"/>
                                            <field name="award_notes"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </page>

                        
                    </notebook>
                </sheet>
                <chatter open_attachments="True"/>
            </form>
        </field>
    </record>

