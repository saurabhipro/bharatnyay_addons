<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_move_form_bharat_arbitration" model="ir.ui.view">
        <field name="name">account.move.form.bharat.arbitration</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_arbitration_line_loader"
                        string="Create consolidated invoice"
                        type="object"
                        class="btn-secondary"
                        invisible="move_type != 'out_invoice' or state != 'draft'"/>
                <button name="action_print_arbitration_annexure"
                        string="Print annexure"
                        type="object"
                        class="btn-secondary"
                        invisible="not bharat_annexure_line_ids"/>
            </xpath>
            <xpath expr="//field[@name='ref']" position="after">
                <field name="bharat_loan_id" readonly="1"
                       invisible="not bharat_loan_id"/>
                <field name="bharat_loan_number" readonly="1"
                       invisible="not bharat_loan_id"/>
                <field name="bharat_case_number" readonly="1"
                       invisible="not bharat_case_number"/>
                <field name="bharat_milestone_code" readonly="1"
                       invisible="not bharat_milestone_code"/>
                <field name="bharat_invoice_batch_ref"
                       readonly="state != 'draft'"
                       invisible="not bharat_invoice_batch_ref and not bharat_arbitration_invoice"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Annexure" name="bharat_annexure"
                      invisible="not bharat_annexure_line_ids">
                    <field name="bharat_annexure_case_count" readonly="1"/>
                    <field name="bharat_annexure_line_ids" nolabel="1" readonly="1">
                        <list create="0" delete="0" edit="0">
                            <field name="loan_number"/>
                            <field name="case_number"/>
                            <field name="customer_name"/>
                            <field name="milestone_label"/>
                            <field name="unit_price"/>
                            <field name="quantity"/>
                            <field name="amount"/>
                        </list>
                    </field>
                </page>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <field name="bharat_arbitration_invoice" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_invoice_tree_bharat_arbitration" model="ir.ui.view">
        <field name="name">account.invoice.list.bharat.arbitration</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_partner_display_name']" position="after">
                <field name="bharat_invoice_batch_ref" string="Batch no" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
